Cell[CellGroupData[{

Cell["Fabry-Perot functions", "Section",
 CellChangeTimes->{{3.983109491538329*^9, 
  3.983109515388942*^9}},ExpressionUUID->"c5ca4f93-522f-4440-a3d8-\
041b19487859"],

Cell[CellGroupData[{

Cell["\<\
\[Phi] = single pass phase
ri = input mirror reflectivity of FP (assuming minus reflectivity inside the \
cavity)
re = end mirror reflectivity of FP (again assuming minus reflectivity inside \
the cavity)
Here I on purpose leave the negative sign out of the exponential, 
although it should be there, because mathematica prefers positive \
exponentials and will simplify weird without them.
We\[CloseCurlyQuote]ll need to remember to set \[Phi] \[Rule] -\[Phi]  at the \
end of this for the plots\
\>", "Subsubsection",
 CellChangeTimes->{{3.983109630088641*^9, 3.98310966188585*^9}, {
  3.983112011243931*^9, 3.983112094323415*^9}, {3.9831323320368023`*^9, 
  3.983132351300036*^9}},ExpressionUUID->"cf17e768-afac-4af0-95bd-\
c9da379afcf7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"refl", "[", 
    RowBox[{"\[Phi]_", ",", "ri_", ",", "re_"}], "]"}], ":=", 
   FractionBox[
    RowBox[{"ri", "-", 
     RowBox[{"re", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "2", "\[Phi]"}], "]"}]}]}], 
    RowBox[{"1", "-", 
     RowBox[{"ri", " ", "re", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}]}]]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gain", "[", 
    RowBox[{"\[Phi]_", ",", "ri_", ",", "re_", ",", "ti_"}], "]"}], ":=", 
   FractionBox["ti", 
    RowBox[{"1", "-", 
     RowBox[{"ri", " ", "re", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}]}]]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"trans", "[", 
    RowBox[{"\[Phi]_", ",", "ri_", ",", "re_", ",", "ti_", ",", "te_"}], 
    "]"}], ":=", 
   FractionBox[
    RowBox[{"ti", " ", "te", " ", 
     RowBox[{"Exp", "[", 
      RowBox[{"I", " ", "\[Phi]"}], "]"}]}], 
    RowBox[{"1", "-", 
     RowBox[{"ri", " ", "re", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}]}]]}], ";"}]}], "Input",\

 CellChangeTimes->{{3.9831095002850122`*^9, 3.9831096150199013`*^9}, {
  3.983112095574795*^9, 3.983112102381688*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"7652ae82-873e-45f6-8b02-68a6554ad481"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tutorial Answers", "Section",
 CellChangeTimes->{{3.983109689985107*^9, 3.983109691007455*^9}, {
  3.983109793355961*^9, 
  3.98310979440313*^9}},ExpressionUUID->"531b5e18-eea6-41c5-ad02-\
800340975e33"],

Cell[CellGroupData[{

Cell[TextData[{
 "1. Write the second cavity reflectivity, gain, and transmission expressions \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "(", 
    SubscriptBox["\[Phi]", "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fea91ca4-ab44-43a5-8b70-2a73f385f13b"],
 "), ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "(", 
    SubscriptBox["\[Phi]", "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a848cc7b-d7d3-444d-9b81-5cd647a16213"],
 "),",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"t", "(", 
     SubscriptBox["\[Phi]", "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d55bd4fc-5db2-4562-94fb-74f52b9f5474"],
 ")."
}], "Subsubsection",
 CellChangeTimes->{{3.983109836107388*^9, 
  3.983109874952895*^9}},ExpressionUUID->"85b20be0-8789-4a7d-8553-\
4ad665c28447"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"r23", "=", 
  RowBox[{"refl", "[", 
   RowBox[{"\[Phi]2", ",", "r2", ",", "r3"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"g23", "=", 
  RowBox[{"gain", "[", 
   RowBox[{"\[Phi]2", ",", "r2", ",", "r3", ",", "t2"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"t23", "=", 
  RowBox[{"trans", "[", 
   RowBox[{"\[Phi]2", ",", "r2", ",", "r3", ",", "t2", ",", "t3"}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.98310971914042*^9, 3.983109788167398*^9}},
 CellLabel->"In[38]:=",ExpressionUUID->"c3f3e725-1200-424e-b711-d29ea1164b18"],

Cell[BoxData[
 FractionBox[
  RowBox[{"r2", "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r3"}]}], 
  RowBox[{"1", "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r2", " ", 
    "r3"}]}]]], "Output",
 CellChangeTimes->{{3.98310976496852*^9, 3.983109788728075*^9}, 
   3.983112104978903*^9},
 CellLabel->"Out[38]=",ExpressionUUID->"4389a223-0f48-46da-a7b0-b068ce07391a"],

Cell[BoxData[
 FractionBox["t2", 
  RowBox[{"1", "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r2", " ", 
    "r3"}]}]]], "Output",
 CellChangeTimes->{{3.98310976496852*^9, 3.983109788728075*^9}, 
   3.983112104980616*^9},
 CellLabel->"Out[39]=",ExpressionUUID->"af730404-fb1a-4b1f-9701-b14e4e78dd7e"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "t2", " ", "t3"}], 
  RowBox[{"1", "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r2", " ", 
    "r3"}]}]]], "Output",
 CellChangeTimes->{{3.98310976496852*^9, 3.983109788728075*^9}, 
   3.98311210498234*^9},
 CellLabel->"Out[40]=",ExpressionUUID->"c70bd109-8158-43fa-81e2-f042b8e72cac"]
}, Open  ]]
