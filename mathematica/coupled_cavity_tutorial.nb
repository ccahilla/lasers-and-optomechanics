Cell[CellGroupData[{

Cell["\<\
2. Write the compound cavity reflectivity, gain, and transmission expressions \
r(\[Phi]1, \[Phi]2), g1(\[Phi]1, \[Phi]2), t(\[Phi]1, \[Phi]2) in terms of \
r1, t1, \[Phi]1, and your expressions from (1)\
\>", "Subsubsection",
 CellChangeTimes->{{3.983109879881328*^9, 
  3.983109909970098*^9}},ExpressionUUID->"d8bb04b9-5831-44a9-8e19-\
19bd24172062"],

Cell[TextData[{
 "Here I use the subscript ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "23"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c2d210bf-5a14-4d7f-95a3-2dd664df2c8e"],
 ", as opposed to r23 above, to allow for the variable representation.\n\
Notice that we have just stacked the usual Fabry-Perot equations, but subbed \
in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "23"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a81dac40-b627-4dd8-a625-e3f93f7d4ef5"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "23"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bf753a79-a154-468b-becc-135e3e00841c"],
 " everywhere.\n\nThere is a very sneaky minus sign I\[CloseCurlyQuote]ve put \
in here, the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", 
    SubscriptBox["r", "23"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e7440beb-2972-4229-a1bb-e28668f3584c"],
 " in all the calls to the functions.\nThis is because, in the Fabry Perot \
functions defined above, we have assumed that the mirrors on the interior of \
the cavity inflict a sign flip (i.e. have a minus sign), while the \
reflections outside the cavity are positive.\nTo recover a plus sign \
reflection on the interior of the Fabry Perot, I must use ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", 
    SubscriptBox["r", "23"]}], TraditionalForm]],ExpressionUUID->
  "7b6f5a59-e733-4c07-bb9b-fa48f877186b"],
 " in my FP function calls.\nNotice that this gives us the unusual \
denominator with a plus sign: (1 + ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["r", "1"], 
    SubscriptBox["r", "23"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3fc94217-53fe-49cf-8c31-383d3a94a82b"],
 Cell[BoxData[
  RowBox[{" ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]]}]],
  CellChangeTimes->{3.983109977636147*^9, 3.983110010387307*^9, 
   3.983110208698779*^9, 3.98311210675171*^9, 3.983132692911974*^9},
  ExpressionUUID->"4b0942bc-69e9-459b-8896-a4eab1e9daff"],
 ")"
}], "Text",
 CellChangeTimes->{{3.983110255736479*^9, 3.9831103494466343`*^9}, {
  3.983132267748438*^9, 3.983132320560321*^9}, {3.98313236954138*^9, 
  3.9831324359499598`*^9}, {3.98313251647379*^9, 
  3.983132719159382*^9}},ExpressionUUID->"612e8f23-b927-4b96-8530-\
e38771c588ca"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"rr", "=", 
  RowBox[{"refl", "[", 
   RowBox[{"\[Phi]1", ",", "r1", ",", 
    RowBox[{"-", 
     SubscriptBox["r", "23"]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"g1", "=", 
  RowBox[{"gain", "[", 
   RowBox[{"\[Phi]1", ",", "r1", ",", 
    RowBox[{"-", 
     SubscriptBox["r", "23"]}], ",", "t1"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"tt", "=", 
  RowBox[{"trans", "[", 
   RowBox[{"\[Phi]1", ",", "r1", ",", 
    RowBox[{"-", 
     SubscriptBox["r", "23"]}], ",", "t1", ",", 
    SubscriptBox["t", "23"]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.983109912602933*^9, 3.983109943830349*^9}, {
  3.983109981255891*^9, 3.983110009841345*^9}, {3.983110179980682*^9, 
  3.983110208108666*^9}, {3.983132286722947*^9, 3.983132289782963*^9}},
 CellLabel->"In[75]:=",ExpressionUUID->"35690fc1-da90-4de9-8922-ee596ddaf556"],

Cell[BoxData[
 FractionBox[
  RowBox[{"r1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", 
    SubscriptBox["r", "23"]}]}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    SubscriptBox["r", "23"]}]}]]], "Output",
 CellChangeTimes->{3.983109977636147*^9, 3.983110010387307*^9, 
  3.983110208698779*^9, 3.98311210675171*^9, 3.983132692911974*^9},
 CellLabel->"Out[75]=",ExpressionUUID->"898eec05-130a-4db3-81d4-84a1922cc5cf"],

Cell[BoxData[
 FractionBox["t1", 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    SubscriptBox["r", "23"]}]}]]], "Output",
 CellChangeTimes->{3.983109977636147*^9, 3.983110010387307*^9, 
  3.983110208698779*^9, 3.98311210675171*^9, 3.983132692914257*^9},
 CellLabel->"Out[76]=",ExpressionUUID->"c6abf52a-c106-4f9b-90eb-8423e48d0d3d"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "t1", " ", 
   SubscriptBox["t", "23"]}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    SubscriptBox["r", "23"]}]}]]], "Output",
 CellChangeTimes->{3.983109977636147*^9, 3.983110010387307*^9, 
  3.983110208698779*^9, 3.98311210675171*^9, 3.983132692916157*^9},
 CellLabel->"Out[77]=",ExpressionUUID->"f405d0c9-70cc-47e7-b420-7c8ccc4973ac"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
3. Expand out your terms for r(\[Phi]1, \[Phi]2), g1(\[Phi]1, \[Phi]2), t(\
\[Phi]1, \[Phi]2), to get the full expressions in terms of r1, r2, r3, t1, \
t2, t3, \[Phi]1, \[Phi]2.\
\>", "Subsubsection",
 CellChangeTimes->{{3.9831114812825823`*^9, 
  3.9831114835496473`*^9}},ExpressionUUID->"4547b069-c64e-4161-9ad5-\
8a986c989484"],

Cell[TextData[{
 "I\[CloseCurlyQuote]ll do a substitution of the evaluated r23 for the \
variable ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "23"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6c770489-3587-4f46-acfc-10efc6c9b3e9"],
 ", \[LineSeparator]and t23 for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "23"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b4e885a6-c3fb-487c-a009-bdddd138a164"],
 ", then expand.\[LineSeparator]cc suffix below stands for coupled cavity."
}], "Text",
 CellChangeTimes->{{3.983111492112537*^9, 3.983111524700403*^9}, {
  3.983112002442294*^9, 3.983112004522983*^9}, {3.983113470402163*^9, 
  3.983113484554653*^9}},ExpressionUUID->"1cf5a231-7623-4512-b800-\
afbc6ba6d452"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SubscriptBox["r", "23"], "->", "r23"}], ",", 
     RowBox[{
      SubscriptBox["t", "23"], "->", "t23"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"reflcc", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"rr", "/.", "params"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"gain1cc", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"Together", "[", 
    RowBox[{"g1", "/.", "params"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"transcc", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"tt", "/.", "params"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.983111526449523*^9, 3.983111548057829*^9}, {
  3.9831115918587933`*^9, 3.983111634447838*^9}, {3.9831117551668777`*^9, 
  3.983111758069113*^9}, {3.9831134416047564`*^9, 3.983113465347597*^9}},
 CellLabel->"In[78]:=",ExpressionUUID->"15690976-9c70-4291-8832-f845cee53682"],

Cell[BoxData[
 FractionBox[
  RowBox[{"r1", "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r1", " ", 
    "r2", " ", "r3"}], "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", 
    RowBox[{"(", 
     RowBox[{"r2", "-", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r3"}]}], 
     ")"}]}]}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    "r2"}], "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{"\[Phi]1", "+", "\[Phi]2"}], ")"}]}]], " ", "r1", " ", "r3"}], 
   "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r2", " ", 
    "r3"}]}]]], "Output",
 CellChangeTimes->{{3.983111609806059*^9, 3.9831116349339867`*^9}, 
   3.98311175835462*^9, 3.983112109345783*^9, 3.983113467428342*^9, 
   3.983132781442108*^9},
 CellLabel->"Out[79]=",ExpressionUUID->"452b7d18-6908-4d2c-8a39-6ee47827d36b"],

Cell[BoxData[
 FractionBox[
  RowBox[{"t1", "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r2", " ", 
    "r3", " ", "t1"}]}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    "r2"}], "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{"\[Phi]1", "+", "\[Phi]2"}], ")"}]}]], " ", "r1", " ", "r3"}], 
   "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r2", " ", 
    "r3"}]}]]], "Output",
 CellChangeTimes->{{3.983111609806059*^9, 3.9831116349339867`*^9}, 
   3.98311175835462*^9, 3.983112109345783*^9, 3.983113467428342*^9, 
   3.983132781455748*^9},
 CellLabel->"Out[80]=",ExpressionUUID->"87dbec0a-d5a5-41f5-ae84-fb29b8f7398c"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{"\[Phi]1", "+", "\[Phi]2"}], ")"}]}]], " ", "t1", " ", "t2", 
    " ", "t3"}], 
   RowBox[{
    RowBox[{"-", "1"}], "-", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
     "r2"}], "+", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", " ", "\[ImaginaryI]", " ", 
       RowBox[{"(", 
        RowBox[{"\[Phi]1", "+", "\[Phi]2"}], ")"}]}]], " ", "r1", " ", "r3"}],
     "+", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r2", " ", 
     "r3"}]}]]}]], "Output",
 CellChangeTimes->{{3.983111609806059*^9, 3.9831116349339867`*^9}, 
   3.98311175835462*^9, 3.983112109345783*^9, 3.983113467428342*^9, 
   3.983132781457623*^9},
 CellLabel->"Out[81]=",ExpressionUUID->"40d1e739-9fc4-4895-bbeb-cad51b4b3854"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
4. How might you derive the amplitude gain for the second cavity g2(\[Phi]1, \
\[Phi]2)?\
\>", "Subsubsection",
 CellChangeTimes->{{3.983112448363344*^9, 
  3.983112451917276*^9}},ExpressionUUID->"16443e73-ad02-4f52-9883-\
8075094a94d3"],

Cell["\<\
There are several ways to go about it, \[LineSeparator]the simplest is to \
realize that you\[CloseCurlyQuote]ve got almost all the way there with the \
g1(\[Phi]1,\[Phi]2) calculation, \[LineSeparator]you just need to multiply \
g1(\[Phi]1,\[Phi]2) by a single-pass phase of the first cavity \[Phi]1, then \
the Fabry-Perot gain g(\[Phi]2) we calculated in Part 1. \
\>", "Text",
 CellChangeTimes->{{3.983112478304338*^9, 3.983112645762889*^9}, {
  3.983113201901771*^9, 3.983113366837386*^9}, {3.983113402460371*^9, 
  3.98311342729554*^9}, {3.983132783847887*^9, 
  3.983132784776054*^9}},ExpressionUUID->"5a0be4be-6e3a-47db-a16c-\
a346151cf058"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"gain2cc", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"gain1cc", " ", 
    RowBox[{"Exp", "[", 
     RowBox[{"I", " ", "\[Phi]1"}], "]"}], " ", "g23"}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.983113429190035*^9, {3.983113488137073*^9, 3.983113519861611*^9}},
 CellLabel->"In[82]:=",ExpressionUUID->"4c779069-e552-48bb-bce1-1237610da2bf"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "t1", " ", "t2"}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    "r2"}], "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{"\[Phi]1", "+", "\[Phi]2"}], ")"}]}]], " ", "r1", " ", "r3"}], 
   "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r2", " ", 
    "r3"}]}]]], "Output",
 CellChangeTimes->{3.983113520200839*^9, 3.983132786427452*^9},
 CellLabel->"Out[82]=",ExpressionUUID->"3cfc4927-6648-45c8-bdf9-187f159dfb4a"]
}, Open  ]],

Cell["\<\
Another way is to instead compound the first two mirrors to form an r12 and \
t12, then use those to calculate the coupled cavity gain in the second \
cavity.\[LineSeparator]Remember to use -r2, to account for the positive \
reflection we get from reflection off the middle mirror from the left!\
\[LineSeparator]This again should give us the \[OpenCurlyDoubleQuote]unusual \
denominator\[CloseCurlyDoubleQuote] with a plus sign.\
\>", "Text",
 CellChangeTimes->{{3.983113526776164*^9, 3.983113587468281*^9}, {
  3.9831328027560997`*^9, 
  3.9831328938689137`*^9}},ExpressionUUID->"e02823d0-a3ec-42fb-917d-\
1a0b05b7dfee"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"r12", "=", 
  RowBox[{"refl", "[", 
   RowBox[{"\[Phi]1", ",", "r1", ",", 
    RowBox[{"-", "r2"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"g12", "=", 
  RowBox[{"gain", "[", 
   RowBox[{"\[Phi]1", ",", "r1", ",", 
    RowBox[{"-", "r2"}], ",", "t1"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"t12", "=", 
  RowBox[{"trans", "[", 
   RowBox[{"\[Phi]1", ",", "r1", ",", 
    RowBox[{"-", "r2"}], ",", "t1", ",", "t2"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"gain2cc2", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"gain", "[", 
    RowBox[{"\[Phi]2", ",", "r12", ",", "r3", ",", "t12"}], "]"}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.983113606096716*^9, 3.983113683335492*^9}, {
  3.983113716973846*^9, 3.9831137190063133`*^9}, {3.9831328563834953`*^9, 
  3.983132858189994*^9}, {3.9831329119539137`*^9, 3.983132928194977*^9}},
 CellLabel->"In[93]:=",ExpressionUUID->"efc17f6c-f9d8-419f-8776-c6064a92b97b"],

Cell[BoxData[
 FractionBox[
  RowBox[{"r1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r2"}]}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    "r2"}]}]]], "Output",
 CellChangeTimes->{{3.983113714821062*^9, 3.9831137193092127`*^9}, 
   3.983132860089292*^9, {3.983132895642091*^9, 3.983132929129772*^9}},
 CellLabel->"Out[93]=",ExpressionUUID->"0d158fc6-ba1d-4389-8e51-681ae2ae59b7"],

Cell[BoxData[
 FractionBox["t1", 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    "r2"}]}]]], "Output",
 CellChangeTimes->{{3.983113714821062*^9, 3.9831137193092127`*^9}, 
   3.983132860089292*^9, {3.983132895642091*^9, 3.9831329291322412`*^9}},
 CellLabel->"Out[94]=",ExpressionUUID->"75b6be5d-cf87-40c3-bb2b-343bbd69fbf9"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "t1", " ", "t2"}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    "r2"}]}]]], "Output",
 CellChangeTimes->{{3.983113714821062*^9, 3.9831137193092127`*^9}, 
   3.983132860089292*^9, {3.983132895642091*^9, 3.983132929134459*^9}},
 CellLabel->"Out[95]=",ExpressionUUID->"8daee69c-4255-449e-b33f-9753a9444190"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "t1", " ", "t2"}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    "r2"}], "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r1", " ", 
    "r3"}], "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{"\[Phi]1", "+", "\[Phi]2"}], ")"}]}]], " ", "r2", " ", 
    "r3"}]}]]], "Output",
 CellChangeTimes->{{3.983113714821062*^9, 3.9831137193092127`*^9}, 
   3.983132860089292*^9, {3.983132895642091*^9, 3.9831329291366158`*^9}},
 CellLabel->"Out[96]=",ExpressionUUID->"1c7d8da9-ca88-43df-8d3b-712770eddbd9"]
}, Open  ]],

Cell["\<\
Final way would be explicit adjacency matrix.  Exercise left to the reader.\
\>", "Text",
 CellChangeTimes->{{3.983113738088653*^9, 
  3.9831137559253607`*^9}},ExpressionUUID->"9315098c-66e8-4aef-a81d-\
f4764348aa5f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
5. What should the phases for \[Phi]1 and \[Phi]2 be to maximize carrier \
power in the arm cavity?\
\>", "Subsubsection",
 CellChangeTimes->{{3.983124539550673*^9, 
  3.983124551414136*^9}},ExpressionUUID->"b30fd801-f1d5-4e55-a5f3-\
1aef0dd4485f"],

Cell[TextData[{
 "Starting with the arm cavity, \[Phi]2 must be zero, \[LineSeparator]so we \
can get the resonant buildup inside the arm according to g(\[Phi]2) = ",
 Cell[BoxData[
  FormBox[
   FractionBox["t2", 
    RowBox[{"1", "-", 
     RowBox[{"r1", " ", "r2", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}]}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "05d64817-6fef-4f4b-b957-22233bbde660"]
}], "Text",
 CellChangeTimes->{{3.983124567030492*^9, 3.983124603885049*^9}, {
   3.983124664321768*^9, 3.983124720453959*^9}, 
   3.983126564916938*^9},ExpressionUUID->"e33444dd-eb46-41bc-8170-\
189fc1237c46"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"g23", "/.", 
  RowBox[{"{", 
   RowBox[{"\[Phi]2", "->", "0"}], "}"}]}]], "Input",
 CellChangeTimes->{{3.9831261437520514`*^9, 3.9831261541871557`*^9}},
 CellLabel->"In[97]:=",ExpressionUUID->"09e04f0a-eae8-411c-a118-b7c25784dbdb"],

Cell[BoxData[
 FractionBox["t2", 
  RowBox[{"1", "-", 
   RowBox[{"r2", " ", "r3"}]}]]], "Output",
 CellChangeTimes->{3.983126154860766*^9, 3.983132946319377*^9},
 CellLabel->"Out[97]=",ExpressionUUID->"dc67598e-31e2-4179-ba11-61275c426df4"]
}, Open  ]],

Cell["\<\
Next, let\[CloseCurlyQuote]s consider the compound interferometer expression \
for the gain of the first cavity\
\>", "Text",
 CellChangeTimes->{{3.983126662181761*^9, 3.9831266762868347`*^9}, {
  3.9831267104746103`*^9, 
  3.983126714377645*^9}},ExpressionUUID->"7d99eb51-11c9-4286-9d26-\
a0d3125c2b7c"],

Cell[CellGroupData[{

Cell[BoxData["g1"], "Input",
 CellChangeTimes->{{3.983126685148295*^9, 3.983126701132307*^9}},
 CellLabel->"In[98]:=",ExpressionUUID->"68e59f51-5fad-4e35-a33e-21962804d119"],

Cell[BoxData[
 FractionBox["t1", 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    SubscriptBox["r", "23"]}]}]]], "Output",
 CellChangeTimes->{{3.983126687061572*^9, 3.983126701705501*^9}, 
   3.983132947494512*^9},
 CellLabel->"Out[98]=",ExpressionUUID->"1359cae4-844e-4953-914a-43b6b20aa607"]
}, Open  ]],

Cell[TextData[{
 "To figure this out, we might instinctively think we need \[Phi]1 =0 as \
well, but remember that ",
 Cell[BoxData[
  SubscriptBox["r", "23"]],
  CellChangeTimes->{{3.983126687061572*^9, 3.983126701705501*^9}},
  ExpressionUUID->"b1255271-b047-436d-b931-5513337fcb3a"],
 " is complex and can be either positive or negative.\[LineSeparator]We have \
to think about the sign of the reflection off the arm cavity r(\[Phi]2) when \
\[Phi]2 = 0:"
}], "Text",
 CellChangeTimes->{{3.9831262204125347`*^9, 3.9831262812227373`*^9}, {
  3.983126511355332*^9, 3.983126522906006*^9}, {3.983126718691119*^9, 
  3.983126789222785*^9}, {3.983126877878408*^9, 
  3.98312690333821*^9}},ExpressionUUID->"0e3fe05f-1cfc-4a6e-b071-\
2a6ec2744772"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"r23", "/.", 
  RowBox[{"{", 
   RowBox[{"\[Phi]2", "->", "0"}], "}"}]}]], "Input",
 CellChangeTimes->{{3.98312626440232*^9, 3.983126271153874*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"eed15238-6699-4f20-9710-b42b15c30990"],

Cell[BoxData[
 FractionBox[
  RowBox[{"r2", "-", "r3"}], 
  RowBox[{"1", "-", 
   RowBox[{"r2", " ", "r3"}]}]]], "Output",
 CellChangeTimes->{3.983126271977231*^9},
 CellLabel->"Out[60]=",ExpressionUUID->"433e1b76-6341-4e97-9908-dd637b552c34"]
}, Open  ]],

Cell[TextData[{
 "The reflection actually flips sign based on how reflective the mirrors r2 \
and r3 are.\nFor our case in Advanced LIGO, T3 = 5 ppm, and T2 = 1.5%, so r3 \
> r2.\nThis means that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "23"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "438db8d9-88d4-4893-ae44-2e60d4bc56c8"],
 " will be ",
 StyleBox["negative",
  FontSlant->"Italic"],
 " at resonance.\nThis negative sign ",
 StyleBox["flips",
  FontSlant->"Italic"],
 " the denominator of ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"g1", 
    RowBox[{"(", "\[Phi]1", ")"}]}], " ", "=", " ", 
   FractionBox["t1", 
    RowBox[{"1", " ", "+", " ", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
      SubscriptBox["r", "23"]}]}]]}]],
  CellChangeTimes->{{3.983126687061572*^9, 3.983126701705501*^9}, 
    3.983132947494512*^9},ExpressionUUID->
  "0bdb0256-89ef-43d6-a090-a023f0b5f1bc"],
 ", so ",
 "\[Phi]1 = 0 will give us our resonant gain boost.\n\nSo, in the end, \
\[Phi]1 = 0 is the correct value to keep carrier on resonance",
 StyleBox[" in the entire coupled cavity",
  FontSlant->"Italic"],
 ", given Advanced LIGO\[CloseCurlyQuote]s mirror reflectivities.\nThis gives \
us the following cavity gain expressions"
}], "Text",
 CellChangeTimes->{{3.983126905318348*^9, 3.983126906172084*^9}, {
  3.983127210753895*^9, 3.983127293904748*^9}, {3.983131401145536*^9, 
  3.983131425875287*^9}, {3.983131493202141*^9, 3.983131495907474*^9}, {
  3.9831315629934473`*^9, 3.983131592867813*^9}, {3.983132975317429*^9, 
  3.983133015952876*^9}, {3.983133891790251*^9, 3.9831339666645193`*^9}, {
  3.9831340070403357`*^9, 
  3.983134116340213*^9}},ExpressionUUID->"1161ed4f-cd7c-45af-9673-\
2f5d8658d02d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"gain1cc", "/.", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"\[Phi]1", "->", "0"}], ",", 
    RowBox[{"\[Phi]2", "->", "0"}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"gain2cc", "/.", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"\[Phi]1", "->", "0"}], ",", 
    RowBox[{"\[Phi]2", "->", "0"}]}], "}"}]}]}], "Input",
 CellChangeTimes->{{3.983131594035098*^9, 3.983131610534902*^9}},
 CellLabel->"In[99]:=",ExpressionUUID->"479c99bf-6d0f-4a56-a977-be696c01816f"],

Cell[BoxData[
 FractionBox[
  RowBox[{"t1", "-", 
   RowBox[{"r2", " ", "r3", " ", "t1"}]}], 
  RowBox[{"1", "+", 
   RowBox[{"r1", " ", "r2"}], "-", 
   RowBox[{"r1", " ", "r3"}], "-", 
   RowBox[{"r2", " ", "r3"}]}]]], "Output",
 CellChangeTimes->{3.983131610806521*^9, 3.98313302898069*^9},
 CellLabel->"Out[99]=",ExpressionUUID->"a06b746b-7186-4bf3-9167-cde3d20746bb"],

Cell[BoxData[
 FractionBox[
  RowBox[{"t1", " ", "t2"}], 
  RowBox[{"1", "+", 
   RowBox[{"r1", " ", "r2"}], "-", 
   RowBox[{"r1", " ", "r3"}], "-", 
   RowBox[{"r2", " ", "r3"}]}]]], "Output",
 CellChangeTimes->{3.983131610806521*^9, 3.9831330289825573`*^9},
 CellLabel->
  "Out[100]=",ExpressionUUID->"3fb23df8-7fe8-4508-8c37-8d9c3217ac52"]
}, Open  ]],

Cell["\<\
The (lossless) power gain values below are subbed in to give us
1) Arm Gain
2) Power Recycling Gain (PRG)
3) Total CARM gain = (Power Recycling Gain) \[Cross] (Arm Gain)\
\>", "Text",
 CellChangeTimes->{{3.983131576647603*^9, 3.983131578165832*^9}, 
   3.983131828272855*^9, {3.983133184489069*^9, 3.9831332378446693`*^9}, {
   3.983133651668352*^9, 3.983133656044734*^9}, {3.983133692357929*^9, 
   3.983133693372353*^9}},ExpressionUUID->"3bf8953f-7f39-4e3a-a177-\
12b5fca65b75"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"values", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Phi]1", "->", "0"}], ",", 
     RowBox[{"\[Phi]2", "->", "0"}], ",", 
     RowBox[{"T1", "->", "0.031"}], ",", 
     RowBox[{"T2", "->", "0.015"}], ",", 
     RowBox[{"T3", "->", 
      RowBox[{"5", " ", 
       SuperscriptBox["10", 
        RowBox[{"-", "6"}]]}]}], ",", 
     RowBox[{"r1", "->", 
      SqrtBox[
       RowBox[{"1", "-", "T1"}]]}], ",", 
     RowBox[{"r2", "->", 
      SqrtBox[
       RowBox[{"1", "-", "T2"}]]}], ",", 
     RowBox[{"r3", "->", 
      SqrtBox[
       RowBox[{"1", "-", "T3"}]]}], ",", 
     RowBox[{"t1", "->", 
      SqrtBox["T1"]}], ",", 
     RowBox[{"t2", "->", 
      SqrtBox["T2"]}], ",", 
     RowBox[{"t3", "->", 
      SqrtBox["T3"]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  SuperscriptBox[
   RowBox[{"Abs", "[", "g23", "]"}], "2"], "//.", 
  "values"}], "\[IndentingNewLine]", 
 RowBox[{
  SuperscriptBox[
   RowBox[{"Abs", "[", "gain1cc", "]"}], "2"], "//.", 
  "values"}], "\[IndentingNewLine]", 
 RowBox[{
  SuperscriptBox[
   RowBox[{"Abs", "[", "gain2cc", "]"}], "2"], "//.", "values"}]}], "Input",
 CellChangeTimes->{{3.983131412043244*^9, 3.983131412965536*^9}, {
  3.983131826486781*^9, 3.983131872596344*^9}, {3.983131922069313*^9, 
  3.983131942737864*^9}, {3.983133035631771*^9, 3.983133039060034*^9}, {
  3.983133132813861*^9, 3.983133133143189*^9}, {3.983133659021728*^9, 
  3.983133674916274*^9}},
 CellLabel->
  "In[115]:=",ExpressionUUID->"4794c91c-721d-4abf-b0f0-5d0730977687"],

Cell[BoxData["264.4885198102972`"], "Output",
 CellChangeTimes->{{3.983131852801659*^9, 3.983131872968508*^9}, 
   3.983131943205855*^9, {3.983133031106011*^9, 3.983133039454425*^9}, 
   3.983133135542654*^9, 3.983133675278639*^9},
 CellLabel->
  "Out[116]=",ExpressionUUID->"6541a877-6009-4c11-97d3-41a1fe55ff30"],

Cell[BoxData["117.0629493143689`"], "Output",
 CellChangeTimes->{{3.983131852801659*^9, 3.983131872968508*^9}, 
   3.983131943205855*^9, {3.983133031106011*^9, 3.983133039454425*^9}, 
   3.983133135542654*^9, 3.9831336752814837`*^9},
 CellLabel->
  "Out[117]=",ExpressionUUID->"fc81ebe3-c289-45cb-8e88-1fa08756f4eb"],

Cell[BoxData["30961.80618878463`"], "Output",
 CellChangeTimes->{{3.983131852801659*^9, 3.983131872968508*^9}, 
   3.983131943205855*^9, {3.983133031106011*^9, 3.983133039454425*^9}, 
   3.983133135542654*^9, 3.983133675283475*^9},
 CellLabel->
  "Out[118]=",ExpressionUUID->"ec04ef33-d3e5-4c5f-8f3b-8cd61e8d36ef"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
6. What should the phases for \[Phi]1 and \[Phi]2 for the sidebands in the \
coupled cavity?\
\>", "Subsubsection",
 CellChangeTimes->{
  3.983135972240061*^9, {3.983136037083561*^9, 
   3.983136045048848*^9}},ExpressionUUID->"aa5c3882-c681-4941-b190-\
858218ee026b"],

Cell[TextData[{
 "Again starting with the arm cavity, we want the sidebands to be \
antiresonant in the arm cavity, so \[Phi]2 must be ",
 Cell[BoxData[
  FormBox[
   FractionBox["\[Pi]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c941b08d-fcfb-4dec-8d67-797c5ac2c3ac"],
 ", \[LineSeparator]This stems from g(\[Phi]2) = ",
 Cell[BoxData[
  FormBox[
   FractionBox["t2", 
    RowBox[{"1", "-", 
     RowBox[{"r1", " ", "r2", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}]}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "eb1ede8a-39ce-4880-8438-8b9e859dc66a"],
 ".  \nWe need the denominator to be large, so the gain is small.\nThis means \
Exp[I 2 \[Phi]] = -1 is our desired setpoint, which means we must have \
\[Phi]2 = ",
 Cell[BoxData[
  FormBox[
   FractionBox["\[Pi]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7b85c7bd-a805-49b7-a059-166337c88c7c"],
 ":"
}], "Text",
 CellChangeTimes->{{3.9831366429000587`*^9, 3.983136734213956*^9}, {
  3.983136774858754*^9, 
  3.983136872192267*^9}},ExpressionUUID->"ed7a7a2b-9d1d-4d04-9096-\
504e62cd7f8b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"g23", "/.", 
  RowBox[{"{", 
   RowBox[{"\[Phi]2", "->", 
    FractionBox["\[Pi]", "2"]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.983136875299382*^9, 3.98313688177457*^9}},
 CellLabel->
  "In[119]:=",ExpressionUUID->"9b916be3-069e-4f2c-8206-041503d860dc"],

Cell[BoxData[
 FractionBox["t2", 
  RowBox[{"1", "+", 
   RowBox[{"r2", " ", "r3"}]}]]], "Output",
 CellChangeTimes->{3.98313688206809*^9},
 CellLabel->
  "Out[119]=",ExpressionUUID->"1873df3d-5d1b-4502-a0e3-b5fdedb08a46"]
}, Open  ]],

Cell[TextData[{
 "So now we have the arm\[CloseCurlyQuote]s phase setting so the sidebands do \
not resonate there.\nBut we want the sidebands to still resonate inside the \
first cavity.\nWhat does this mean for \[Phi]1?\n\nAgain, consider the arm \
reflectivity term r(\[Phi]2), but this time let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]2", "\[Rule]", 
    FractionBox["\[Pi]", "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "13bd92f0-67ce-4dae-9f99-3a5f82a937c3"],
 "."
}], "Text",
 CellChangeTimes->{{3.983136901309842*^9, 3.983137034617793*^9}, {
  3.983137070648446*^9, 
  3.983137071366591*^9}},ExpressionUUID->"885a6acc-cb02-435b-8848-\
262b39821025"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"r23", "/.", 
  RowBox[{"{", 
   RowBox[{"\[Phi]2", "->", 
    FractionBox["\[Pi]", "2"]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.983137021327776*^9, 3.983137023079172*^9}},
 CellLabel->
  "In[120]:=",ExpressionUUID->"e48a72d8-4c7c-4172-a4c3-18eef462ab04"],

Cell[BoxData[
 FractionBox[
  RowBox[{"r2", "+", "r3"}], 
  RowBox[{"1", "+", 
   RowBox[{"r2", " ", "r3"}]}]]], "Output",
 CellChangeTimes->{3.983137036103201*^9},
 CellLabel->
  "Out[120]=",ExpressionUUID->"e90fcd23-336b-4c17-a976-19ff15a866ef"]
}, Open  ]],

Cell[TextData[{
 "The reflectivity off the arm is ",
 StyleBox["positive.",
  FontSlant->"Italic"],
 "\nThis is different than before, with carrier.  \nNow, again consider the \
gain of the full coupled cavity inside the first cavity:"
}], "Text",
 CellChangeTimes->{{3.983137046697474*^9, 
  3.983137121476206*^9}},ExpressionUUID->"7bfd2fa1-894d-4694-a9f4-\
e16db6511f00"],

Cell[CellGroupData[{

Cell[BoxData["g1"], "Input",
 CellChangeTimes->{{3.983137122682063*^9, 3.983137123594496*^9}},
 CellLabel->
  "In[121]:=",ExpressionUUID->"85f89115-cce7-4f21-a424-710dc5035839"],

Cell[BoxData[
 FractionBox["t1", 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    SubscriptBox["r", "23"]}]}]]], "Output",
 CellChangeTimes->{3.983137125134185*^9},
 CellLabel->
  "Out[121]=",ExpressionUUID->"ba04b37e-9618-4514-9cb6-3b7988f8a417"]
}, Open  ]],

Cell[TextData[{
 "With us wanting resonance inside this cavity, we need the denominator (",
 Cell[BoxData[
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    SubscriptBox["r", "23"]}]}]],
  CellChangeTimes->{3.983137125134185*^9},ExpressionUUID->
  "c73c7619-d591-47e7-b109-0b25031a1980"],
 ") as ",
 StyleBox["small",
  FontSlant->"Italic"],
 " as possible.\nWith ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "23"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cc8e273c-4404-4157-b80f-35445b992965"],
 " being ",
 StyleBox["positive",
  FontSlant->"Italic"],
 ", that means that ",
 Cell[BoxData[
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]]],
  CellChangeTimes->{3.983137125134185*^9},ExpressionUUID->
  "e1ed0a28-c66c-42e8-9843-58f100bffcc2"],
 "= -1 is desired.\nAgain, this leads us to \[Phi]1 = ",
 Cell[BoxData[
  FormBox[
   FractionBox["\[Pi]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c99fd30c-919a-4c91-b413-571c7805baa2"],
 ". \nThis ",
 StyleBox["restores",
  FontSlant->"Italic"],
 " resonance for the sideband inside of the first cavity, despite being \
antiresonant inside the second cavity.\n\nThis gives us the following gain \
expressions:"
}], "Text",
 CellChangeTimes->{{3.983137140216416*^9, 3.983137183047989*^9}, {
  3.983137216158399*^9, 
  3.983137378203773*^9}},ExpressionUUID->"17ef0321-e3d9-4916-b4fb-\
994293c2ff8a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"gain1cc", "/.", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"\[Phi]1", "->", 
     FractionBox["\[Pi]", "2"]}], ",", 
    RowBox[{"\[Phi]2", "->", 
     FractionBox["\[Pi]", "2"]}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"gain2cc", "/.", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"\[Phi]1", "->", 
     FractionBox["\[Pi]", "2"]}], ",", 
    RowBox[{"\[Phi]2", "->", 
     FractionBox["\[Pi]", "2"]}]}], "}"}]}]}], "Input",
 CellChangeTimes->{{3.9831373807203293`*^9, 3.983137388681151*^9}},
 CellLabel->
  "In[122]:=",ExpressionUUID->"b2e1b069-6c72-4113-930c-9d54771c9c67"],

Cell[BoxData[
 FractionBox[
  RowBox[{"t1", "+", 
   RowBox[{"r2", " ", "r3", " ", "t1"}]}], 
  RowBox[{"1", "-", 
   RowBox[{"r1", " ", "r2"}], "-", 
   RowBox[{"r1", " ", "r3"}], "+", 
   RowBox[{"r2", " ", "r3"}]}]]], "Output",
 CellChangeTimes->{3.983137389333857*^9},
 CellLabel->
  "Out[122]=",ExpressionUUID->"77320e02-33ac-43fc-94f4-f0aa4b0eb3b9"],

Cell[BoxData[
 FractionBox[
  RowBox[{"\[ImaginaryI]", " ", "t1", " ", "t2"}], 
  RowBox[{"1", "-", 
   RowBox[{"r1", " ", "r2"}], "-", 
   RowBox[{"r1", " ", "r3"}], "+", 
   RowBox[{"r2", " ", "r3"}]}]]], "Output",
 CellChangeTimes->{3.983137389336214*^9},
 CellLabel->
  "Out[123]=",ExpressionUUID->"e2e79519-4390-42cd-837d-2a7cc4fe63ef"]
}, Open  ]],

Cell["\<\
These are similar to carrier, but with some significant sign flips in the \
denominator that lead to less power buildup in the arms.
To demonstrate, let\[CloseCurlyQuote]s substitute in the Advanced LIGO values \
again
1) RF Sideband Arm Gain ( should be < 1 )
2) Power Recycling Gain (PRG) ( should be >> 1 )
3) Total CARM gain = (Power Recycling Gain) \[Cross] (Arm Gain) ( should be < \
1 )\
\>", "Text",
 CellChangeTimes->{{3.983137426860235*^9, 3.9831374769051943`*^9}, {
  3.983137525430739*^9, 
  3.983137560821127*^9}},ExpressionUUID->"50206f7c-ea3b-488e-8327-\
0a3dbec0df61"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"values2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Phi]1", "->", 
      FractionBox["\[Pi]", "2"]}], ",", 
     RowBox[{"\[Phi]2", "->", 
      FractionBox["\[Pi]", "2"]}], ",", 
     RowBox[{"T1", "->", "0.031"}], ",", 
     RowBox[{"T2", "->", "0.015"}], ",", 
     RowBox[{"T3", "->", 
      RowBox[{"5", " ", 
       SuperscriptBox["10", 
        RowBox[{"-", "6"}]]}]}], ",", 
     RowBox[{"r1", "->", 
      SqrtBox[
       RowBox[{"1", "-", "T1"}]]}], ",", 
     RowBox[{"r2", "->", 
      SqrtBox[
       RowBox[{"1", "-", "T2"}]]}], ",", 
     RowBox[{"r3", "->", 
      SqrtBox[
       RowBox[{"1", "-", "T3"}]]}], ",", 
     RowBox[{"t1", "->", 
      SqrtBox["T1"]}], ",", 
     RowBox[{"t2", "->", 
      SqrtBox["T2"]}], ",", 
     RowBox[{"t3", "->", 
      SqrtBox["T3"]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  SuperscriptBox[
   RowBox[{"Abs", "[", "g23", "]"}], "2"], "//.", 
  "values2"}], "\[IndentingNewLine]", 
 RowBox[{
  SuperscriptBox[
   RowBox[{"Abs", "[", "gain1cc", "]"}], "2"], "//.", 
  "values2"}], "\[IndentingNewLine]", 
 RowBox[{
  SuperscriptBox[
   RowBox[{"Abs", "[", "gain2cc", "]"}], "2"], "//.", "values2"}]}], "Input",
 CellChangeTimes->{{3.983137009271104*^9, 3.98313701035194*^9}, {
  3.983137484349888*^9, 3.983137498596949*^9}},
 CellLabel->
  "In[124]:=",ExpressionUUID->"566d6d1f-03c5-4683-af25-44d2bcfe36ce"],

Cell[BoxData["0.0037784008822649537`"], "Output",
 CellChangeTimes->{3.983137499213084*^9},
 CellLabel->
  "Out[125]=",ExpressionUUID->"f4cfa0ee-0704-472e-8328-69d89e193602"],

Cell[BoxData["127.02423434730869`"], "Output",
 CellChangeTimes->{3.983137499215313*^9},
 CellLabel->
  "Out[126]=",ExpressionUUID->"f8de9586-2057-44bb-9dd9-932cf4904ab6"],

Cell[BoxData["0.47994847912690136`"], "Output",
 CellChangeTimes->{3.983137499217112*^9},
 CellLabel->
  "Out[127]=",ExpressionUUID->"1087361c-d186-4c8f-8345-99ffd16f945b"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "7. Find the coupled cavity pole ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", "cc"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "89e25bf8-2f77-4c0d-ba89-f744546fd1cb"],
 " for carrier."
}], "Subsubsection",
 CellChangeTimes->{{3.983138236962023*^9, 
  3.983138268201373*^9}},ExpressionUUID->"c183990f-af41-4bf3-a3c3-\
e7b22fdd8b10"],

Cell["\<\
Find the denominator for the electric field solutions.  Print e.g. the second \
cavity gain:\
\>", "Text",
 CellChangeTimes->{{3.98313825124841*^9, 
  3.9831383184740057`*^9}},ExpressionUUID->"5e480760-6369-4072-b699-\
86c77babf778"],

Cell[CellGroupData[{

Cell[BoxData["gain2cc"], "Input",
 CellLabel->
  "In[128]:=",ExpressionUUID->"7a6d1b7f-3dc4-436d-87e1-ffe215bb8852"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "t1", " ", "t2"}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    "r2"}], "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{"\[Phi]1", "+", "\[Phi]2"}], ")"}]}]], " ", "r1", " ", "r3"}], 
   "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r2", " ", 
    "r3"}]}]]], "Output",
 CellChangeTimes->{3.983138296157837*^9},
 CellLabel->
  "Out[128]=",ExpressionUUID->"99a1f7d8-a156-41c8-af6c-2f51d326d2b0"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"denom", "=", 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
    "r2"}], "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{"\[Phi]1", "+", "\[Phi]2"}], ")"}]}]], " ", "r1", " ", "r3"}], 
   "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r2", " ", 
    "r3"}]}]}]], "Input",
 CellChangeTimes->{{3.983138320261012*^9, 3.98313832632522*^9}},
 CellLabel->
  "In[129]:=",ExpressionUUID->"4f4d3674-63d9-49eb-a601-023607b996ed"],

Cell[BoxData[
 RowBox[{"1", "+", 
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]1"}]], " ", "r1", " ", 
   "r2"}], "-", 
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"2", " ", "\[ImaginaryI]", " ", 
     RowBox[{"(", 
      RowBox[{"\[Phi]1", "+", "\[Phi]2"}], ")"}]}]], " ", "r1", " ", "r3"}], 
  "-", 
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]2"}]], " ", "r2", " ", 
   "r3"}]}]], "Output",
 CellChangeTimes->{3.983138332976026*^9},
 CellLabel->
  "Out[129]=",ExpressionUUID->"dd91489a-6ecf-4f44-a00c-d6916d70f1cb"]
}, Open  ]],

Cell[TextData[{
 "Substitute in \[Phi]1 \[Rule] 0 and \[Phi]2 \[Rule] ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SubscriptBox["\[Omega]", "cc"], 
     SubscriptBox["L", "2"]}], "c"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "30de5da2-9084-447e-959e-f15ae6e22ff2"],
 ", \[LineSeparator]set the denom = 0, then solve for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", "cc"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "49794815-8011-4ef3-911f-4b90029ec08d"],
 "."
}], "Text",
 CellChangeTimes->{{3.983138340994009*^9, 3.983138410589733*^9}, {
  3.9831384942472563`*^9, 
  3.9831385174055223`*^9}},ExpressionUUID->"c957972d-b98d-47d5-a6a3-\
1185d6e5b044"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"soln", "=", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"denom", "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Phi]1", "->", "0"}], ",", 
         RowBox[{"\[Phi]2", "->", 
          FractionBox[
           RowBox[{"\[Omega]cc", " ", "L2"}], "c"]}]}], "}"}]}], ")"}], "==", 
     "0"}], ",", "\[Omega]cc"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"\[Omega]cc0", "=", 
  RowBox[{
   RowBox[{"I", " ", 
    RowBox[{"soln", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1", ",", "2"}], "]"}], "]"}]}], "/.", 
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"1"},
      "C"], "->", "0"}], "}"}]}]}]}], "Input",
 CellChangeTimes->{{3.983138420647809*^9, 3.983138465602414*^9}, {
  3.983138521574029*^9, 3.9831385927250767`*^9}, {3.983138679568037*^9, 
  3.983138679911599*^9}},
 CellLabel->
  "In[140]:=",ExpressionUUID->"68e835d0-9774-43a6-beba-97d4e3ec574f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"\[Omega]cc", "\[Rule]", 
    TemplateBox[{
      RowBox[{"-", 
        FractionBox[
         RowBox[{"\[ImaginaryI]", " ", "c", " ", 
           RowBox[{"(", 
             RowBox[{
               RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Pi]", " ", 
                 TemplateBox[{"1"}, "C"]}], "+", 
               RowBox[{"Log", "[", 
                 FractionBox[
                  RowBox[{"1", "+", 
                    RowBox[{"r1", " ", "r2"}]}], 
                  RowBox[{
                    RowBox[{"(", 
                    RowBox[{"r1", "+", "r2"}], ")"}], " ", "r3"}]], "]"}]}], 
             ")"}]}], 
         RowBox[{"2", " ", "L2"}]]}], 
      RowBox[{
        TemplateBox[{"1"}, "C"], "\[Element]", 
        TemplateBox[{}, "Integers"]}]},
     "ConditionalExpression"]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{{3.983138456688553*^9, 3.983138466186153*^9}, {
   3.983138524100481*^9, 3.983138527504799*^9}, {3.983138574356999*^9, 
   3.983138593252386*^9}, 3.98313868046054*^9},
 CellLabel->
  "Out[140]=",ExpressionUUID->"1d319642-28bf-4931-9d6f-17a86c653ebc"],

Cell[BoxData[
 FractionBox[
  RowBox[{"c", " ", 
   RowBox[{"Log", "[", 
    FractionBox[
     RowBox[{"1", "+", 
      RowBox[{"r1", " ", "r2"}]}], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"r1", "+", "r2"}], ")"}], " ", "r3"}]], "]"}]}], 
  RowBox[{"2", " ", "L2"}]]], "Output",
 CellChangeTimes->{{3.983138456688553*^9, 3.983138466186153*^9}, {
   3.983138524100481*^9, 3.983138527504799*^9}, {3.983138574356999*^9, 
   3.983138593252386*^9}, 3.983138680467371*^9},
 CellLabel->
  "Out[141]=",ExpressionUUID->"c4c45f0d-65cc-4d02-a58c-8aa8d2b55fa0"]
}, Open  ]],

Cell["Evaluate the coupled cavity pole in Hertz", "Text",
 CellChangeTimes->{{3.983138603415412*^9, 3.9831386044163933`*^9}, {
  3.9831386424357653`*^9, 
  3.983138650242569*^9}},ExpressionUUID->"45fc64da-fd6a-4090-9155-\
951eff591f6e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["\[Omega]cc0", 
    RowBox[{"2", "\[Pi]"}]], "//.", "values"}], "/.", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"L2", "->", "3994.5"}], ",", 
    RowBox[{"c", "->", 
     RowBox[{"3", " ", 
      SuperscriptBox["10", "8"]}]}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.9831386092386837`*^9, 3.9831386691349287`*^9}},
 CellLabel->
  "In[142]:=",ExpressionUUID->"a42e4784-e247-4943-9c56-4b837032d208"],

Cell[BoxData["0.37048982462900626`"], "Output",
 CellChangeTimes->{{3.983138651483102*^9, 3.9831386912950897`*^9}},
 CellLabel->
  "Out[142]=",ExpressionUUID->"f68e08a9-a83e-41e9-8195-c99685428dab"]
}, Open  ]],

Cell[TextData[{
 "The coupled cavity pole for Advanced LIGO is 0.37 Hertz.  This is ",
 StyleBox["extremely low",
  FontSlant->"Italic"],
 ".  \nThis means that when locked, Advanced LIGO low-passes all laser \
frequency and intensity excursions faster than 0.37 Hz.\nAlso, the laser must \
be stabilized to better than 0.37 Hertz in order to resonate inside the LIGO \
interferometer.  \nThis is extraordinarily stable, and in some frequency \
regimes is the most stable laser in the world."
}], "Text",
 CellChangeTimes->{{3.983138698980383*^9, 3.983138818180098*^9}, {
  3.983138926824914*^9, 
  3.9831389455272427`*^9}},ExpressionUUID->"34810e5f-b77b-44e3-9351-\
3e9fc7a9e16d"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
