        ")"}]}], "+", 
      RowBox[{"Ereflm\[Omega]", " ", 
       RowBox[{"ComplexExpand", "[", 
        RowBox[{"Conjugate", "[", 
         RowBox[{"Ereflm\[CapitalOmega]", "+", "Ereflp\[CapitalOmega]"}], 
         "]"}], "]"}]}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PreflQ", "=", 
   RowBox[{"I", " ", 
    FractionBox[
     RowBox[{"\[Gamma]", " ", "\[CapitalGamma]"}], "2"], "E0", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Erefl0", " ", 
       RowBox[{"ComplexExpand", "[", 
        RowBox[{"Conjugate", "[", 
         RowBox[{
         "Ereflp\[CapitalOmega]p\[Omega]", "-", 
          "Ereflm\[CapitalOmega]p\[Omega]"}], "]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"ComplexExpand", "[", 
        RowBox[{"Conjugate", "[", "Erefl0", "]"}], "]"}], 
       RowBox[{"(", 
        RowBox[{
        "Ereflm\[CapitalOmega]m\[Omega]", "-", 
         "Ereflp\[CapitalOmega]m\[Omega]"}], ")"}]}], "+", 
      RowBox[{
       RowBox[{"ComplexExpand", "[", 
