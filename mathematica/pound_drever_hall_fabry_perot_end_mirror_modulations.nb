Cell[CellGroupData[{

Cell["\<\
Calculate the double demodulated transfer function power term\
\>", "Section",
 CellChangeTimes->{{3.903717471345879*^9, 3.90371747624319*^9}, {
  3.904567192409629*^9, 3.904567224230564*^9}, {3.9682491285551558`*^9, 
  3.968249153225048*^9}},ExpressionUUID->"12f231d1-36d2-4979-aa60-\
f8821be8d9f0"],

Cell["\<\
Using the results from double_demoduation_derivation.nb, calculate the RF \
demodulation I and Q transfer function terms.
\[CapitalGamma] and \[Gamma] are the RF and audio modulation depths in \
radians, \[LineSeparator]\[Gamma] = k \[CapitalDelta]x is the modulation for \
a simple mirror motion.\
\>", "Text",
 CellChangeTimes->{{3.968249166202281*^9, 3.968249224121361*^9}, {
  3.96825375759898*^9, 3.968253845520949*^9}, {3.9682544157798843`*^9, 
  3.9682544193190603`*^9}},ExpressionUUID->"713368b2-cd03-4ef0-a804-\
a75daf7ece0a"],

Cell[CellGroupData[{

Cell["Cavity power", "Subsubsection",
 CellChangeTimes->{{3.903887996820513*^9, 
  3.9038879979658012`*^9}},ExpressionUUID->"8e9b0691-1132-48ea-9fad-\
fb37159c23f4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"PcavI", "=", 
   RowBox[{
    FractionBox[
     RowBox[{"\[Gamma]", " ", "\[CapitalGamma]"}], "2"], "E0", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "Ecav0"}], " ", 
       RowBox[{"ComplexExpand", "[", 
        RowBox[{"Conjugate", "[", 
         RowBox[{
         "Ecavm\[CapitalOmega]p\[Omega]", "+", 
          "Ecavp\[CapitalOmega]p\[Omega]"}], "]"}], "]"}]}], "-", 
      RowBox[{
       RowBox[{"ComplexExpand", "[", 
        RowBox[{"Conjugate", "[", "Ecav0", "]"}], "]"}], 
       RowBox[{"(", 
        RowBox[{
        "Ecavm\[CapitalOmega]m\[Omega]", "+", 
         "Ecavp\[CapitalOmega]m\[Omega]"}], ")"}]}], "+", 
      RowBox[{
       RowBox[{"ComplexExpand", "[", 
        RowBox[{"Conjugate", "[", "Ecavp\[Omega]", "]"}], "]"}], 
       RowBox[{"(", 
        RowBox[{"Ecavp\[CapitalOmega]", "+", "Ecavm\[CapitalOmega]"}], 
        ")"}]}], "+", 
      RowBox[{"Ecavm\[Omega]", " ", 
       RowBox[{"ComplexExpand", "[", 
        RowBox[{"Conjugate", "[", 
         RowBox[{"Ecavm\[CapitalOmega]", "+", "Ecavp\[CapitalOmega]"}], "]"}],
         "]"}]}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PcavQ", "=", 
   RowBox[{"I", " ", 
    FractionBox[
     RowBox[{"\[Gamma]", " ", "\[CapitalGamma]"}], "2"], "E0", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Ecav0", " ", 
       RowBox[{"ComplexExpand", "[", 
        RowBox[{"Conjugate", "[", 
         RowBox[{
         "Ecavp\[CapitalOmega]p\[Omega]", "-", 
          "Ecavm\[CapitalOmega]p\[Omega]"}], "]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"ComplexExpand", "[", 
        RowBox[{"Conjugate", "[", "Ecav0", "]"}], "]"}], 
       RowBox[{"(", 
        RowBox[{
        "Ecavm\[CapitalOmega]m\[Omega]", "-", 
         "Ecavp\[CapitalOmega]m\[Omega]"}], ")"}]}], "+", 
      RowBox[{
       RowBox[{"ComplexExpand", "[", 
        RowBox[{"Conjugate", "[", "Ecavp\[Omega]", "]"}], "]"}], 
       RowBox[{"(", 
        RowBox[{"Ecavp\[CapitalOmega]", "-", "Ecavm\[CapitalOmega]"}], 
        ")"}]}], "+", 
      RowBox[{"Ecavm\[Omega]", " ", 
       RowBox[{"ComplexExpand", "[", 
        RowBox[{"Conjugate", "[", 
         RowBox[{"Ecavm\[CapitalOmega]", "-", "Ecavp\[CapitalOmega]"}], "]"}],
         "]"}]}]}], ")"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.903714621820981*^9, 3.903714649240477*^9}, {
   3.9037196612898693`*^9, 3.9037197013533278`*^9}, {3.9037200069839153`*^9, 
   3.903720007465061*^9}, {3.9037200686563873`*^9, 3.903720073380056*^9}, {
   3.903775931100535*^9, 3.903775954979007*^9}, {3.903780750765134*^9, 
