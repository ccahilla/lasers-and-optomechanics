      RowBox[{"\[Phi]", "\[Rule]", "\[Phi]p\[CapitalOmega]"}], "}"}]}], "]"}], 
   RowBox[{"Simplify", "[", 
    RowBox[{"end2cav", "/.", 
     RowBox[{"{", 
      RowBox[{"\[Phi]", "->", "\[Phi]p\[CapitalOmega]p\[Omega]"}], "}"}]}], 
    "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Ecavp\[CapitalOmega]m\[Omega]", "=", 
