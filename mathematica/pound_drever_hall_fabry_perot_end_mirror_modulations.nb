Cell[CellGroupData[{
Cell["Pound-Drever-Hall Fabry Perot End Mirror Modulations", "Title",
 CellChangeTimes->{{3.968246131643181*^9, 
  3.9682461428425837`*^9}},ExpressionUUID->"d37092a7-0f20-4457-8a02-\
fdfac494be3d"],

Cell["\<\
Calculate from first principles the Fabry-Perot PDH reflection transfer \
function,
similar to double_demod_derivation.nb.\
\>", "Subtitle",
 CellChangeTimes->{{3.968246146486623*^9, 3.9682461715903397`*^9}, {
  3.968246202413068*^9, 
  3.9682462419900713`*^9}},ExpressionUUID->"af3ac75a-9e72-40a5-a264-\
72b28f05fc7b"],

Cell[CellGroupData[{

Cell["Electric Field Adjacency Matrix", "Section",
 CellChangeTimes->{{3.9042309754412403`*^9, 3.90423100253568*^9}, {
  3.904337293907963*^9, 3.90433729502451*^9}, {3.904340479472308*^9, 
