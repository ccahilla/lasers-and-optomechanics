    RowBox[{"Simplify", "[", 
     RowBox[{"end2cav", "/.", 
      RowBox[{"{", 
       RowBox[{"\[Phi]", "->", "\[Phi]m\[CapitalOmega]m\[Omega]"}], "}"}]}], 
     "]"}]}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ecav", "=", 
   RowBox[{"E0", " ", 
    RowBox[{"(", 
     RowBox[{
     "Ecav0", "+", "Ecavp\[CapitalOmega]", "+", "Ecavm\[CapitalOmega]", "+", 
      "Ecavp\[Omega]", "+", "Ecavm\[Omega]", "+", 
      "Ecavp\[CapitalOmega]p\[Omega]", "+", "Ecavp\[CapitalOmega]m\[Omega]", 
