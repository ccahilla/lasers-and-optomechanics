    "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Ecavm\[CapitalOmega]p\[Omega]", "=", 
  RowBox[{
   RowBox[{"Simplify", "[", 
    RowBox[{"cav2", "/.", 
     RowBox[{"{", 
      RowBox[{"\[Phi]", "\[Rule]", "\[Phi]m\[CapitalOmega]"}], "}"}]}], "]"}], 
   RowBox[{"Simplify", "[", 
    RowBox[{"end2cav", "/.", 
     RowBox[{"{", 
      RowBox[{"\[Phi]", "->", "\[Phi]m\[CapitalOmega]p\[Omega]"}], "}"}]}], 
    "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ecavm\[CapitalOmega]m\[Omega]", "=", 
   RowBox[{
    RowBox[{"Simplify", "[", 
