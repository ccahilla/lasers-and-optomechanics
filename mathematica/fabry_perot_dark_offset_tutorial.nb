  3.982524554905204*^9, 3.9825245658997517`*^9}, {3.982524759866685*^9, 
  3.982524783958228*^9}, {3.982524867737546*^9, 
  3.982525102863439*^9}},ExpressionUUID->"c0eea3ca-6da4-4959-9cc8-\
4dd35b1be9c9"],

