Notebook[{

Cell[CellGroupData[{
Cell["Fabry Perot Dark Offset Tutorial Solutions", "Title",
 CellChangeTimes->{{3.9825059633747272`*^9, 
  3.982505973174676*^9}},ExpressionUUID->"5b9f3b1e-e07b-46f8-9796-\
ed2174395000"],

Cell[CellGroupData[{

Cell["Part 1: Transmitted Power", "Section",
 CellChangeTimes->{{3.982505982402397*^9, 
  3.982505991054408*^9}},ExpressionUUID->"3ddb59b8-2d4d-4b00-8011-\
0bf73a55bda5"],

Cell[CellGroupData[{

Cell[TextData[{
 "Define the transmitted field function (assuming Ein = 1 ",
 Cell[BoxData[
  FormBox[
   SqrtBox["W"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "19302775-d144-4ff9-8d49-d4a13d8720b5"],
 ")"
}], "Subsubsection",
 CellChangeTimes->{{3.982505994478889*^9, 
  3.982506018270903*^9}},ExpressionUUID->"7cbd094a-dab3-4751-82bd-\
7e97f9c4b0dd"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Etrans", "[", 
    RowBox[{"\[Phi]_", ",", 
     RowBox[{"t1_", ":", "0.3"}], ",", 
     RowBox[{"t2_", ":", "0.3"}], ",", 
     RowBox[{"r1_", ":", 
      SqrtBox[
       RowBox[{"1", "-", 
        SuperscriptBox["0.3", "2"]}]]}], ",", 
     RowBox[{"r2_", ":", 
      SqrtBox[
       RowBox[{"1", "-", 
        SuperscriptBox["0.3", "2"]}]]}]}], "]"}], ":=", 
   FractionBox[
    RowBox[{"t1", " ", "t2", " ", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], " ", "\[Phi]"}], "]"}]}], 
    RowBox[{"1", "-", 
     RowBox[{"r1", " ", "r2", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", "2", " ", "\[Phi]"}], "]"}]}]}]]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.982443003105345*^9, 3.982443044590407*^9}, {
   3.9824471220540237`*^9, 3.982447163015849*^9}, {3.982447239449416*^9, 
   3.982447262326288*^9}, {3.98244732615127*^9, 3.982447336402953*^9}, {
   3.982447766049059*^9, 3.9824477704033537`*^9}, 3.98250592914145*^9},
 CellLabel->"In[74]:=",ExpressionUUID->"bc3fafcc-13ac-4ee4-bafb-260e62714957"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "1. Derive an expression for the transmitted power ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "trans"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "01e83008-1e34-4d9f-8a14-b51b6e0a8149"],
 "(\[Phi])"
}], "Subsubsection",
 CellChangeTimes->{{3.982506147026485*^9, 3.9825061691525383`*^9}, {
  3.982506286800239*^9, 
  3.982506288001524*^9}},ExpressionUUID->"07e77155-1bbf-42a3-bd13-\
187bd93cb3c2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Etrans0", "=", 
   RowBox[{"Etrans", "[", 
    RowBox[{"\[Phi]", ",", "t1", ",", "t2", ",", "r1", ",", "r2"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Ptrans", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"ComplexExpand", "[", 
    RowBox[{"Etrans0", " ", 
     RowBox[{"Conjugate", "[", "Etrans0", "]"}]}], "]"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.982506169903577*^9, 3.982506226191002*^9}, {
  3.982506259953186*^9, 3.982506266389468*^9}},
 CellLabel->"In[75]:=",ExpressionUUID->"e8d7f559-e541-4363-8521-59ad8d22e4df"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["t1", "2"], " ", 
   SuperscriptBox["t2", "2"]}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["r1", "2"], " ", 
    SuperscriptBox["r2", "2"]}], "-", 
   RowBox[{"2", " ", "r1", " ", "r2", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}]]], "Output",
 CellChangeTimes->{{3.982506215302443*^9, 3.982506226508951*^9}, 
   3.982506266719386*^9, 3.982773134756412*^9, 3.987006904363873*^9},
 CellLabel->"Out[76]=",ExpressionUUID->"5a9ef38f-4a3e-42d7-8e35-4e1b7ba7497f"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "2. What is the maximum transmitted power at resonance ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "trans"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "367e6ea7-8481-4df1-acac-c6c43b5e64cf"],
 "(0)?"
}], "Subsubsection",
 CellChangeTimes->{{3.982506278001088*^9, 
  3.9825062965014133`*^9}},ExpressionUUID->"f00de10e-2bdc-48cf-a03c-\
945624a5d414"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Ptrans", "/.", 
  RowBox[{"{", 
   RowBox[{"\[Phi]", "->", "0"}], "}"}]}]], "Input",
 CellChangeTimes->{{3.982506302819474*^9, 3.982506318560343*^9}},
 CellLabel->"In[77]:=",ExpressionUUID->"5f7aa932-a910-4d69-a897-05cf0ccdbb56"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["t1", "2"], " ", 
   SuperscriptBox["t2", "2"]}], 
  RowBox[{"1", "-", 
   RowBox[{"2", " ", "r1", " ", "r2"}], "+", 
   RowBox[{
    SuperscriptBox["r1", "2"], " ", 
    SuperscriptBox["r2", "2"]}]}]]], "Output",
 CellChangeTimes->{{3.982506305968215*^9, 3.98250631891332*^9}, 
   3.982773134785316*^9, 3.987006904369803*^9},
 CellLabel->"Out[77]=",ExpressionUUID->"6355eaf9-e5a5-48cd-97aa-108263741eeb"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "3. Starting at resonance, what happens to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "trans"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cfd2ad67-524f-499b-a350-5d7adad7db19"],
 " when the cavity gets longer?"
}], "Subsubsection",
 CellChangeTimes->{{3.982506333102293*^9, 3.982506353624508*^9}, {
  3.982506765513812*^9, 
  3.9825067712793417`*^9}},ExpressionUUID->"79f6435d-bd94-4f3e-804e-\
6086e08bad28"],

Cell[TextData[{
 "The power goes down like ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Phi]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ab02e50a-d3b7-40c0-a450-4aad5ce52eb1"],
 ".  \[LineSeparator]Looking at the equation for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "trans"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bb752439-f2d9-464c-9aec-2852c1669c38"],
 ", the cosine in the denominator ensures that the offset must be significant \
before we start to see change.\[LineSeparator]Quantitatively, we could take \
the derivative of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "trans"], TraditionalForm]],ExpressionUUID->
  "734cf44d-71ef-49b1-8776-4fae72ff9c85"],
 " with respect to \[Phi], then evaluate at \[Phi] = 0"
}], "Text",
 CellChangeTimes->{{3.982506486019068*^9, 3.982506596415496*^9}, {
  3.982506738782858*^9, 3.9825068479405212`*^9}, {3.982507736915852*^9, 
  3.982507739141274*^9}},ExpressionUUID->"574887c3-0377-4ac9-8c97-\
70a6442fd210"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dPtransd\[Phi]", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"D", "[", 
    RowBox[{"Ptrans", ",", "\[Phi]"}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9825064055503597`*^9, 3.982506416175002*^9}, {
  3.982506861454259*^9, 3.982506866067761*^9}},
 CellLabel->"In[78]:=",ExpressionUUID->"dc6528b4-9b10-4901-bc26-c9756ddc7a12"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"4", " ", "r1", " ", "r2", " ", 
    SuperscriptBox["t1", "2"], " ", 
    SuperscriptBox["t2", "2"], " ", 
    RowBox[{"Sin", "[", 
     RowBox[{"2", " ", "\[Phi]"}], "]"}]}], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       SuperscriptBox["r1", "2"], " ", 
       SuperscriptBox["r2", "2"]}], "-", 
      RowBox[{"2", " ", "r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], ")"}], "2"]]}]], "Output",
 CellChangeTimes->{3.982506416453103*^9, 3.982506877079761*^9, 
  3.982773134819346*^9, 3.9870069043910418`*^9},
 CellLabel->"Out[78]=",ExpressionUUID->"4ec904ee-0470-41b0-8f68-3a13f4e86ffb"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dPtransd\[Phi]", "/.", 
  RowBox[{"{", 
   RowBox[{"\[Phi]", "->", "0"}], "}"}]}]], "Input",
 CellChangeTimes->{{3.982506857833125*^9, 3.9825068752395563`*^9}},
 CellLabel->"In[79]:=",ExpressionUUID->"2e1f4253-60bb-43c9-b06c-15cd5cbc994d"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.9825068778406677`*^9, 3.982773134871354*^9, 
  3.9870069043977737`*^9},
 CellLabel->"Out[79]=",ExpressionUUID->"9da14b0c-68c7-4371-8719-3699fffd614a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "4. Starting at resonance, what happens to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "trans"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4e18bd6a-8579-4c0c-8ea1-ddabfea93938"],
 " when the cavity gets shorter?"
}], "Subsubsection",
 CellChangeTimes->{{3.9825068992201443`*^9, 
  3.982506918399746*^9}},ExpressionUUID->"f8d5c757-6e94-4909-b764-\
4c2c6c0502e9"],

Cell[TextData[{
 "Again, the power goes down like ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Phi]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "97786b91-ffd0-4a56-93d2-50610cd6f5ca"],
 ".  \[LineSeparator]This is equivalent because the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "trans"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fed1cb90-f033-42b0-a450-de3272420209"],
 " function is symmetric.  If one considers \[Phi] \[Rule] -\[Phi] in the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "trans"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ec9a722b-5614-4b37-9bcb-2bf0daaaeb7c"],
 " function, we get the same value as before because Cos[-\[Phi]] = \
Cos[\[Phi]]"
}], "Text",
 CellChangeTimes->{{3.982506925711637*^9, 3.9825070302684507`*^9}, {
  3.9825077456927443`*^9, 
  3.9825077478749743`*^9}},ExpressionUUID->"f9ebceed-1f63-422d-894a-\
d9374a4fc768"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Ptrans", "//.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r2", "->", "r1"}], ",", 
      RowBox[{"t2", "->", "t1"}], ",", 
      RowBox[{"r1", "->", 
       SqrtBox[
        RowBox[{"1", "-", 
         SuperscriptBox["t1", "2"]}]]}], ",", 
      RowBox[{"t1", "->", "0.5"}]}], "}"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Phi]", ",", 
     RowBox[{"-", 
      FractionBox["\[Pi]", "2"]}], ",", 
     FractionBox["\[Pi]", "2"]}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "Full"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.982507985530073*^9, 3.982508106954401*^9}},
 CellLabel->"In[80]:=",ExpressionUUID->"64be9a96-3e81-488b-8161-804d5a19cbd9"],

