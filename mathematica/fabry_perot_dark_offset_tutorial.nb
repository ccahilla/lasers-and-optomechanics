Cell[CellGroupData[{

Cell[TextData[{
 "1. Derive an expression for the reflected power ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "refl"], "(", "\[Phi]", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "169e8529-7992-42b4-bf18-0b8d3fb6525f"],
 ".  What is the reflected power at resonance?"
}], "Subsubsection",
 CellChangeTimes->{{3.982507333133164*^9, 
  3.9825073708753557`*^9}},ExpressionUUID->"d352e1df-d2f8-47c8-9935-\
2bc795aec529"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Erefl0", "=", 
  RowBox[{"Erefl", "[", 
   RowBox[{"\[Phi]", ",", "t1", ",", "t2", ",", "r1", ",", "r2"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.982488661715148*^9, 3.982488684459229*^9}},
 CellLabel->"In[39]:=",ExpressionUUID->"11072c56-2cf2-4e32-8bb4-75cc7409201e"],

Cell[BoxData[
 FractionBox[
  RowBox[{"r1", "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
    "r2"}]}], 
  RowBox[{"1", "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", "r1", 
    " ", "r2"}]}]]], "Output",
 CellChangeTimes->{{3.98248866618519*^9, 3.982488690074089*^9}},
 CellLabel->"Out[39]=",ExpressionUUID->"660f5967-5357-4d80-8841-0789bb3b9c26"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Prefl", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"ComplexExpand", "[", 
    RowBox[{"Erefl0", " ", 
     RowBox[{"Conjugate", "[", "Erefl0", "]"}]}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.982488699310376*^9, 3.982488725853546*^9}, {
  3.982490594287834*^9, 3.9824905965051117`*^9}},
 CellLabel->"In[44]:=",ExpressionUUID->"a9789f07-8d38-4f29-be3f-d0b79ed3c897"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["r1", "2"], "+", 
   SuperscriptBox["r2", "2"], "-", 
   RowBox[{"2", " ", "r1", " ", "r2", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], 
  RowBox[{"1", "+", 
   RowBox[{
    SuperscriptBox["r1", "2"], " ", 
    SuperscriptBox["r2", "2"]}], "-", 
   RowBox[{"2", " ", "r1", " ", "r2", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}]]], "Output",
 CellChangeTimes->{{3.982488720759531*^9, 3.982488728554214*^9}, 
   3.982490598139267*^9},
 CellLabel->"Out[44]=",ExpressionUUID->"ab3d48c7-bbd9-4d3d-b3dc-67d9f33f73aa"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{"Prefl", "/.", 
   RowBox[{"{", 
    RowBox[{"\[Phi]", "->", "0"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.982492086234597*^9, 3.982492090955188*^9}},
 CellLabel->"In[46]:=",ExpressionUUID->"55f86549-b9da-4302-a980-d1a0a04f72bf"],

Cell[BoxData[
 FractionBox[
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{"r1", "-", "r2"}], ")"}], "2"], 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     RowBox[{"r1", " ", "r2"}]}], ")"}], "2"]]], "Output",
 CellChangeTimes->{3.982492091758361*^9},
 CellLabel->"Out[46]=",ExpressionUUID->"40484cd7-7217-4c46-af40-78d56e6c72ac"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "2. Set ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["r", "2"], "=", 
    RowBox[{
     SubscriptBox["r", "1"], "=", "r"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "15d7de7b-2c21-45fc-9f5a-711670374bd4"],
 ".  Does ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "refl"], "(", "\[Phi]", ")"}], TraditionalForm]],
  ExpressionUUID->"75a4e777-428c-4981-b5b8-c73135cadf1f"],
 " simplify at all?  What value do you get at resonance?"
}], "Subsubsection",
 CellChangeTimes->{{3.982507395753286*^9, 3.982507434020022*^9}, {
  3.982507541329608*^9, 
  3.982507548828747*^9}},ExpressionUUID->"d7a4ed0a-f618-43ef-beef-\
cd15450394a7"],

Cell["\<\
We get zero reflected power for a critically-coupled cavity at resonance.\
\>", "Text",
 CellChangeTimes->{{3.982507618061225*^9, 
  3.982507635121085*^9}},ExpressionUUID->"366582a9-d852-428b-a843-\
6320c128f449"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Prefl2", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"Prefl", "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r2", "->", "r"}], ",", 
      RowBox[{"r1", "->", "r"}]}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.982490599712742*^9, 3.982490609909978*^9}, {
  3.9825075330781193`*^9, 3.9825075344478703`*^9}, {3.982507598281042*^9, 
  3.982507600734516*^9}},
 CellLabel->
  "In[102]:=",ExpressionUUID->"b4a98247-a9fe-47d8-b36c-40c086abcd8f"],

Cell[BoxData[
 FractionBox[
  RowBox[{"4", " ", 
   SuperscriptBox["r", "2"], " ", 
   SuperscriptBox[
    RowBox[{"Sin", "[", "\[Phi]", "]"}], "2"]}], 
  RowBox[{"1", "+", 
   SuperscriptBox["r", "4"], "-", 
   RowBox[{"2", " ", 
    SuperscriptBox["r", "2"], " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}]]], "Output",
 CellChangeTimes->{3.982490610203141*^9, 3.9825075369183273`*^9, 
  3.9825076011130047`*^9},
 CellLabel->
  "Out[102]=",ExpressionUUID->"2e63ab09-0366-4086-9162-5cd3506e2b2b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Prefl2", "/.", 
  RowBox[{"{", 
   RowBox[{"\[Phi]", "->", "0"}], "}"}]}]], "Input",
 CellChangeTimes->{{3.982507551431905*^9, 3.982507555326178*^9}},
 CellLabel->
  "In[101]:=",ExpressionUUID->"8b486095-60c2-43fa-af7c-54ebfe8a897a"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.98250756488233*^9},
 CellLabel->
  "Out[101]=",ExpressionUUID->"555cac2e-060b-40d6-b01e-42a433c73c52"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
3. Starting at resonance, what happens to the reflected power when the cavity \
gets longer? Shorter?\
\>", "Subsubsection",
 CellChangeTimes->{{3.9825075626218452`*^9, 3.9825075627854643`*^9}, 
   3.98250764713416*^9},ExpressionUUID->"6b1e0df0-cfa2-4e2f-b0e0-\
a5a9b0fcf052"],

Cell[TextData[{
 "Here, the reflected power goes up like ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Phi]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4fd5e969-2ec9-47da-9a97-93688eb3c689"],
 " for both the cavity getting longer and shorter, which can again be seen \
from the symmetric ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "refl"], "(", "\[Phi]", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ecc1f8ee-63db-4177-ab5a-693bebcd3e02"],
 " function."
}], "Text",
 CellChangeTimes->{{3.98250776723627*^9, 3.9825078077023*^9}, {
  3.982507841175219*^9, 3.982507866721623*^9}, {3.9825081889135447`*^9, 
  3.982508199849832*^9}},ExpressionUUID->"94a9cad5-248e-4ed7-bb62-\
a5b55bd77f88"],

