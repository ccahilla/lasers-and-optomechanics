  "Out[175]=",ExpressionUUID->"3bff306f-4411-4f2e-a63b-9d526a9e901e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "5. Calculate the total reflected power ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "refl"], "(", "t", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e4461c66-311f-4966-8d98-c88ae30d6a1c"],
 ".  \n    Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalDelta]x", "2"], "\[Rule]", "0"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9522e4a5-8ca5-4261-8d03-9967886a495a"],
 " for small length modulations."
}], "Subsubsection",
 CellChangeTimes->{{3.982519515295999*^9, 3.982519519289456*^9}, {
  3.982519583467379*^9, 
  3.982519611655209*^9}},ExpressionUUID->"97c272aa-c8bc-4e33-88de-\
d55b9196e10c"],

Cell["\<\
This is a lot of algebra, and it can be easier to let Mathematica handle it.
Letting Mathematica do the heavy lifting\
\>", "Text",
 CellChangeTimes->{{3.9825243309592333`*^9, 3.982524338652089*^9}, {
  3.982524869206708*^9, 
  3.982524870321863*^9}},ExpressionUUID->"436403ae-cd7d-4121-b6b9-\
a85b93e86523"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Prefltotal", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"ComplexExpand", "[", 
     RowBox[{"Erefltotal", " ", 
      RowBox[{"Conjugate", "[", "Erefltotal", "]"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Prefltotal", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Prefltotal", "/.", 
     RowBox[{"{", 
      RowBox[{
       SuperscriptBox["\[CapitalDelta]x", "2"], "->", "0"}], "}"}]}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Preflcollect", "=", 
   RowBox[{"Collect", "[", 
    RowBox[{"Prefltotal", ",", "\[CapitalDelta]x"}], "]"}]}], 
  RowBox[{"(*", 
   RowBox[{"DC", " ", "term", " ", "on", " ", "the", " ", "Left"}], 
   "*)"}]}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.98251952928094*^9, 3.982519537128686*^9}, {
  3.982519617882518*^9, 3.9825196272677717`*^9}, {3.982524237664719*^9, 
  3.982524253702956*^9}, {3.982524316142191*^9, 3.9825243225743847`*^9}, {
  3.9825252586523*^9, 3.982525267421166*^9}},
 CellLabel->
  "In[202]:=",ExpressionUUID->"498f8e83-76ad-4c64-91fc-b802cf605922"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    SuperscriptBox["E0", "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["r1", "2"], "+", 
      SuperscriptBox["r2", "2"], "-", 
      RowBox[{"2", " ", "r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], ")"}]}], 
   RowBox[{"1", "+", 
    RowBox[{
     SuperscriptBox["r1", "2"], " ", 
     SuperscriptBox["r2", "2"]}], "-", 
    RowBox[{"2", " ", "r1", " ", "r2", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}]], "+", 
  FractionBox[
   RowBox[{"4", " ", 
    SuperscriptBox["E0", "2"], " ", "k", " ", "r2", " ", 
    SuperscriptBox["t1", "2"], " ", "\[CapitalDelta]x", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"t", " ", "\[Omega]"}], "]"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         SuperscriptBox["r1", "2"]}], ")"}], " ", "r2", " ", 
       RowBox[{"Sin", "[", "\[Eta]", "]"}]}], "-", 
      RowBox[{"r1", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         SuperscriptBox["r2", "2"]}], ")"}], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Eta]", "+", 
         RowBox[{"2", " ", "\[Phi]"}]}], "]"}]}]}], ")"}]}], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       SuperscriptBox["r1", "2"], " ", 
       SuperscriptBox["r2", "2"]}], "-", 
      RowBox[{"2", " ", "r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       SuperscriptBox["r1", "2"], " ", 
       SuperscriptBox["r2", "2"]}], "-", 
      RowBox[{"2", " ", "r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"\[Eta]", "+", "\[Phi]"}], ")"}]}], "]"}]}]}], 
     ")"}]}]]}]], "Output",
 CellChangeTimes->{{3.982519618212328*^9, 3.98251963204287*^9}, 
   3.98252425842561*^9, 3.982524303593865*^9, 3.982525270634297*^9},
 CellLabel->
  "Out[204]=",ExpressionUUID->"6a2b40eb-cad1-4192-8dcd-eb06253b0036"]
}, Open  ]],

Cell[TextData[{
 "However, we can also try to be clever, and develop our intuition, \
\[LineSeparator]by leaving the fields in their general form:\n(below I have \
incorporated the imaginary term ",
 StyleBox["i ",
  FontSlant->"Italic"],
 "into the E-fields to be consistent with our Mathematica definitions.)",
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "refl"], "=", 
    RowBox[{
     SubscriptBox["E", 
      RowBox[{"refl", ",", "0"}]], "+", 
     RowBox[{"k", " ", "\[CapitalDelta]x", " ", 
      SubscriptBox["E", 
       RowBox[{"refl", ",", "usb"}]], " ", 
      SuperscriptBox["e", 
       RowBox[{"i", " ", "\[Omega]", " ", "t"}]]}], "+", 
     RowBox[{"k", " ", "\[CapitalDelta]x", " ", 
      SubscriptBox["E", 
       RowBox[{"refl", ",", "lsb"}]], 
      SuperscriptBox["e", 
       RowBox[{
        RowBox[{"-", "i"}], " ", "\[Omega]", " ", "t"}]]}]}]}], 
   TraditionalForm]],ExpressionUUID->"776bebe0-fe6b-40b5-a391-4d6942859372"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "refl"], "(", "t", ")"}], "="}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1c43542e-f2ac-41f2-8301-3f4bd395a2ad"],
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     SubscriptBox["P", 
      RowBox[{"refl", ",", "DC"}]], "+", 
     RowBox[{
      SubscriptBox["P", 
       RowBox[{"refl", ",", 
        RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"d97f5ba4-d4b2-4108-a0f2-ef011e72b814"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", 
     RowBox[{"refl", ",", "DC"}]], "=", 
    RowBox[{"|", 
     SubscriptBox["E", 
      RowBox[{"refl", ",", "0"}]], 
     SuperscriptBox["|", "2"], 
     RowBox[{"+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"k", " ", "\[CapitalDelta]x"}], ")"}], "2"]}], "|", 
     SubscriptBox["E", 
      RowBox[{"refl", ",", "usb"}]], 
     SuperscriptBox["|", "2"], 
     RowBox[{"+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"k", " ", "\[CapitalDelta]x"}], ")"}], "2"]}], "|", 
     SubscriptBox["E", 
      RowBox[{"refl", ",", "lsb"}]], 
     SuperscriptBox["|", "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "99c092fc-266b-4aa6-9288-6d9e7bc5380c"],
 "\[LineSeparator]\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", 
      RowBox[{"refl", ",", 
       RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}], "=", 
    RowBox[{"k", " ", "\[CapitalDelta]x", " ", 
     SubscriptBox["P", "in"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox["e", 
         RowBox[{"i", " ", "\[Omega]", " ", "t"}]], "(", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           SubscriptBox["E", 
            RowBox[{"refl", ",", "0"}]], "*"], 
          SubscriptBox["E", 
           RowBox[{"refl", ",", "usb"}]]}], "+", 
         RowBox[{
          SubscriptBox["E", 
           RowBox[{"refl", ",", "0"}]], 
          SuperscriptBox[
           SubscriptBox["E", 
            RowBox[{"refl", ",", "lsb"}]], "*"]}]}], ")"}], "+", 
       RowBox[{
        SuperscriptBox["e", 
         RowBox[{
          RowBox[{"-", "i"}], " ", "\[Omega]", " ", "t"}]], "(", 
        RowBox[{
         RowBox[{
          SubscriptBox["E", 
           RowBox[{"refl", ",", "0"}]], 
          SuperscriptBox[
           SubscriptBox["E", 
            RowBox[{"refl", ",", "usb"}]], "*"]}], "+", 
         RowBox[{
          SuperscriptBox[
           SubscriptBox["E", 
            RowBox[{"refl", ",", "0"}]], "*"], 
          SubscriptBox["E", 
           RowBox[{"refl", ",", "lsb"}]]}]}], ")"}]}], ")"}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e9c19f4a-e7a0-43f8-b8b4-6ea9b867dce9"],
 "\n\nIn the last term ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", 
     RowBox[{"refl", ",", 
      RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}], TraditionalForm]],
  ExpressionUUID->"5f3b17b0-1fb4-41d2-a504-0ab14accaed8"],
 ", we get our oscillations at frequency \[Omega].  \nThe term on the right \
inside the parentheses is just the complex conjugate of the term on the left.\
\nSo we could do something like write ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"z", "(", "t", ")"}], "=", 
    RowBox[{
     SuperscriptBox["e", 
      RowBox[{"i", " ", "\[Omega]", " ", "t"}]], "(", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        SubscriptBox["E", 
         RowBox[{"refl", ",", "0"}]], "*"], 
       SubscriptBox["E", 
        RowBox[{"refl", ",", "usb"}]]}], "+", 
      RowBox[{
       SubscriptBox["E", 
        RowBox[{"refl", ",", "0"}]], 
       SuperscriptBox[
        SubscriptBox["E", 
         RowBox[{"refl", ",", "lsb"}]], "*"]}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"9e3e0f4b-a19a-4c5f-9163-6a50f65cd40b"],
 ", and get \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", 
      RowBox[{"refl", ",", 
       RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}], "=", 
    RowBox[{"k", " ", "\[CapitalDelta]x", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox["e", 
         RowBox[{"i", " ", "\[Omega]", " ", "t"}]], "(", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           SubscriptBox["E", 
            RowBox[{"refl", ",", "0"}]], "*"], 
          SubscriptBox["E", 
           RowBox[{"refl", ",", "usb"}]]}], "+", 
         RowBox[{
          SubscriptBox["E", 
