  "Out[126]=",ExpressionUUID->"d97c09e2-80be-4f89-842f-355c53893e05"]
}, Open  ]],

Cell[TextData[{
 "Interpreting the above plot, we get a zero crossing of our reflected power \
signal ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "refl"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b735beac-8a2d-4e17-8df1-f19ecd0533ed"],
 " coming from our end-mirror modulation \[CapitalDelta]x directly at \
resonance where \[Phi] = 0.\nThe y-axis units are in watts per meter, and \
tell us ultra-sensitive our interferometer is to end-mirror motion near \
resonance, even for this low-performing interferometer..\n\nComparing to the \
real and imaginary plots of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "refl"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1f320790-1dcd-47a0-89d7-6e6d83d21528"],
 " sweep over \[Phi].\[LineSeparator]Notice that our real demodulated signal ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["P", "refl"], "\[CapitalDelta]x"], 
    RowBox[{"(", 
     RowBox[{"\[Omega]", ",", "\[Phi]"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "279d4986-dea2-4461-a258-bf16bccd6c7d"],
 "  is very similar to our imaginary part of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "refl"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4a799823-04dc-4c6d-a29c-861998d25d68"]
}], "Text",
 CellChangeTimes->{{3.98252917986651*^9, 3.982529294924512*^9}, {
  3.982529682846133*^9, 
  3.982529928068575*^9}},ExpressionUUID->"4226274a-2502-4f66-b587-\
108694922b13"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Re", "[", 
    RowBox[{"Erefl0", "//.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"r2", "->", "r1"}], ",", 
       RowBox[{"r1", "->", 
        SqrtBox[
         RowBox[{"1", "-", "0.3"}]]}]}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Phi]", ",", 
     RowBox[{"-", 
      FractionBox["\[Pi]", "2"]}], ",", 
     FractionBox["\[Pi]", "2"]}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "Full"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<Phase \[Phi]\>\"", ",", 
      "\"\<Re[\!\(\*SubscriptBox[\(E\), \(refl\)]\)]\>\""}], "}"}]}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Im", "[", 
    RowBox[{"Erefl0", "//.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"r2", "->", "r1"}], ",", 
       RowBox[{"r1", "->", 
        SqrtBox[
         RowBox[{"1", "-", "0.3"}]]}]}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Phi]", ",", 
     RowBox[{"-", 
      FractionBox["\[Pi]", "2"]}], ",", 
     FractionBox["\[Pi]", "2"]}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "Full"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<Phase \[Phi]\>\"", ",", 
      "\"\<Im[\!\(\*SubscriptBox[\(E\), \(refl\)]\)]\>\""}], "}"}]}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.982529214189671*^9, 3.982529219736548*^9}, {
  3.9825293655356894`*^9, 3.982529374485425*^9}, {3.982594132236437*^9, 
