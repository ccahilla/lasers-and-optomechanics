         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{"\[Eta]", "+", "\[Phi]"}], ")"}]}], "]"}]}]}], ")"}]}], 
    ")"}]}]}]], "Output",
 CellChangeTimes->{{3.982519618212328*^9, 3.98251963204287*^9}, 
   3.98252425842561*^9, 3.982524303593865*^9, 3.982525270634297*^9, 
   3.982773139053996*^9, 3.9870069338327703`*^9},
 CellLabel->
  "Out[108]=",ExpressionUUID->"b79e996c-5a53-4cef-b850-cd9b7471d4c1"]
}, Open  ]],

Cell[TextData[{
 "However, we can also try to be clever, and develop our intuition, \
\[LineSeparator]by leaving the fields in their general form:\n(below I have \
incorporated the imaginary term ",
 StyleBox["i ",
  FontSlant->"Italic"],
 "into the E-fields to be consistent with our Mathematica definitions.)",
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "refl"], "=", 
    RowBox[{
     SubscriptBox["E", 
      RowBox[{"refl", ",", "0"}]], "+", 
     RowBox[{"k", " ", "\[CapitalDelta]x", " ", 
      SubscriptBox["E", 
       RowBox[{"refl", ",", "usb"}]], " ", 
      SuperscriptBox["e", 
       RowBox[{"i", " ", "\[Omega]", " ", "t"}]]}], "+", 
     RowBox[{"k", " ", "\[CapitalDelta]x", " ", 
      SubscriptBox["E", 
       RowBox[{"refl", ",", "lsb"}]], 
      SuperscriptBox["e", 
       RowBox[{
        RowBox[{"-", "i"}], " ", "\[Omega]", " ", "t"}]]}]}]}], 
   TraditionalForm]],ExpressionUUID->"776bebe0-fe6b-40b5-a391-4d6942859372"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "refl"], "(", "t", ")"}], "="}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1c43542e-f2ac-41f2-8301-3f4bd395a2ad"],
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     SubscriptBox["P", 
      RowBox[{"refl", ",", "DC"}]], "+", 
     RowBox[{
      SubscriptBox["P", 
       RowBox[{"refl", ",", 
        RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"d97f5ba4-d4b2-4108-a0f2-ef011e72b814"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", 
     RowBox[{"refl", ",", "DC"}]], "=", 
    RowBox[{"|", 
     SubscriptBox["E", 
      RowBox[{"refl", ",", "0"}]], 
     SuperscriptBox["|", "2"], 
     RowBox[{"+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"k", " ", "\[CapitalDelta]x"}], ")"}], "2"]}], "|", 
     SubscriptBox["E", 
      RowBox[{"refl", ",", "usb"}]], 
     SuperscriptBox["|", "2"], 
     RowBox[{"+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"k", " ", "\[CapitalDelta]x"}], ")"}], "2"]}], "|", 
     SubscriptBox["E", 
      RowBox[{"refl", ",", "lsb"}]], 
     SuperscriptBox["|", "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "99c092fc-266b-4aa6-9288-6d9e7bc5380c"],
 "\[LineSeparator]\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", 
      RowBox[{"refl", ",", 
       RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}], "=", 
    RowBox[{"k", " ", "\[CapitalDelta]x", " ", 
     SubscriptBox["P", "in"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox["e", 
         RowBox[{"i", " ", "\[Omega]", " ", "t"}]], "(", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           SubscriptBox["E", 
            RowBox[{"refl", ",", "0"}]], "*"], 
          SubscriptBox["E", 
           RowBox[{"refl", ",", "usb"}]]}], "+", 
         RowBox[{
          SubscriptBox["E", 
           RowBox[{"refl", ",", "0"}]], 
          SuperscriptBox[
           SubscriptBox["E", 
            RowBox[{"refl", ",", "lsb"}]], "*"]}]}], ")"}], "+", 
       RowBox[{
        SuperscriptBox["e", 
         RowBox[{
          RowBox[{"-", "i"}], " ", "\[Omega]", " ", "t"}]], "(", 
        RowBox[{
         RowBox[{
          SubscriptBox["E", 
           RowBox[{"refl", ",", "0"}]], 
          SuperscriptBox[
           SubscriptBox["E", 
            RowBox[{"refl", ",", "usb"}]], "*"]}], "+", 
         RowBox[{
          SuperscriptBox[
           SubscriptBox["E", 
            RowBox[{"refl", ",", "0"}]], "*"], 
          SubscriptBox["E", 
           RowBox[{"refl", ",", "lsb"}]]}]}], ")"}]}], ")"}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e9c19f4a-e7a0-43f8-b8b4-6ea9b867dce9"],
 "\n\nIn the last term ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", 
     RowBox[{"refl", ",", 
      RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}], TraditionalForm]],
  ExpressionUUID->"5f3b17b0-1fb4-41d2-a504-0ab14accaed8"],
 ", we get our oscillations at frequency \[Omega].  \nThe term on the right \
inside the parentheses is just the complex conjugate of the term on the left.\
\nSo we could do something like write ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"z", "(", "t", ")"}], "=", 
    RowBox[{
     SuperscriptBox["e", 
      RowBox[{"i", " ", "\[Omega]", " ", "t"}]], "(", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        SubscriptBox["E", 
         RowBox[{"refl", ",", "0"}]], "*"], 
       SubscriptBox["E", 
        RowBox[{"refl", ",", "usb"}]]}], "+", 
      RowBox[{
       SubscriptBox["E", 
        RowBox[{"refl", ",", "0"}]], 
       SuperscriptBox[
        SubscriptBox["E", 
         RowBox[{"refl", ",", "lsb"}]], "*"]}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"9e3e0f4b-a19a-4c5f-9163-6a50f65cd40b"],
 ", and get \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", 
      RowBox[{"refl", ",", 
       RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}], "=", 
    RowBox[{"k", " ", "\[CapitalDelta]x", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox["e", 
         RowBox[{"i", " ", "\[Omega]", " ", "t"}]], "(", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           SubscriptBox["E", 
            RowBox[{"refl", ",", "0"}]], "*"], 
          SubscriptBox["E", 
           RowBox[{"refl", ",", "usb"}]]}], "+", 
         RowBox[{
          SubscriptBox["E", 
           RowBox[{"refl", ",", "0"}]], 
          SuperscriptBox[
           SubscriptBox["E", 
            RowBox[{"refl", ",", "lsb"}]], "*"]}]}], ")"}], "+", "CC"}], 
      ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "036450ef-7fe2-4c52-95fe-36e0c974e0ca"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", 
      RowBox[{"refl", ",", 
       RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}], "=", 
    RowBox[{"k", " ", "\[CapitalDelta]x", " ", 
     RowBox[{"(", 
      RowBox[{"z", "+", 
       SuperscriptBox["z", "*"]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "25f9627d-4880-4bfc-9d1f-5154491879f8"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", 
      RowBox[{"refl", ",", 
       RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}], "=", 
    RowBox[{"2", "k", " ", "\[CapitalDelta]x", " ", 
     RowBox[{"Re", "(", "z", ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "44c2eb2d-021a-466d-92b5-548e24c99f95"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", 
      RowBox[{"refl", ",", 
       RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}], "=", 
    RowBox[{"2", "k", " ", "\[CapitalDelta]x", " ", 
     RowBox[{"Re", "(", 
      RowBox[{
       SuperscriptBox["e", 
        RowBox[{"i", " ", "\[Omega]", " ", "t"}]], "(", 
       RowBox[{
        RowBox[{
         SuperscriptBox[
          SubscriptBox["E", 
           RowBox[{"refl", ",", "0"}]], "*"], 
         SubscriptBox["E", 
          RowBox[{"refl", ",", "usb"}]]}], "+", 
        RowBox[{
         SubscriptBox["E", 
          RowBox[{"refl", ",", "0"}]], 
         SuperscriptBox[
          SubscriptBox["E", 
           RowBox[{"refl", ",", "lsb"}]], "*"]}]}], ")"}], ")"}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cbd46ae0-b488-429a-a4d7-74d931188b4e"],
 "\n\nIf we calculate this term in the parenthesis: "
}], "Text",
 CellChangeTimes->{{3.982519652274766*^9, 3.982519658140635*^9}, {
  3.982519740308601*^9, 3.982519748227659*^9}, {3.982519873936919*^9, 
  3.982519875504368*^9}, {3.982519928992753*^9, 3.9825199547022133`*^9}, {
  3.982520008954146*^9, 3.9825203608567667`*^9}, {3.982520394127549*^9, 
  3.9825204341182327`*^9}, {3.98252046583372*^9, 3.982520660495109*^9}, {
