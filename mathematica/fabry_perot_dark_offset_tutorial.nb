Cell[CellGroupData[{

Cell["6. Demodulate the power signal", "Subsubsection",
 CellChangeTimes->{{3.982524214367024*^9, 
  3.982524227309844*^9}},ExpressionUUID->"8e066a47-35a2-4615-a4ea-\
905a53924c02"],

Cell["\<\
This appears to be another monumental algebraic task, and it is.\
\[LineSeparator]Again, let\[CloseCurlyQuote]s start by letting Mathematica do \
the heavy lifting.\
\>", "Text",
 CellChangeTimes->{{3.982525311039506*^9, 3.982525374435328*^9}, 
   3.982525487528041*^9},ExpressionUUID->"8d6d3b9b-c47c-479d-b43c-\
e47469597114"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"PrefltotaldemodI", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", "\[Pi]"}]], 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Prefltotal", " ", 
        RowBox[{"Cos", "[", "\[Omega]t", "]"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{"t", "->", 
         RowBox[{"-", 
          FractionBox["\[Omega]t", "\[Omega]"]}]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Omega]t", ",", "0", ",", 
        RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"PrefltotaldemodQ", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", "\[Pi]"}]], 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Prefltotal", " ", 
        RowBox[{"Sin", "[", "\[Omega]t", "]"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{"t", "->", 
         RowBox[{"-", 
          FractionBox["\[Omega]t", "\[Omega]"]}]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Omega]t", ",", "0", ",", 
        RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Prefltotaldemodtf", "=", 
  RowBox[{"Simplify", "[", 
   FractionBox[
    RowBox[{"PrefltotaldemodI", "+", 
     RowBox[{"I", " ", "PrefltotaldemodQ"}]}], "\[CapitalDelta]x"], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.9825253628265743`*^9, 3.9825254664636707`*^9}, {
  3.98252693855862*^9, 3.98252697843675*^9}, {3.98700695300949*^9, 
  3.987006955123143*^9}},
 CellLabel->
  "In[135]:=",ExpressionUUID->"65959654-9a7a-4fc4-8ad3-8d73e3c347a9"],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   SuperscriptBox["E0", "2"], " ", "k", " ", "r1", " ", "r2", " ", 
   SuperscriptBox["t1", "2"], " ", "\[CapitalDelta]x", " ", 
   RowBox[{"Cos", "[", "\[Eta]", "]"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["r2", "2"]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", 
          RowBox[{
           SuperscriptBox["r1", "2"], " ", 
           SuperscriptBox["r2", "2"]}]}], ")"}]}], ")"}]}], "+", 
     RowBox[{"2", " ", "r2", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           SuperscriptBox["r1", "2"]}], ")"}], " ", "r2", " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", " ", "\[Eta]"}], "]"}]}], "+", 
        RowBox[{"r1", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           SuperscriptBox["r2", "2"]}], ")"}], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], ")"}]}]}], ")"}], " ", 
   RowBox[{"Sin", "[", 
    RowBox[{"2", " ", "\[Phi]"}], "]"}]}], 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{
      SuperscriptBox["r1", "2"], " ", 
      SuperscriptBox["r2", "2"]}], "-", 
     RowBox[{"2", " ", "r1", " ", "r2", " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{"\[Eta]", "-", "\[Phi]"}], ")"}]}], "]"}]}]}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{
      SuperscriptBox["r1", "2"], " ", 
      SuperscriptBox["r2", "2"]}], "-", 
     RowBox[{"2", " ", "r1", " ", "r2", " ", 
