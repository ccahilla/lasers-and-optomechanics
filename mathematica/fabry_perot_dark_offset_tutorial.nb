Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"2", " ", "k", " ", "r1", " ", "r2", " ", 
    SuperscriptBox["t1", "2"], " ", "\[CapitalDelta]x", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         SuperscriptBox["r2", "2"]}], ")"}], " ", 
       RowBox[{"Cos", "[", "\[Eta]", "]"}]}], "-", 
      RowBox[{"\[ImaginaryI]", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SuperscriptBox["r2", "2"]}], ")"}], " ", 
       RowBox[{"Sin", "[", "\[Eta]", "]"}]}]}], ")"}], " ", 
    RowBox[{"Sin", "[", 
     RowBox[{"2", " ", "\[Phi]"}], "]"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{
        RowBox[{"2", " ", "\[Eta]"}], "-", 
        RowBox[{"t", " ", "\[Omega]"}]}], "]"}], "-", 
      RowBox[{"\[ImaginaryI]", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{
         RowBox[{"2", " ", "\[Eta]"}], "-", 
         RowBox[{"t", " ", "\[Omega]"}]}], "]"}]}]}], ")"}]}], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       SuperscriptBox["r1", "2"], " ", 
       SuperscriptBox["r2", "2"]}], "-", 
      RowBox[{"2", " ", "r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"\[Eta]", "-", "\[Phi]"}], ")"}]}], "]"}]}], "+", 
      RowBox[{"\[ImaginaryI]", " ", "r1", " ", "r2", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "\[Eta]"}], "+", "\[Phi]"}], ")"}]}], "]"}]}]}], 
     ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"\[Eta]", "+", "\[Phi]"}], ")"}]}], "]"}]}], "-", 
      RowBox[{"\[ImaginaryI]", " ", "r1", " ", "r2", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"\[Eta]", "+", "\[Phi]"}], ")"}]}], "]"}]}]}], 
     ")"}]}]]}]], "Output",
