   RowBox[{"(", 
    RowBox[{"Erefl00", "+", "Ereflusb", "+", "Erefllsb"}], ")"}], "E0", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{"I", " ", "\[Omega]0", " ", "t"}], "]"}]}]}]}], "Input",
