         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
         "r1", " ", "r2"}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", 
           RowBox[{"(", 
            RowBox[{"\[Eta]", "+", "\[Phi]"}], ")"}]}]], " ", "r1", " ", 
         "r2"}]}], ")"}]}]], "+", 
    FractionBox[
     RowBox[{"\[ImaginaryI]", " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Phi]"}], "-", 
        RowBox[{"\[ImaginaryI]", " ", 
         RowBox[{"(", 
          RowBox[{"\[Eta]", "+", "\[Phi]"}], ")"}]}], "+", 
        RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[Omega]"}]}]], " ", "k", 
      " ", "r2", " ", 
      SuperscriptBox["t1", "2"], " ", "\[CapitalDelta]x"}], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
         "r1", " ", "r2"}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", 
           RowBox[{"(", 
            RowBox[{"\[Eta]", "+", "\[Phi]"}], ")"}]}]], " ", "r1", " ", 
         "r2"}]}], ")"}]}]]}], ")"}]}]], "Output",
 CellChangeTimes->{
  3.982515248317088*^9, 3.982515934745063*^9, {3.982519156536654*^9, 
   3.9825191671978483`*^9}, 3.98252429096809*^9},
