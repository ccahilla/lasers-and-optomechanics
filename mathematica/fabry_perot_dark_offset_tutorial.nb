 RowBox[{"zz", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"ComplexExpand", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", "Erefl00", "]"}], "Ereflusb"}], "+", 
     RowBox[{"Erefl00", " ", 
      RowBox[{"Conjugate", "[", "Erefllsb", "]"}]}]}], "]"}], 
   "]"}]}]], "Input",
