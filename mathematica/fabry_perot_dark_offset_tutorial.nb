Cell["\<\
Compare Prefl1\[Omega] to the second term in Prefltotal, and we get the same \
result\
\>", "Text",
 CellChangeTimes->{{3.9825251144503727`*^9, 
  3.982525133703442*^9}},ExpressionUUID->"42cd631a-4002-46c2-bcd2-\
c0075ef692f6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Preflcollect", "[", 
  RowBox[{"[", "2", "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.982525149261395*^9, 3.982525191294867*^9}, {
  3.982525252926691*^9, 3.982525277889434*^9}},
 CellLabel->
  "In[112]:=",ExpressionUUID->"a92a6a7a-1649-4f73-bdfa-854a92701b98"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    SuperscriptBox["E0", "2"], " ", "\[CapitalDelta]x", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"4", " ", "k", " ", "r1", " ", "r2", " ", 
       SuperscriptBox["t1", "2"], " ", 
       RowBox[{"Cos", "[", "\[Eta]", "]"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "+", 
              SuperscriptBox["r2", "2"]}], ")"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "1"}], "+", 
              RowBox[{
               SuperscriptBox["r1", "2"], " ", 
               SuperscriptBox["r2", "2"]}]}], ")"}]}], ")"}]}], "+", 
         RowBox[{"2", " ", "r2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "1"}], "+", 
               SuperscriptBox["r1", "2"]}], ")"}], " ", "r2", " ", 
             RowBox[{"Cos", "[", 
              RowBox[{"2", " ", "\[Eta]"}], "]"}]}], "+", 
            RowBox[{"r1", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "1"}], "+", 
               SuperscriptBox["r2", "2"]}], ")"}], " ", 
             RowBox[{"Cos", "[", 
              RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], ")"}]}]}], ")"}], " ", 
       
       RowBox[{"Cos", "[", 
        RowBox[{"t", " ", "\[Omega]"}], "]"}], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"2", " ", "\[Phi]"}], "]"}]}], "-", 
      RowBox[{"4", " ", "k", " ", "r1", " ", "r2", " ", 
       SuperscriptBox["t1", "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "1"}], "+", 
              SuperscriptBox["r2", "2"]}], ")"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "1"}], "+", 
              RowBox[{
               SuperscriptBox["r1", "2"], " ", 
               SuperscriptBox["r2", "2"]}]}], ")"}]}], ")"}]}], "+", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            SuperscriptBox["r1", "2"]}], ")"}], " ", 
          SuperscriptBox["r2", "2"], " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "\[Eta]"}], "]"}]}], "-", 
         RowBox[{"2", " ", "r1", " ", "r2", " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            SuperscriptBox["r2", "2"]}], ")"}], " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], ")"}], " ", 
       RowBox[{"Sin", "[", "\[Eta]", "]"}], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"2", " ", "\[Phi]"}], "]"}], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"t", " ", "\[Omega]"}], "]"}]}]}], ")"}]}], ")"}], "/", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       SuperscriptBox["r1", "2"], " ", 
       SuperscriptBox["r2", "2"]}], "-", 
      RowBox[{"2", " ", "r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"\[Eta]", "-", "\[Phi]"}], ")"}]}], "]"}]}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       SuperscriptBox["r1", "2"], " ", 
       SuperscriptBox["r2", "2"]}], "-", 
      RowBox[{"2", " ", "r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       SuperscriptBox["r1", "2"], " ", 
       SuperscriptBox["r2", "2"]}], "-", 
      RowBox[{"2", " ", "r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"\[Eta]", "+", "\[Phi]"}], ")"}]}], "]"}]}]}], ")"}]}], 
   ")"}]}]], "Output",
 CellChangeTimes->{{3.9825251551834908`*^9, 3.9825251914790297`*^9}, 
   3.982525282963543*^9, 3.982773139367694*^9, 3.9870069345162783`*^9},
 CellLabel->
