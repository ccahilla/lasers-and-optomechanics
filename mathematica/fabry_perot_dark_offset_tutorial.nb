Cell[BoxData[{
 RowBox[{"PrefltotaldemodI", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", "\[Pi]"}]], 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Prefltotal", " ", 
        RowBox[{"Cos", "[", "\[Omega]t", "]"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{"t", "->", 
         RowBox[{"-", 
          FractionBox["\[Omega]t", "\[Omega]"]}]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Omega]t", ",", "0", ",", 
        RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"PrefltotaldemodQ", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", "\[Pi]"}]], 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Prefltotal", " ", 
        RowBox[{"Sin", "[", "\[Omega]t", "]"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{"t", "->", 
         RowBox[{"-", 
          FractionBox["\[Omega]t", "\[Omega]"]}]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Omega]t", ",", "0", ",", 
        RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Prefltotaldemodtf", "=", 
  FractionBox[
   RowBox[{"PrefltotaldemodI", "+", 
    RowBox[{"I", " ", "PrefltotaldemodQ"}]}], "\[CapitalDelta]x"]}]}], "Input",\

 CellChangeTimes->{{3.9825253628265743`*^9, 3.9825254664636707`*^9}, {
