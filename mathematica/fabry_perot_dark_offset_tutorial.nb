Cell[CellGroupData[{

Cell["Plot of Dither Locking Transfer Function", "Subsubsection",
 CellChangeTimes->{{3.9826054874580173`*^9, 
  3.982605495179278*^9}},ExpressionUUID->"27ffb8ba-ebae-409d-b1aa-\
f3ac3b029a75"],

Cell[TextData[{
 "Here we adjust the dither frequency \[Omega], while assuming we are \
perfectly on resonance. \[LineSeparator]This gives us our",
 StyleBox[" length-to-reflected-power transfer function",
  FontSlant->"Italic"],
 " frequency response.\n\nThis time our values need to specify our carrier \
phase \[Phi], not our modulation frequency \[Omega] which we want to sweep.\
\[LineSeparator]We specify the carrier phase \[Phi] = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "\[Degree]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "76e8866d-9c1c-435d-b1cc-35f37f50b8b2"],
 ", because if we are at exactly \[Phi] = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[Degree]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bd4d7a34-da7d-49a1-aa84-5a4954d704a4"],
 " our error signal goes to zero (as seen in our phase sweep above)."
}], "Text",
 CellChangeTimes->{{3.982605570443408*^9, 3.982605631078665*^9}, {
  3.9826057420788097`*^9, 3.982605776969458*^9}, {3.982606264876874*^9, 
  3.98260629847124*^9}, {3.982606440661992*^9, 3.982606461586318*^9}, {
  3.9826064978546553`*^9, 
  3.9826065053796997`*^9}},ExpressionUUID->"09c9f679-948b-4084-a57d-\
4df393862c6b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"values2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Lambda]", "->", 
      RowBox[{"1064", " ", 
       SuperscriptBox["10", 
        RowBox[{"-", "9"}]]}]}], ",", 
     RowBox[{"T1", "->", "0.3"}], ",", 
     RowBox[{"T2", "->", "0.3"}], ",", 
     RowBox[{"L", "->", "1"}], ",", 
     RowBox[{"c", "->", 
      RowBox[{"3", " ", 
       SuperscriptBox["10", "8"]}]}], ",", 
     RowBox[{"\[Phi]", "->", 
      RowBox[{"1", 
       FractionBox["\[Pi]", "180"]}]}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"flow", "=", 
   SuperscriptBox["10", "4"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fhigh", "=", 
   RowBox[{"3", " ", 
    SuperscriptBox["10", "8"]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.982605744067185*^9, 3.982605748306588*^9}, {
  3.982605783717641*^9, 3.982605823310296*^9}, {3.982606033197641*^9, 
  3.9826060361386147`*^9}, {3.982606096805181*^9, 3.982606100646597*^9}, {
  3.982606224085924*^9, 3.9826062536712933`*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"7cd4a496-2ecc-4848-b96d-724829e74f1b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Prefltotaldemodtf", "//.", "params"}]], "Input",
 CellChangeTimes->{{3.982606000976736*^9, 3.982606058115572*^9}},
 CellLabel->"In[57]:=",ExpressionUUID->"88e0f1fe-7d55-4536-a6bf-947933cdc30f"],

Cell[BoxData[
 FractionBox[
  RowBox[{"4", " ", "\[Pi]", " ", "T1", " ", 
   SqrtBox[
    RowBox[{"1", "-", "T2"}]], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "T1"}], " ", 
      SqrtBox[
       RowBox[{"1", "-", "T2"}]], " ", 
      RowBox[{"Sin", "[", 
       FractionBox[
        RowBox[{"2", " ", "f", " ", "L", " ", "\[Pi]"}], "c"], "]"}]}], "+", 
     RowBox[{
      SqrtBox[
       RowBox[{"1", "-", "T1"}]], " ", "T2", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{
        FractionBox[
         RowBox[{"2", " ", "f", " ", "L", " ", "\[Pi]"}], "c"], "+", 
        RowBox[{"2", " ", "\[Phi]"}]}], "]"}]}]}], ")"}]}], 
  RowBox[{"\[Lambda]", " ", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "T1"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "T2"}], ")"}]}], "-", 
     RowBox[{"2", " ", 
      SqrtBox[
       RowBox[{"1", "-", "T1"}]], " ", 
      SqrtBox[
       RowBox[{"1", "-", "T2"}]], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "T1"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "T2"}], ")"}]}], "-", 
     RowBox[{"2", " ", 
      SqrtBox[
       RowBox[{"1", "-", "T1"}]], " ", 
      SqrtBox[
       RowBox[{"1", "-", "T2"}]], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{
          FractionBox[
           RowBox[{"2", " ", "f", " ", "L", " ", "\[Pi]"}], "c"], "+", 
          "\[Phi]"}], ")"}]}], "]"}]}]}], ")"}]}]]], "Output",
 CellChangeTimes->{
  3.982605989588984*^9, {3.982606020726417*^9, 3.9826060584541397`*^9}, 
   3.9826062064261*^9, 3.982773142036693*^9},
 CellLabel->"Out[57]=",ExpressionUUID->"d3a50eeb-863d-40cf-83bf-267486dc1c49"]
}, Open  ]],

