 RowBox[{
  RowBox[{"Erefl00", "=", "Erefl0"}], " "}], "\[IndentingNewLine]", 
 RowBox[{"Ereflusb", "=", 
  RowBox[{"Ecav2usb", " ", 
   RowBox[{"Ecav2toErefl", "[", 
    RowBox[{"\[Phi]", "+", "\[Eta]"}], "]"}]}]}], "\[IndentingNewLine]", 
