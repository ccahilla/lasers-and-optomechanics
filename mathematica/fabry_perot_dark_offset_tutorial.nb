     RowBox[{"2", " ", "\[Phi]"}], "]"}]}], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       SuperscriptBox["r1", "2"], " ", 
       SuperscriptBox["r2", "2"]}], "-", 
      RowBox[{"2", " ", "r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"\[Eta]", "-", "\[Phi]"}], ")"}]}], "]"}]}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       SuperscriptBox["r1", "2"], " ", 
       SuperscriptBox["r2", "2"]}], "-", 
      RowBox[{"2", " ", "r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       SuperscriptBox["r1", "2"], " ", 
       SuperscriptBox["r2", "2"]}], "-", 
      RowBox[{"2", " ", "r1", " ", "r2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"\[Eta]", "+", "\[Phi]"}], ")"}]}], "]"}]}]}], 
     ")"}]}]]}]], "Output",
 CellChangeTimes->{{3.982525457892262*^9, 3.9825254671125727`*^9}, 
   3.982526950209628*^9, 3.9825269816579523`*^9, 3.98252826456734*^9, 
   3.982773140787431*^9, {3.987006937739841*^9, 3.987006960789415*^9}},
 CellLabel->
  "Out[136]=",ExpressionUUID->"85599f12-bf44-4fb0-9b27-b24ee86172e8"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"2", " ", 
    SuperscriptBox["E0", "2"], " ", "k", " ", "r1", " ", "r2", " ", 
    SuperscriptBox["t1", "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         SuperscriptBox["r2", "2"]}], ")"}], " ", 
       RowBox[{"Cos", "[", "\[Eta]", "]"}]}], "-", 
      RowBox[{"\[ImaginaryI]", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SuperscriptBox["r2", "2"]}], ")"}], " ", 
       RowBox[{"Sin", "[", "\[Eta]", "]"}]}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
