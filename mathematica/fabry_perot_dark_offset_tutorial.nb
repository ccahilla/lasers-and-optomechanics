Cell[BoxData[
 FractionBox[
  RowBox[{"\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Phi]"}], "-", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{"\[Eta]", "+", "\[Phi]"}], ")"}]}], "+", 
     RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[Omega]"}]}]], " ", "k", " ", 
   "r2", " ", 
   SuperscriptBox["t1", "2"], " ", "\[CapitalDelta]x"}], 
  RowBox[{
   RowBox[{"(", 
