  3.982528731117711*^9, 3.9825287311896772`*^9}, {3.982528851094706*^9, 
  3.982528852754499*^9}, {3.9827733166119757`*^9, 3.9827733467789907`*^9}, {
  3.982773468994266*^9, 3.982773469124872*^9}, {3.982773521351239*^9, 
  3.982773539037879*^9}},
 CellLabel->
  "In[122]:=",ExpressionUUID->"93371e41-baf5-4387-91d6-dd2127502f62"],

