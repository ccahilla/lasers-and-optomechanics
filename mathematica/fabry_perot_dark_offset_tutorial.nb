Cell[CellGroupData[{

Cell["\<\
5. Would it be possible to use the transmitted power to restore resonance in \
case of some disturbance \[CapitalDelta]L?\
\>", "Subsubsection",
 CellChangeTimes->{{3.982507038459445*^9, 3.982507057263311*^9}, {
  3.982507231974663*^9, 
  3.982507235826933*^9}},ExpressionUUID->"1f7e6593-2d35-4d1f-9558-\
07b959c2b494"],

Cell["\<\
Perhaps.  \[LineSeparator]You would have to move in a direction and monitor \
whether the transmitted power went up or down.  \[LineSeparator]If \
transmitted power went down, then you\[CloseCurlyQuote]d need to switch \
directions.  \[LineSeparator]It would be hard to know when you achieved \
perfect resonance as well, as you\[CloseCurlyQuote]d tend to go past it and \
need to reverse directions.\
\>", "Text",
 CellChangeTimes->{{3.9825070693635807`*^9, 3.982507138336672*^9}, {
  3.982507249027895*^9, 
  3.982507276379982*^9}},ExpressionUUID->"a3df5c1e-51ca-4066-9ef4-\
ce0396be47f5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Extra Credit: Transmitted Field Phasor Plots", "Subsubsection",
 CellChangeTimes->{{3.982506033190333*^9, 3.982506036566948*^9}, {
  3.982506125878729*^9, 
  3.982506137444284*^9}},ExpressionUUID->"7d636dfd-ea35-4c43-917b-\
4414d8cdfa09"],

Cell["\<\
We get two \[OpenCurlyDoubleQuote]lobes\[CloseCurlyDoubleQuote] for even and \
odd resonances, thanks to the Exp[-I \[Phi]] in the numerator.\
\>", "Text",
 CellChangeTimes->{{3.982506049040433*^9, 
  3.9825060816563063`*^9}},ExpressionUUID->"a09cb6c7-3d86-45a1-ad08-\
3b80236694c3"],

