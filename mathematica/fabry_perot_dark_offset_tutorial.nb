Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[Omega]0"}]], " ", "E0", " ", 
  RowBox[{"(", 
   RowBox[{
    FractionBox[
     RowBox[{"r1", "-", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
       "r2"}]}], 
     RowBox[{"1", "-", 
