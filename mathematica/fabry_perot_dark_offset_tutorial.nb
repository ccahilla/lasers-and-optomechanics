      RowBox[{"Cos", "[", 
       FractionBox[
        RowBox[{"2", " ", "f", " ", "L", " ", "\[Pi]"}], "c"], "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "-", "T1"}], ")"}], " ", 
              RowBox[{"(", 
               RowBox[{"1", "-", "T2"}], ")"}]}]}], ")"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "-", "T2"}], ")"}]}], ")"}]}], "+", 
        RowBox[{"2", " ", 
         SqrtBox[
          RowBox[{"1", "-", "T2"}]], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "T1"}], " ", 
            SqrtBox[
             RowBox[{"1", "-", "T2"}]], " ", 
            RowBox[{"Cos", "[", 
             FractionBox[
              RowBox[{"4", " ", "f", " ", "L", " ", "\[Pi]"}], "c"], "]"}]}], 
           "-", 
           RowBox[{
            SqrtBox[
             RowBox[{"1", "-", "T1"}]], " ", "T2", " ", 
            RowBox[{"Cos", "[", 
             RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], ")"}]}]}], ")"}], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"2", " ", "\[Phi]"}], "]"}]}], 
     RowBox[{"\[Lambda]", " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "T1"}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{"1", "-", "T2"}], ")"}]}], "-", 
