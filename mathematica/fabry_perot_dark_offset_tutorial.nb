         RowBox[{"(", 
          RowBox[{"1", "-", "T2"}], ")"}]}], "-", 
        RowBox[{"2", " ", 
         SqrtBox[
          RowBox[{"1", "-", "T1"}]], " ", 
         SqrtBox[
          RowBox[{"1", "-", "T2"}]], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", " ", "\[Phi]"}], "]"}]}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "T1"}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{"1", "-", "T2"}], ")"}]}], "-", 
        RowBox[{"2", " ", 
         SqrtBox[
          RowBox[{"1", "-", "T1"}]], " ", 
         SqrtBox[
          RowBox[{"1", "-", "T2"}]], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             FractionBox[
              RowBox[{"2", " ", "f", " ", "L", " ", "\[Pi]"}], "c"], "+", 
             "\[Phi]"}], ")"}]}], "]"}]}]}], ")"}]}]], "-", 
    FractionBox[
     RowBox[{"4", " ", "\[ImaginaryI]", " ", "\[Pi]", " ", 
      SqrtBox[
       RowBox[{"1", "-", "T1"}]], " ", "T1", " ", 
      SqrtBox[
       RowBox[{"1", "-", "T2"}]], " ", "\[CapitalDelta]x", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "+", 
             RowBox[{
              RowBox[{"(", 
