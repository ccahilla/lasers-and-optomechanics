Cell["\<\
So we retrieve half the 1\[Omega] power signal in I, and nothing in the Q \
quadrature.  \[LineSeparator]Forming the length to reflected power transfer \
function at \[Omega] is as simple as dividing by \[CapitalDelta]x, as we did \
in the final step.\[LineSeparator]
This can be seen by analyzing Prefl1\[Omega] above.  \[LineSeparator]It has \
only a Cos[\[Omega] t] term, which indicates which quadrature we\
\[CloseCurlyQuote]ll find our signal in (the I-quadrature).\
\>", "Text",
 CellChangeTimes->{{3.982525497168885*^9, 3.982525551505427*^9}, {
  3.982526397089464*^9, 3.982526458411153*^9}, {3.982526512682743*^9, 
  3.982526541966798*^9}, {3.982526957885188*^9, 
  3.9825270163493977`*^9}},ExpressionUUID->"e932ac6c-0974-4c9d-ac15-\
366cc0bb0e3d"],

Cell[TextData[{
 "Again, by being a bit clever we can simplify our calculations.\nStarting \
again with the generalized term:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", 
      RowBox[{"refl", ",", 
       RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}], "=", 
    RowBox[{"2", "k", " ", "\[CapitalDelta]x", " ", 
     RowBox[{"Re", "(", "z", ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3c9a1f83-b602-4fb2-bff1-cfbc974078b2"],
 "\nwith ",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", 
    RowBox[{
     SuperscriptBox["e", 
      RowBox[{"i", " ", "\[Omega]", " ", "t"}]], "(", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        SubscriptBox["E", 
         RowBox[{"refl", ",", "0"}]], "*"], 
       SubscriptBox["E", 
        RowBox[{"refl", ",", "usb"}]]}], "+", 
      RowBox[{
       SubscriptBox["E", 
        RowBox[{"refl", ",", "0"}]], 
       SuperscriptBox[
        SubscriptBox["E", 
         RowBox[{"refl", ",", "lsb"}]], "*"]}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"33863f36-aa45-4982-b0ae-6be47c2b6808"],
 "\n\nWe can try to directly demodulate this expression.\[LineSeparator]\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", 
     RowBox[{"refl", ",", "I"}]], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"2", "\[Pi]"}]], 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["\[Integral]", "0"], 
       RowBox[{"2", "\[Pi]"}]], 
      RowBox[{
       RowBox[{
        SubscriptBox["P", 
         RowBox[{"refl", ",", 
          RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}], 
       RowBox[{"cos", "(", "\[Omega]t", ")"}], 
       RowBox[{"d", "(", "\[Omega]t", ")"}]}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bdb1ea05-49e6-4ccf-9b69-cbd990c7ad3a"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", 
     RowBox[{"refl", ",", "Q"}]], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"2", "\[Pi]"}]], 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["\[Integral]", "0"], 
       RowBox[{"2", "\[Pi]"}]], 
      RowBox[{
       RowBox[{
        SubscriptBox["P", 
         RowBox[{"refl", ",", 
          RowBox[{"1", "\[Omega]"}]}]], "(", "t", ")"}], 
       RowBox[{"sin", "(", "\[Omega]t", ")"}], 
       RowBox[{"d", "(", "\[Omega]t", ")"}]}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f806ff27-756a-4389-911d-64649865df6c"],
 "\n\nIf I set z = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", " ", 
    SuperscriptBox["e", 
     RowBox[{"i", " ", "\[Omega]", " ", "t"}]]}], TraditionalForm]],
  ExpressionUUID->"f927b751-0ee3-41ad-8919-a17c22d9eda5"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       SubscriptBox["E", 
        RowBox[{"refl", ",", "0"}]], "*"], 
      SubscriptBox["E", 
       RowBox[{"refl", ",", "usb"}]]}], "+", 
     RowBox[{
      SubscriptBox["E", 
       RowBox[{"refl", ",", "0"}]], 
      SuperscriptBox[
       SubscriptBox["E", 
        RowBox[{"refl", ",", "lsb"}]], "*"]}]}]}], TraditionalForm]],
  ExpressionUUID->"9b2bcff6-c00f-4f12-9429-110bb957bf6a"],
 ", \[LineSeparator]then it becomes exquisitely clear what we are measuring \
when we do the demodulation"
}], "Text",
 CellChangeTimes->{{3.982526549258389*^9, 3.9825265703683863`*^9}, {
   3.982526603585409*^9, 3.982526646564158*^9}, {3.9825266856010103`*^9, 
   3.982526712171588*^9}, {3.982526746688836*^9, 3.982526936676148*^9}, {
   3.982527022111011*^9, 3.982527058170416*^9}, {3.9825270977066193`*^9, 
   3.9825271135562267`*^9}, 
   3.9825271894803343`*^9},ExpressionUUID->"b834b116-abfc-4b96-aa9f-\
c508f126f451"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"II", "=", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"2", "\[Pi]"}]], 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"ComplexExpand", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Re", "[", 
         RowBox[{"y", " ", 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Omega]t"}], "]"}]}], "]"}], 
        RowBox[{"Cos", "[", "\[Omega]t", "]"}]}], ",", "y"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Omega]t", ",", "0", ",", 
       RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"QQ", "=", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"2", "\[Pi]"}]], 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"ComplexExpand", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Re", "[", 
         RowBox[{"y", " ", 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "\[Omega]t"}], "]"}]}], "]"}], 
        RowBox[{"Sin", "[", "\[Omega]t", "]"}]}], ",", "y"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Omega]t", ",", "0", ",", 
       RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"II", " ", "+", " ", 
  RowBox[{"I", " ", "QQ"}]}], "\[IndentingNewLine]", 
 RowBox[{"TF", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"II", " ", "+", " ", 
    RowBox[{"I", " ", "QQ"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.982523882269561*^9, 3.982523944636977*^9}, {
  3.982523997958528*^9, 3.982523998092758*^9}, {3.982524098604856*^9, 
  3.982524130932255*^9}, {3.982525314404456*^9, 3.9825253146607637`*^9}, {
  3.982526074414508*^9, 3.982526079357851*^9}, {3.982526920006467*^9, 
  3.982526925305038*^9}, {3.9825270257838793`*^9, 3.982527034777802*^9}, {
  3.982527152660736*^9, 3.982527157718183*^9}, {3.982527274631073*^9, 
  3.982527275932782*^9}},
 CellLabel->
  "In[118]:=",ExpressionUUID->"53d750cf-90d6-4c45-b000-3d4979faeafa"],

Cell[BoxData[
 FractionBox[
  RowBox[{"Re", "[", "y", "]"}], "2"]], "Output",
 CellChangeTimes->{{3.982527147756678*^9, 3.982527158092754*^9}, 
   3.982527276377234*^9, 3.982773141747319*^9, 3.987006940437406*^9},
 CellLabel->
  "Out[118]=",ExpressionUUID->"9edc05ef-d348-4c89-8883-566758a7bc31"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"Im", "[", "y", "]"}], "2"]}]], "Output",
 CellChangeTimes->{{3.982527147756678*^9, 3.982527158092754*^9}, 
   3.982527276377234*^9, 3.982773141747319*^9, 3.9870069404439774`*^9},
 CellLabel->
  "Out[119]=",ExpressionUUID->"bc0728aa-8808-47f8-8fe8-78f182247d76"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    FractionBox["1", "2"]}], " ", "\[ImaginaryI]", " ", 
   RowBox[{"Im", "[", "y", "]"}]}], "+", 
  FractionBox[
   RowBox[{"Re", "[", "y", "]"}], "2"]}]], "Output",
 CellChangeTimes->{{3.982527147756678*^9, 3.982527158092754*^9}, 
   3.982527276377234*^9, 3.982773141747319*^9, 3.987006940446227*^9},
 CellLabel->
  "Out[120]=",ExpressionUUID->"925799a0-956f-4827-934d-68e9e0ea86cf"],

Cell[BoxData[
 FractionBox[
  RowBox[{"Conjugate", "[", "y", "]"}], "2"]], "Output",
 CellChangeTimes->{{3.982527147756678*^9, 3.982527158092754*^9}, 
   3.982527276377234*^9, 3.982773141747319*^9, 3.987006940448024*^9},
 CellLabel->
  "Out[121]=",ExpressionUUID->"da5b3e12-524b-4ee7-aa10-bee794ea149b"]
}, Open  ]],

Cell[TextData[{
 "By using modulating the end mirror with a length change \[CapitalDelta]x \
cos(\[Omega] t), \[LineSeparator]and then demodulating at that same frequency \
\[Omega], \[LineSeparator]we are picking off a product of our electric fields \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       SubscriptBox["E", 
        RowBox[{"refl", ",", "0"}]], "*"], 
      SubscriptBox["E", 
       RowBox[{"refl", ",", "usb"}]]}], "+", 
     RowBox[{
      SubscriptBox["E", 
       RowBox[{"refl", ",", "0"}]], 
      SuperscriptBox[
       SubscriptBox["E", 
        RowBox[{"refl", ",", "lsb"}]], "*"]}]}]}], TraditionalForm]],
  ExpressionUUID->"010e6586-739b-41fd-8cac-3166647fef01"],
 ".\n\nWhat\[CloseCurlyQuote]s more, that product of electric fields is \
incredibly useful for our ultimate goal: maintaining resonance by detecting \
the phase of light via a power signal.\nEssentially, encoded into the power \
signal ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "refl"], "(", "t", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b1a3ce83-6d04-4133-a5cc-9b37213e1112"],
 " at the frequency \[Omega] is our phase signal from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "refl"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c3dc8a6f-c5d5-4658-815c-052db13b1c6a"],
 ", which can be used to hold onto resonance."
}], "Text",
 CellChangeTimes->{{3.982527287186277*^9, 3.9825273374943027`*^9}, {
  3.982527392136325*^9, 3.9825275631699142`*^9}, {3.982527593862792*^9, 
  3.9825277393837023`*^9}, {3.982527917925061*^9, 3.982527928164356*^9}, {
  3.9825279591673393`*^9, 3.982528029533428*^9}, {3.9825281211884623`*^9, 
  3.982528133600423*^9}, {3.982528844836227*^9, 3.9825288471496897`*^9}, {
  3.982530509016079*^9, 3.9825305287904*^9}, {3.982530857246682*^9, 
  3.982530864611556*^9}},ExpressionUUID->"81d6e082-675f-43cb-a92b-\
839ff03e004b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Plot of Dither Locking Phase Sweep", "Subsubsection",
 CellChangeTimes->{{3.982530533670349*^9, 3.982530543822233*^9}, {
  3.9826054791894703`*^9, 
  3.982605482897873*^9}},ExpressionUUID->"ccc66997-7c2b-48c7-bf16-\
2f88a80c8877"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s plot a phase sweep of our demodulated cavity length \
to reflected power transfer function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["P", "refl"], "\[CapitalDelta]x"], 
    RowBox[{"(", 
     RowBox[{"\[Omega]", ",", "\[Phi]"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c4f7be2b-929d-463b-b0e3-e32176d0233d"],
 " \[LineSeparator]for some low frequency signal, say \[Omega] = 2\[Pi] (100 \
Hz) for some cavity length L = 1 meter.\[LineSeparator]We\[CloseCurlyQuote]ll \
assume some moderate finesse cavity, with equal transmissions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", "1"], "=", 
    RowBox[{
     SubscriptBox["T", "2"], "=", "0.3"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "82f2281d-3b6e-41a6-91db-8f701c9f2af4"],
 "."
}], "Text",
 CellChangeTimes->{
  3.9825305177474127`*^9},ExpressionUUID->"97773572-e4c8-4c45-8191-\
4a065adf7699"],

Cell["Parameters for substitution into our function", "Text",
 CellChangeTimes->{{3.982530522112238*^9, 
  3.982530523985878*^9}},ExpressionUUID->"8e972dd1-0629-4a05-bbe4-\
b43d1f67e79d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"E0", "->", "1"}], ",", 
     RowBox[{"k", "->", 
      FractionBox[
       RowBox[{"2", "\[Pi]"}], "\[Lambda]"]}], ",", 
     RowBox[{"\[Omega]", "->", 
      RowBox[{"2", "\[Pi]", " ", "f"}]}], ",", 
     RowBox[{"\[Eta]", "->", 
      FractionBox[
       RowBox[{"\[Omega]", " ", "L"}], "c"]}], ",", 
     RowBox[{"r1", "->", 
      SqrtBox[
       RowBox[{"1", "-", "T1"}]]}], ",", 
     RowBox[{"r2", "->", 
      SqrtBox[
       RowBox[{"1", "-", "T2"}]]}], ",", 
     RowBox[{"t1", "->", 
      SqrtBox["T1"]}], ",", 
     RowBox[{"t2", "->", 
      SqrtBox["T2"]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"values", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Lambda]", "->", 
      RowBox[{"1064", " ", 
       SuperscriptBox["10", 
        RowBox[{"-", "9"}]]}]}], ",", 
     RowBox[{"T1", "->", "0.3"}], ",", 
     RowBox[{"T2", "->", "0.3"}], ",", 
     RowBox[{"L", "->", "1"}], ",", 
     RowBox[{"c", "->", 
      RowBox[{"3", " ", 
       SuperscriptBox["10", "8"]}]}], ",", 
     RowBox[{"f", "->", "10000"}]}], "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9825277423665667`*^9, 3.982527934343705*^9}, {
  3.982528032861581*^9, 3.9825281135760937`*^9}, {3.982528146564589*^9, 
  3.982528203872945*^9}, {3.982528240757482*^9, 3.982528319111953*^9}, {
