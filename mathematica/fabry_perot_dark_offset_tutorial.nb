Cell[CellGroupData[{

Cell["4. Can you use reflected power to restore resonance?", "Subsubsection",
 CellChangeTimes->{{3.982508209820281*^9, 
  3.982508214310892*^9}},ExpressionUUID->"11d16709-f61e-4c34-8b90-\
c6cde7a818f9"],

Cell["\<\
You would run into the same problems as for the transmitted power.\
\>", "Text",
 CellChangeTimes->{{3.982508218856661*^9, 
  3.982508236547183*^9}},ExpressionUUID->"082ee7c5-c5d0-49e3-9676-\
2b07ecb761b1"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Part C: The Reflected Field", "Section",
 CellChangeTimes->{{3.982507825656519*^9, 
  3.982507836238364*^9}},ExpressionUUID->"d6211b8e-2019-434b-99d2-\
a58e8299f0b9"],

Cell[CellGroupData[{

Cell[TextData[{
 "1. Derive an expression for the change in reflected field with respect to \
phase \[Phi]: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["dE", "refl"], "d\[Phi]"], 
    RowBox[{"(", "\[Phi]", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2d45b445-b96a-4310-ace8-bea973163ab9"],
 "."
}], "Subsubsection",
 CellChangeTimes->{{3.982508270981921*^9, 3.9825082997441*^9}, {
  3.982508363991267*^9, 
  3.982508364860341*^9}},ExpressionUUID->"6dec7fcc-d7d1-466c-84c6-\
039cec4dbeb6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"D", "[", 
  RowBox[{"Erefl0", ",", "\[Phi]"}], "]"}]], "Input",
 CellChangeTimes->{{3.982492282589322*^9, 3.982492286617146*^9}},
 CellLabel->"In[90]:=",ExpressionUUID->"14c3618c-9974-4c6d-8d3c-efac9ce2a505"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox[
    RowBox[{"2", " ", "\[ImaginaryI]", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", "r1", 
     " ", "r2", " ", 
     RowBox[{"(", 
      RowBox[{"r1", "-", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
        "r2"}]}], ")"}]}], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
        "r1", " ", "r2"}]}], ")"}], "2"]]}], "+", 
  FractionBox[
   RowBox[{"2", " ", "\[ImaginaryI]", " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", "r2"}], 
   RowBox[{"1", "-", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", "r1", 
     " ", "r2"}]}]]}]], "Output",
 CellChangeTimes->{3.982492289319544*^9, 3.982773135499117*^9, 
  3.987006904986641*^9},
 CellLabel->"Out[90]=",ExpressionUUID->"83c342b9-c891-4237-9de3-d7a14ff0d444"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dErefl0d\[Phi]", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"D", "[", 
    RowBox[{"Erefl0", ",", "\[Phi]"}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.982492292794367*^9, 3.98249229480882*^9}, {
  3.982492762946623*^9, 3.982492765267963*^9}},
 CellLabel->"In[91]:=",ExpressionUUID->"4668a8f7-e9a7-4aac-a7f2-14f830ebe4c5"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"2", " ", "\[ImaginaryI]", " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SuperscriptBox["r1", "2"]}], ")"}], " ", "r2"}], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]"}]], "-", 
      RowBox[{"r1", " ", "r2"}]}], ")"}], "2"]]}]], "Output",
 CellChangeTimes->{3.982492295129087*^9, 3.98249276598418*^9, 
  3.982773135520152*^9, 3.987006905004609*^9},
 CellLabel->"Out[91]=",ExpressionUUID->"d2c0c73b-fcaf-4577-9b89-f6fa6a5bd23e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "2. Set ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["r", "2"], "=", 
    RowBox[{
     SubscriptBox["r", "1"], "=", "r"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4e0a0afd-dab6-4dbd-bbc4-28c9cf5cb3a9"],
 ".  What is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "refl"], "(", "0", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "71ad8608-1b85-47f9-b985-0b672f4837b2"],
 "?  What is ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["dE", "refl"], "d\[Phi]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "40e59265-af20-4a65-adb0-5328594e7b71"],
 "(0)?"
}], "Subsubsection",
 CellChangeTimes->{{3.982508324292622*^9, 
  3.982508360450441*^9}},ExpressionUUID->"a1205bd9-bab1-4b20-8dd5-\
bf2328700f1a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{"Erefl0", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r2", "->", "r"}], ",", 
     RowBox[{"r1", "->", "r"}], ",", 
     RowBox[{"\[Phi]", "->", "0"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9825083994406767`*^9, 3.9825084275427923`*^9}},
 CellLabel->"In[92]:=",ExpressionUUID->"b189fd9d-fa9f-4adc-92d5-9ea1c6c13f35"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{{3.982508411019299*^9, 3.9825084278972397`*^9}, 
   3.982773135596025*^9, 3.9870069050086308`*^9},
 CellLabel->"Out[92]=",ExpressionUUID->"7af4cffd-585f-4a70-ae12-70bd3f01cfdc"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{"dErefl0d\[Phi]", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r2", "->", "r"}], ",", 
     RowBox[{"r1", "->", "r"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.982493292875346*^9, 3.982493301457295*^9}, {
  3.982508370189446*^9, 3.982508378370069*^9}},
 CellLabel->"In[93]:=",ExpressionUUID->"956f79ae-49e7-4d42-805d-8f11323a12a5"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"2", " ", "\[ImaginaryI]", " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", "r", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SuperscriptBox["r", "2"]}], ")"}]}], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]"}]], "-", 
      SuperscriptBox["r", "2"]}], ")"}], "2"]]}]], "Output",
 CellChangeTimes->{{3.982493296607263*^9, 3.982493301732922*^9}, 
   3.9825083791008043`*^9, 3.982773135626292*^9, 3.987006905027574*^9},
 CellLabel->"Out[93]=",ExpressionUUID->"0d91932f-ad0f-4a1a-b304-de41fa1c0f3e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{"dErefl0d\[Phi]", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r2", "->", "r"}], ",", 
     RowBox[{"r1", "->", "r"}], ",", 
     RowBox[{"\[Phi]", "->", "0"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9824933304287148`*^9, 3.982493334882625*^9}, 
   3.982508462920656*^9},
 CellLabel->"In[94]:=",ExpressionUUID->"09cfa9ba-1858-4cae-849c-dcf274a8128e"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"2", " ", "\[ImaginaryI]", " ", "r"}], 
   RowBox[{
    RowBox[{"-", "1"}], "+", 
    SuperscriptBox["r", "2"]}]]}]], "Output",
 CellChangeTimes->{3.982493335371726*^9, 3.9825084639910316`*^9, 
  3.9827731356553373`*^9, 3.987006905031743*^9},
 CellLabel->"Out[94]=",ExpressionUUID->"35416744-f38d-4964-8b0a-fa0e87c40ed1"]
}, Open  ]],

Cell[TextData[{
 "Again, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["E", "refl"], "(", "0", ")"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cffceb6d-552c-4013-b672-796820776640"],
 ", but ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["dE", "refl"], "d\[Phi]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "65b701c8-6c65-4c63-890c-94def0738302"],
 "(0) = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"2", " ", "i", " ", "r"}], 
    RowBox[{"1", "-", 
     SuperscriptBox["r", "2"]}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d5e93301-84f8-4b03-9868-3c4455a5c4db"],
 ".  \[LineSeparator]So we have ",
 StyleBox["no",
  FontSlant->"Italic"],
 " reflected field returning in reflection exactly at resonance, but the \
field is moving rapidly in the imaginary direction at resonance.  "
}], "Text",
 CellChangeTimes->{{3.982508436221389*^9, 3.982508561803499*^9}, {
  3.982508595496765*^9, 
  3.982508694780551*^9}},ExpressionUUID->"3180fa1d-df00-40e9-b632-\
1e9decd9bbb6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
3. What happens to the reflected field when the cavity gets longer? What \
about shorter?\
\>", "Subsubsection",
 CellChangeTimes->{{3.9825087005070343`*^9, 
  3.982508710360592*^9}},ExpressionUUID->"2ebfece4-d91f-4069-8a01-\
33084de5bf8f"],

Cell[TextData[{
 "If we think about a field Taylor expansion about resonance, to first order \
we get \[LineSeparator]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["E", "refl"], "(", "\[Phi]", ")"}], 
     SubscriptBox["|", 
      RowBox[{"\[Phi]", "\[Rule]", "0"}]]}], " ", "=", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["E", "refl"], "(", "0", ")"}], "+", 
      RowBox[{"\[Phi]", " ", 
       FractionBox[
        SubscriptBox["dE", "refl"], "d\[Phi]"], 
       RowBox[{"(", "0", ")"}]}]}], " ", "=", " ", 
     RowBox[{"\[Phi]", 
      FormBox[
       FractionBox[
        RowBox[{"2", " ", "i", " ", "r"}], 
        RowBox[{"1", "-", 
         SuperscriptBox["r", "2"]}]],
       TraditionalForm]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "60bd8e3e-75a3-4c4b-b2e1-41100fd1f6a2"],
 ".\nThis means that the field is becomes positive imaginary when the cavity \
gets longer (\[Phi] > 0),\[LineSeparator]but becomes negative imaginary when \
the cavity gets shorter (\[Phi] < 0).\nSo we\[CloseCurlyQuote]ve finally \
recovered something which changes linearly with phase."
}], "Text",
 CellChangeTimes->{{3.982508726066682*^9, 3.982509020623804*^9}, {
  3.98250986641595*^9, 
  3.982509880350893*^9}},ExpressionUUID->"a6f3e7d6-a1b3-4446-b862-\
4b2cb16ed97e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
4. Could you use the reflected field to restore resonance?  What would you \
need in order to do so?\
\>", "Subsubsection",
 CellChangeTimes->{{3.982509029603201*^9, 
  3.982509033833461*^9}},ExpressionUUID->"4ab0de99-36a8-499a-ad2d-\
8f28b58afff7"],

Cell[TextData[{
 "We can\[CloseCurlyQuote]t measure the reflected electric field directly \
unfortunately.  \[LineSeparator]When we tried to measure the power, we got \
something that scaled like ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Phi]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3bf4d940-1452-4cd0-9b75-62367b6457d5"],
 ", which wasn\[CloseCurlyQuote]t that useful.\n\nWe would need a ",
 StyleBox["local oscillator",
  FontSlant->"Italic"],
 " to measure ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "refl"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "72be5e43-b011-4358-846f-545fb8c149d8"],
 " directly.\nA local oscillator is just a reference electric field that \
interferes with our signal field.  \nWe will explore one option for creating \
a local oscillator below."
}], "Text",
 CellChangeTimes->{{3.9825090374594707`*^9, 3.9825092253480377`*^9}, 
   3.982509887811783*^9},ExpressionUUID->"920790ea-6bc9-4f47-a880-\
e658e96a7b63"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Abs", "[", 
    RowBox[{"Erefl0", "//.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"r2", "->", "r1"}], ",", 
       RowBox[{"r1", "->", 
        SqrtBox[
         RowBox[{"1", "-", "0.3"}]]}]}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Phi]", ",", 
     RowBox[{"-", 
      FractionBox["\[Pi]", "2"]}], ",", 
     FractionBox["\[Pi]", "2"]}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "Full"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<Phase \[Phi]\>\"", ",", 
      "\"\<|\!\(\*SubscriptBox[\(E\), \(refl\)]\)|\>\""}], "}"}]}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    FractionBox["180", "\[Pi]"], 
    RowBox[{"Arg", "[", 
     RowBox[{"Erefl0", "//.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"r2", "->", "r1"}], ",", 
        RowBox[{"r1", "->", 
         SqrtBox[
          RowBox[{"1", "-", "0.3"}]]}]}], "}"}]}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Phi]", ",", 
     RowBox[{"-", 
      FractionBox["\[Pi]", "2"]}], ",", 
     FractionBox["\[Pi]", "2"]}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "Full"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<Phase \[Phi]\>\"", ",", 
      "\"\<\!\(\*SubscriptBox[\(\[Angle]E\), \(refl\)]\)\>\""}], "}"}]}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.9825154850610456`*^9, 3.982515634705854*^9}, {
  3.982529134825034*^9, 3.982529145333682*^9}},
 CellLabel->"In[95]:=",ExpressionUUID->"566a1599-0caa-4e85-a7ac-1089c231a1a5"],

