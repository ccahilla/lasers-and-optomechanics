       RowBox[{
        RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", 
        RowBox[{"(", 
         RowBox[{"\[Eta]", "+", "\[Phi]"}], ")"}]}]], " ", "r1", " ", 
      "r2"}]}], ")"}]}]]], "Output",
 CellChangeTimes->{
  3.982515248317088*^9, 3.982515934745063*^9, {3.982519156536654*^9, 
   3.9825191671978483`*^9}, 3.982524290961924*^9},
 CellLabel->
  "Out[173]=",ExpressionUUID->"52e7211a-c647-486a-81b2-843adfe906a0"],

Cell[BoxData[
 FractionBox[
  RowBox[{"\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Phi]"}], "-", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{"\[Eta]", "+", "\[Phi]"}], ")"}]}], "-", 
     RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[Omega]"}]}]], " ", "k", " ", 
