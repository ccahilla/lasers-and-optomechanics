Cell[CellGroupData[{

Cell["Part 4. Dither Locking", "Section",
 CellChangeTimes->{{3.98250501486418*^9, 3.982505018085394*^9}, {
  3.982509893005476*^9, 
  3.982509894998081*^9}},ExpressionUUID->"a5220b4c-a1f3-4e1d-aec5-\
352ccfc34ed4"],

Cell[CellGroupData[{

Cell[TextData[{
 "1. First, find the transfer function from the end mirror ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "cav2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3344802f-80e9-431b-af47-825c7b38957b"],
 " to the reflected field ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "refl"], TraditionalForm]],ExpressionUUID->
  "ad331f9e-92eb-4631-92c2-a6c96ce0d190"],
 "."
}], "Subsubsection",
 CellChangeTimes->{{3.982510608990617*^9, 3.9825106328469553`*^9}, 
   3.982519220171554*^9},ExpressionUUID->"fb76155b-3a76-4013-b6ec-\
fb7b128bfd44"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "refl"], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["r", "1"], 
      SubscriptBox["E", "in"]}], "+", 
     RowBox[{
      SubscriptBox["t", "1"], 
      SuperscriptBox["e", 
       RowBox[{
        RowBox[{"-", "i"}], " ", "\[Phi]"}]], 
      SubscriptBox["E", "cav2"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "48d55342-dfb9-48f4-9bd6-7d17a72baacb"],
 ", but we are only focused on the contribution to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "refl"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "93ea820c-dd65-44b0-8c5f-12ad53a094dd"],
 " from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "cav2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2e978d33-1106-4e4c-81bd-f64bfa609ea2"],
 ", so we set ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", 
     RowBox[{"in", " "}]], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "87a9f538-a9f5-43f8-93fd-aee782986d8b"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["E", "refl"], 
     SubscriptBox["E", "cav2"]], "=", 
    RowBox[{
     SubscriptBox["t", "1"], 
     SuperscriptBox["e", 
      RowBox[{
       RowBox[{"-", "i"}], " ", "\[Phi]"}]], 
     FractionBox[
      SubscriptBox["E", "cav2"], 
      SubscriptBox["E", "cav2"]]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7fb7c533-205d-4dea-af8e-d59eb7ac00b8"],
 "\n\nRemember that ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["E", "cav2"], 
    SubscriptBox["E", "cav2"]], TraditionalForm]],ExpressionUUID->
  "fac52f6f-768e-4314-a772-4cd0cd076af0"],
 "= ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    RowBox[{"1", "-", 
     RowBox[{
      SubscriptBox["r", 
       RowBox[{"1", " "}]], 
      SubscriptBox["r", "2"], 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "i"}], " ", "2", " ", "\[Phi]"}], "]"}]}]}]], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4fd1f39a-d4dc-4d15-aa87-124441820002"],
 " is the cavity loop suppression: ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "cav2"], TraditionalForm]],ExpressionUUID->
  "30cb672c-e500-4923-a2c2-9f516bd32048"],
 " has to go around the loop to get back to itself.\[LineSeparator]This \
yields our final answer:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["E", "refl"], 
     SubscriptBox["E", "cav2"]], "=", 
    FractionBox[
     RowBox[{
      SubscriptBox["t", "1"], " ", 
      SuperscriptBox["e", 
       RowBox[{
        RowBox[{"-", "i"}], " ", "\[Phi]"}]]}], 
     RowBox[{"1", "-", 
      RowBox[{
       SubscriptBox["r", "1"], 
       SubscriptBox["r", "2"], 
       SuperscriptBox["e", 
        RowBox[{
         RowBox[{"-", "i"}], " ", "2", "\[Phi]"}]]}]}]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "87b39928-6c61-4273-8af3-6b6db7b967aa"]
}], "Text",
 CellChangeTimes->{{3.9825106450530577`*^9, 3.982510657383706*^9}, {
  3.982510707309876*^9, 3.982510729631048*^9}, {3.982511291989592*^9, 
  3.982511369910548*^9}, {3.982511407865151*^9, 3.982511449070804*^9}, {
  3.982511480123172*^9, 3.982511600895955*^9}, {3.982511646673462*^9, 
  3.982511695799877*^9}, {3.982511733385607*^9, 3.982511753836603*^9}, {
  3.982512073624711*^9, 3.982512121929266*^9}, {3.982512320395282*^9, 
  3.982512426003272*^9}, {3.982512461542161*^9, 3.982512553806583*^9}, {
  3.982512589862941*^9, 
  3.982512598845808*^9}},ExpressionUUID->"228082b5-5b10-445c-a223-\
2a20a4ca70a1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Ecav2toErefl", "[", "\[Phi]_", "]"}], ":=", 
   FractionBox[
    RowBox[{"t1", " ", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], " ", "\[Phi]"}], "]"}]}], 
    RowBox[{"1", "-", 
     RowBox[{"r1", " ", "r2", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", "2", "\[Phi]"}], "]"}]}]}]]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9825151661132927`*^9, 3.982515196014325*^9}},
 CellLabel->
  "In[125]:=",ExpressionUUID->"0de99c95-0172-43c6-8c10-15b82798dfbc"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Find the carrier field incident on the end mirror.", "Subsubsection",
 CellChangeTimes->{{3.982512633455373*^9, 
  3.982512640480752*^9}},ExpressionUUID->"ad29128d-c1a2-4324-8771-\
c4e7b5fb8d16"],

Cell[TextData[{
 "Incident on the end mirror will be ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["E", "cav"], 
     SubscriptBox["E", "in"]], "=", 
    FractionBox[
     SubscriptBox["t", "1"], 
     RowBox[{"1", "-", 
      RowBox[{
       SubscriptBox["r", "1"], 
       SubscriptBox["r", "2"], 
       SuperscriptBox["e", 
        RowBox[{
         RowBox[{"-", "i"}], " ", "2", "\[Phi]"}]]}]}]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0abfe455-abbe-4e57-99d5-36e0350788b7"],
 "times the propagation to the back mirror ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{
     RowBox[{"-", "i"}], " ", "\[Phi]"}]], TraditionalForm]],ExpressionUUID->
  "2ed420bc-5c82-4f0f-9dc7-6d381766947c"],
 "."
}], "Text",
 CellChangeTimes->{{3.982512650771556*^9, 
  3.982512771394866*^9}},ExpressionUUID->"6118fcd6-c34e-4857-8f60-\
f1c13febcdf1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Ecavend", "=", 
   FractionBox[
    RowBox[{"t1", " ", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], " ", "\[Phi]"}], "]"}]}], 
    RowBox[{"1", "-", 
     RowBox[{"r1", " ", "r2", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", "2", "\[Phi]"}], "]"}]}]}]]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9825127995733232`*^9, 3.9825128335504436`*^9}, {
  3.982514084828236*^9, 3.982514098329319*^9}, {3.982516489123866*^9, 
  3.98251649097616*^9}},
 CellLabel->
  "In[141]:=",ExpressionUUID->"5b7e3477-b0c9-4198-b998-1c7ba64b96e2"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "3. Apply the length modulation \[CapitalDelta]x cos(\[Omega] t) to find the \
total field immediately reflected off the end mirror ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "cav2"], TraditionalForm]],ExpressionUUID->
  "46051a1a-7007-476a-ac72-fd521717e6a2"],
 ".  \[LineSeparator]",
 StyleBox["Hint: There should be three fields.",
  FontSlant->"Italic"]
}], "Subsubsection",
 CellChangeTimes->{{3.982512916353695*^9, 3.982512965453471*^9}, 
   3.9825130466829643`*^9},ExpressionUUID->"75a18416-b821-4c19-9959-\
a45bd04a8543"],

Cell[TextData[{
 "We apply the modulation to the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "cavend"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "18137b6d-c9e7-4f92-aca7-b058d26fcbba"],
 " carrier field\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "cav2"], "=", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"i", " ", "k", " ", "\[CapitalDelta]x", " ", 
       SuperscriptBox["e", 
        RowBox[{"i", " ", "\[Omega]", " ", "t"}]]}], "+", 
      RowBox[{"i", " ", "k", " ", "\[CapitalDelta]x", " ", 
       SuperscriptBox["e", 
        RowBox[{
         RowBox[{"-", "i"}], " ", "\[Omega]", " ", "t"}]]}]}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"d4b193f1-1834-44fa-bfe7-fba2faaf149b"],
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     SubscriptBox["r", "2"], 
     SubscriptBox["E", "cavend"]}]}], TraditionalForm]],ExpressionUUID->
  "9be23ef3-0c95-4876-9b6e-5107646e2226"],
 "\n\nI\[CloseCurlyQuote]ll split the fields explicitly like\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "cav2"], TraditionalForm]],ExpressionUUID->
  "85a5cb12-0d9a-431b-8c74-75449fe11624"],
 " = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", 
     RowBox[{"cav2", ",", "0"}]], "+", 
    SubscriptBox["E", 
     RowBox[{"cav2", ",", "usb"}]], "+", 
    SubscriptBox["E", 
     RowBox[{"cav2", ",", "lsb"}]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b78572d5-fbaa-40cf-9b0e-1b44f8ff18ab"]
}], "Text",
 CellChangeTimes->{{3.982512983412676*^9, 3.9825130886337976`*^9}, {
   3.9825131225962343`*^9, 3.982513210438986*^9}, {3.982513323582225*^9, 
   3.982513323908803*^9}, {3.9825133783470163`*^9, 3.9825133810344887`*^9}, {
   3.9825149194209003`*^9, 3.982514926635927*^9}, 
   3.9825190924274693`*^9},ExpressionUUID->"2f026d1e-4649-4c57-9049-\
87ec44a5fa6b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Ecav20", "=", 
  RowBox[{"r2", " ", "Ecavend"}]}], "\[IndentingNewLine]", 
 RowBox[{"Ecav2usb", "=", 
  RowBox[{
  "I", " ", "k", " ", "\[CapitalDelta]x", " ", "r2", " ", "Ecavend", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{"I", " ", "\[Omega]", " ", "t"}], 
    "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Ecav2lsb", "=", 
  RowBox[{
  "I", " ", "k", " ", "\[CapitalDelta]x", " ", "r2", " ", "Ecavend", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "I"}], " ", "\[Omega]", " ", "t"}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.982513998134894*^9, 3.982514077405099*^9}, {
  3.982514108129991*^9, 3.982514120029718*^9}, {3.9825149090597963`*^9, 
  3.982514913486161*^9}},
 CellLabel->
  "In[169]:=",ExpressionUUID->"fbd394ee-413b-494c-b7fd-98299c1fe54c"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Phi]"}]], " ", "r2", " ", "t1"}], 
  RowBox[{"1", "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", "r1", 
    " ", "r2"}]}]]], "Output",
 CellChangeTimes->{3.9825142589211397`*^9, 3.9825149156348886`*^9, 
  3.982524286270606*^9},
 CellLabel->
  "Out[169]=",ExpressionUUID->"6a5c9911-4d60-4c31-afb3-1bac4695ce45"],

Cell[BoxData[
 FractionBox[
  RowBox[{"\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Phi]"}], "+", 
     RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[Omega]"}]}]], " ", "k", " ", 
   "r2", " ", "t1", " ", "\[CapitalDelta]x"}], 
  RowBox[{"1", "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", "r1", 
    " ", "r2"}]}]]], "Output",
 CellChangeTimes->{3.9825142589211397`*^9, 3.9825149156348886`*^9, 
  3.982524286273121*^9},
 CellLabel->
  "Out[170]=",ExpressionUUID->"8c8785c5-0a15-44c9-bd98-63ed01e14484"],

Cell[BoxData[
 FractionBox[
  RowBox[{"\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Phi]"}], "-", 
     RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[Omega]"}]}]], " ", "k", " ", 
   "r2", " ", "t1", " ", "\[CapitalDelta]x"}], 
  RowBox[{"1", "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", "r1", 
    " ", "r2"}]}]]], "Output",
 CellChangeTimes->{3.9825142589211397`*^9, 3.9825149156348886`*^9, 
  3.982524286276033*^9},
 CellLabel->
  "Out[171]=",ExpressionUUID->"245a70cf-e1e1-4b4d-973c-08551d6c441e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "4. Apply your transfer function from (1) to your ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "cav2"], TraditionalForm]],ExpressionUUID->
  "c95fbf31-5e59-42d7-be65-2a9e4a6e447e"],
 " to find the total reflected field.\[LineSeparator]",
 StyleBox["Hint: It may be easier to consider the accrued phases for carrier \
\[Phi]  and for the audio sidebands \[Phi] \[PlusMinus] \[Eta]",
  FontSlant->"Italic"],
 " "
}], "Subsubsection",
 CellChangeTimes->{{3.982513385387164*^9, 3.982513445354621*^9}, {
  3.9825135016799793`*^9, 
  3.982513515674962*^9}},ExpressionUUID->"ec44d3c3-9f6b-4bbd-912d-\
85a4190bb494"],

Cell[TextData[{
 "First, I clarify what the phases \[Phi] and \[Eta] are.  \[LineSeparator]\n\
\[Phi] = k L = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SubscriptBox["\[Omega]", "0"], "L"}], "c"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6d6a67ff-0b23-44b0-a080-dbe3cebd42df"],
 " is the phase accrued by the carrier as it passes through the cavity.  Here \
",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ac8f5485-2c41-4db0-8326-d76db7b84a29"],
 " is the carrier frequency.\n\n\[Eta] = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[Omega]", " ", "L"}], "c"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "67dba2d1-4c22-4679-b3e4-ced1039ea328"],
 " is the additional phase accrued by the upper sideband (or phase subtracted \
for the lower sideband) as they pass through the cavity.\n\nThe key is, all \
the beams experience the same cavity length L, but have a different \
frequency.  \[LineSeparator]This causes the fields to accrue a different \
phase as they pass through the cavity.\n\nSo, to find the carrier \
contribution to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "refl"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "064ce3fb-e735-49e6-bb1c-a2e98e541160"],
 ", we simply do the usual transfer function ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["E", "refl"], 
    SubscriptBox["E", "in"]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "08fb08c0-a40c-44d0-b636-821bf74fe0e9"],
 " at the same phase \[Phi].\nBut for the upper and lower sideband \
contributions to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "refl"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3bcc3333-262a-48cc-b918-64be740b0f90"],
 ", we need to apply ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["E", "refl"], 
    SubscriptBox["E", "cav2"]], TraditionalForm]],ExpressionUUID->
  "81b2e1fc-a0b8-402e-8c50-2d0cf273b16d"],
 "at \[Phi] ",
 StyleBox["\[PlusMinus]",
  FontSlant->"Italic"],
 " \[Eta] to our carrier TF that got us to the end mirror:\[LineSeparator]\n\
",
 StyleBox["Carrier:",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", 
     RowBox[{"refl", ",", "0"}]], "=", 
    RowBox[{
     FractionBox[
      SubscriptBox["E", "refl"], 
      SubscriptBox["E", "in"]], 
     RowBox[{"(", "\[Phi]", ")"}], 
     SubscriptBox["E", "in"]}]}], TraditionalForm]],ExpressionUUID->
  "75c0e4e6-07f1-4a64-a68e-6d8ccd919f35"],
 "\n",
 StyleBox["Upper Sideband:",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", 
     RowBox[{"refl", ",", "usb"}]], "=", 
    RowBox[{
     FormBox[
      FractionBox[
       SubscriptBox["E", "refl"], 
       SubscriptBox["E", "cav2"]],
      TraditionalForm], 
     RowBox[{"(", 
      RowBox[{"\[Phi]", "+", "\[Eta]"}], ")"}], " ", 
     FractionBox[
      SubscriptBox["E", "cav2"], 
      SubscriptBox["E", "in"]], 
     RowBox[{"(", "\[Phi]", ")"}], 
     SubscriptBox["E", "in"]}]}], TraditionalForm]],ExpressionUUID->
  "658fc6bc-d681-4397-9b69-f31efcac9a00"],
 "\n",
 StyleBox["Lower Sideband:",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", 
     RowBox[{"refl", ",", "lsb"}]], "=", 
    RowBox[{
     FormBox[
      FractionBox[
       SubscriptBox["E", "refl"], 
       SubscriptBox["E", "cav2"]],
      TraditionalForm], 
     RowBox[{"(", 
      RowBox[{"\[Phi]", "-", "\[Eta]"}], ")"}], 
     FractionBox[
      SubscriptBox["E", "cav2"], 
      SubscriptBox["E", "in"]], 
     RowBox[{"(", "\[Phi]", ")"}], " ", 
     SubscriptBox["E", "in"]}]}], TraditionalForm]],ExpressionUUID->
  "4707437f-2a5a-44b4-9363-291f1ad24422"],
 "\[LineSeparator]\nFor the sideband terms, we get a product of the carrier \
resonance experienced in the cavity, building up to high field strength, and \
the sideband term itself, which can also resonant inside the cavity"
}], "Text",
 CellChangeTimes->{{3.982513527340479*^9, 3.982513691910796*^9}, {
  3.982513858345397*^9, 3.982513942730483*^9}, {3.982513980127686*^9, 
  3.9825139942942*^9}, {3.982515019719376*^9, 3.982515130133675*^9}, {
  3.982515237794609*^9, 3.982515292361117*^9}, {3.9825153506255283`*^9, 
  3.982515394299518*^9}, {3.982515435101042*^9, 3.9825154412664413`*^9}, {
  3.98251592482478*^9, 3.982515924865118*^9}, {3.9825159613836603`*^9, 
  3.982516061187924*^9}, {3.9825160944518843`*^9, 3.982516190253419*^9}, {
  3.982516287993552*^9, 
  3.982516333132119*^9}},ExpressionUUID->"54bb7bb4-6771-4c95-a222-\
3d790822d7e0"],

Cell[CellGroupData[{

