Cell[CellGroupData[{

Cell["Part B: Reflected Power", "Section",
 CellChangeTimes->{{3.982506109010335*^9, 3.9825061113019133`*^9}, {
  3.9825072922620897`*^9, 
  3.982507295215106*^9}},ExpressionUUID->"1d36cedb-86e9-4dc0-989e-\
8f9c387c127e"],

Cell[CellGroupData[{

Cell["Define the REFL electric field", "Subsubsection",
 CellChangeTimes->{{3.9824885788399687`*^9, 3.9824885796481237`*^9}, {
  3.982507303292588*^9, 
  3.982507309626494*^9}},ExpressionUUID->"2d0ac1c2-9b8d-48da-9cb9-\
be54aca16687"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Erefl", "[", 
    RowBox[{"\[Phi]_", ",", 
     RowBox[{"t1_", ":", "0.3"}], ",", 
     RowBox[{"t2_", ":", "0.3"}], ",", 
     RowBox[{"r1_", ":", 
      SqrtBox[
       RowBox[{"1", "-", 
        SuperscriptBox["0.3", "2"]}]]}], ",", 
     RowBox[{"r2_", ":", 
      SqrtBox[
       RowBox[{"1", "-", 
        SuperscriptBox["0.3", "2"]}]]}]}], "]"}], ":=", 
   FractionBox[
    RowBox[{"r1", "-", 
     RowBox[{"r2", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", "2", " ", "\[Phi]"}], "]"}]}]}], 
    RowBox[{"1", "-", 
     RowBox[{"r1", " ", "r2", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", "2", " ", "\[Phi]"}], "]"}]}]}]]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.98248858224863*^9, 3.982488603086307*^9}},
 CellLabel->"In[82]:=",ExpressionUUID->"b33eb2bb-1df5-41c1-95ef-1e04a0a27fde"],

