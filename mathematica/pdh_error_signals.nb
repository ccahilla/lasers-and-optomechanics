Notebook[{

Cell[CellGroupData[{
Cell["Pound-Drever-Hall Error Signal Derivation ", "Title",
 CellChangeTimes->{{3.982833395883298*^9, 
  3.98283341239679*^9}},ExpressionUUID->"d62f63b1-85ed-42d5-a455-\
adc2b80b77ba"],

Cell["\<\
Derivation of PDH error signal, following March 18, 2026 tutorial here:\
\[LineSeparator]https://ccahilla.github.io/lasers-and-optomechanics/tutorials/\
\>", "Subtitle",
 CellChangeTimes->{{3.982833419845052*^9, 
  3.982833452421093*^9}},ExpressionUUID->"5d5e484d-50dc-4b65-86e1-\
7b690add1d35"],

Cell[CellGroupData[{

Cell["0. Fabry Perot cavity reflection as a function of phase", \
"Subsubsection",
 CellChangeTimes->{{3.982837604258731*^9, 
  3.982837617284155*^9}},ExpressionUUID->"852652d0-c2a6-41df-b533-\
824c340aef4e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"refl", "[", "\[Phi]_", "]"}], ":=", 
   FractionBox[
    RowBox[{"r1", "-", 
     RowBox[{"r2", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", "2", "\[Phi]"}], "]"}]}]}], 
    RowBox[{"1", "-", 
     RowBox[{"r1", " ", "r2", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", "2", "\[Phi]"}], "]"}]}]}]]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.982837565578486*^9, 3.9828375989795313`*^9}},
 CellLabel->"In[89]:=",ExpressionUUID->"10353094-bee5-4aa4-98c3-86a45e67f459"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
1. What is the total electric field incident on the front of the cavity?\
\>", "Subsubsection",
 CellChangeTimes->{
  3.982833467213253*^9},ExpressionUUID->"b70f5c1c-1624-4d73-bfb6-\
993038a24c8e"],

Cell["Carrier input", "Text",
 CellChangeTimes->{{3.982833526169289*^9, 
  3.982833538031684*^9}},ExpressionUUID->"10ba6184-c49f-4801-8a70-\
cf68c7f0be2d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Ein", "=", 
   RowBox[{"E0", " ", 
    RowBox[{"Exp", "[", 
     RowBox[{"I", " ", "\[Omega]0", " ", "t"}], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.982833476778411*^9, 3.982833489809678*^9}},
 CellLabel->"In[87]:=",ExpressionUUID->"a773353b-1f39-4b37-ac37-b809530371d8"],

Cell["Carrier + Upper Sideband + Lower Sideband", "Text",
 CellChangeTimes->{{3.982833544930284*^9, 
  3.982833554539578*^9}},ExpressionUUID->"ea3632ed-3cda-4b0a-a8af-\
52f7f697bd83"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Eintotal", "=", 
  RowBox[{"Ein", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"I", " ", 
      FractionBox["\[CapitalGamma]", "2"], 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "\[CapitalOmega]", " ", "t"}], "]"}]}], "+", 
     RowBox[{"I", " ", 
      FractionBox["\[CapitalGamma]", "2"], 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], " ", "\[CapitalOmega]", " ", "t"}], "]"}]}]}], 
    ")"}]}]}]], "Input",
 CellChangeTimes->{{3.98283347059975*^9, 3.982833518753728*^9}},
 CellLabel->"In[88]:=",ExpressionUUID->"47d60350-5299-4931-97fe-b7c6b7cae32d"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[Omega]0"}]], " ", "E0", " ", 
  RowBox[{"(", 
   RowBox[{"1", "+", 
    RowBox[{
     FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[CapitalOmega]"}]], 
     " ", "\[CapitalGamma]"}], "+", 
    RowBox[{
     FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]], " ", 
     "\[CapitalGamma]"}]}], ")"}]}]], "Output",
 CellChangeTimes->{3.982833558108829*^9},
 CellLabel->"Out[88]=",ExpressionUUID->"5f72cd17-a143-40eb-bc5e-fcc7538085c2"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
2. Write down three single-pass phases \[Phi]0 , \[Phi]usb , \[Phi]lsb that \
the carrier, upper sideband, and

lower sideband, will experience as they traverse the cavity, in terms of the \
cavity length L,

and carrier and RF frequencies \[Omega]0 and \[CapitalOmega].\
\>", "Subsubsection",
 CellChangeTimes->{
  3.982833568677866*^9},ExpressionUUID->"7227a674-21b3-4a1c-9c7d-\
8cd02b8bc8a7"],

Cell["Where L is the nominal cavity length:", "Text",
 CellChangeTimes->{{3.98283359300987*^9, 
  3.98283360019734*^9}},ExpressionUUID->"a74be9aa-bca3-4662-bc68-\
1d56f4f8c8a3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Phi]0", "->", 
      FractionBox[
       RowBox[{"\[Omega]0", " ", "L"}], "c"]}], ",", 
     RowBox[{"\[Phi]usb", "->", 
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Omega]0", "+", "\[CapitalOmega]"}], ")"}], "L"}], "c"]}], 
     ",", 
     RowBox[{"\[Phi]lsb", "->", 
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Omega]0", "-", "\[CapitalOmega]"}], ")"}], "L"}], 
       "c"]}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.982833577775014*^9, 
  3.982833679463736*^9}},ExpressionUUID->"a0cba18f-9d91-4845-9b2a-\
a0fe6f5a0773"],

Cell[TextData[{
 "I have make this a list of parameters, so we can leave things in terms of \
\[Phi]0,\[Phi]usb,\[Phi]lsb,\nNotice that we can also do another phase \
breakdown where \[LineSeparator]\[LineSeparator]\[Phi]usb = \[Phi]0 + \
\[Phi]rf and \[Phi]lsb = \[Phi]0 - \[Phi]rf\[LineSeparator]where\
\[LineSeparator]\[Phi]rf = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[CapitalOmega]", " ", "L"}], "c"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2c2a4845-384b-4468-bb48-28e466680d09"],
 "."
}], "Text",
 CellChangeTimes->{{3.982837550050012*^9, 3.9828375610111322`*^9}, {
  3.9828376383054657`*^9, 3.9828376426160183`*^9}, {3.9828378266066847`*^9, 
  3.9828378950697613`*^9}},ExpressionUUID->"76a8404a-0373-47e1-8721-\
e0d89712b94e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
3. Write down the cavity total reflected field Erefl in terms of the \
reflection function r(\[Phi]) and

\[Phi]0 , \[Phi]usb , \[Phi]lsb \
\>", "Subsubsection",
 CellChangeTimes->{{3.982837645146154*^9, 
  3.982837659014502*^9}},ExpressionUUID->"665acea5-9f02-4725-b353-\
11171f0695a1"],

Cell["\<\
r0 is the reflected carrier refl[\[Phi]0],
rp\[CapitalOmega] is the reflected upper sideband refl[\[Phi]usb],
rm\[CapitalOmega] is the reflected lower sideband refl[\[Phi]lsb].\
\>", "Text",
 CellChangeTimes->{{3.9828377452655163`*^9, 3.982837754348102*^9}, {
  3.982837796726343*^9, 3.98283781041181*^9}, {3.982837916524397*^9, 
  3.982837926953569*^9}, {3.982837994610096*^9, 
  3.982837995561178*^9}},ExpressionUUID->"99f026fa-c3e7-433d-922b-\
4abe9b3ac37f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"reflparams", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r0", "->", 
      RowBox[{"refl", "[", "\[Phi]0", "]"}]}], ",", 
     RowBox[{"rp\[CapitalOmega]", "->", 
      RowBox[{"refl", "[", "\[Phi]usb", "]"}]}], ",", 
     RowBox[{"rm\[CapitalOmega]", "->", 
      RowBox[{"refl", "[", "\[Phi]lsb", "]"}]}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.982837946005549*^9, 3.9828379781575336`*^9}, 
   3.982838019377317*^9},
 CellLabel->"In[90]:=",ExpressionUUID->"ee02a48a-58fc-45da-8970-2d7476546a10"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Erefltotal", "=", 
   RowBox[{"Ein", 
    RowBox[{"(", 
     RowBox[{"r0", "+", 
      RowBox[{"I", " ", 
       FractionBox["\[CapitalGamma]", "2"], "rp\[CapitalOmega]", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "\[CapitalOmega]", " ", "t"}], "]"}]}], "+", 
      RowBox[{"I", " ", "rm\[CapitalOmega]", 
       FractionBox["\[CapitalGamma]", "2"], 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", "\[CapitalOmega]", " ", "t"}], "]"}]}]}], 
     ")"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9828376623924427`*^9, 3.982837736039596*^9}, 
   3.982837902604951*^9},
 CellLabel->"In[91]:=",ExpressionUUID->"34395d32-58ff-428a-9900-b96eb5329416"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "4. Write down the cavity total reflected power ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "refl"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a75947ed-d0f0-4eff-ac34-f6cb5f33876a"],
 " (t) in terms of the reflection function r(\[Phi])\n\nand \[Phi]0 , \
\[Phi]usb , \[Phi]lsb ."
}], "Subsubsection",
 CellChangeTimes->{
  3.982838033496778*^9, {3.982839664950506*^9, 
   3.982839669175662*^9}},ExpressionUUID->"c8de6e80-64e1-4c21-a19d-\
b493b1e0d1eb"],

Cell["\<\
Use ComplexExpand, which assumes all variables are real variables, with \
Conjugate to quickly calculate our power.\[LineSeparator]However, in \
Mathematica we need to be careful because r0, rusb, and rlsb are NOT real \
variables, they are complex.\[LineSeparator]So when we take the complex \
conjugate we need to keep track of them.\[LineSeparator]\[LineSeparator]I \
keep track of this manually below, by replacing r0, rusb, and rlsb with r0c, \
rusbc, and rlsbc, where the \[OpenCurlyDoubleQuote]c\[CloseCurlyDoubleQuote] \
suffix indicates complex conjugate.  \[LineSeparator]Not elegant but it \
works.
\[LineSeparator]TrigToExp expands our trig expressions we get from \
FullSimplify into exponentials, which is easier to reach given our starting \
point\
\>", "Text",
 CellChangeTimes->{{3.982838048982106*^9, 3.982838092287428*^9}, {
  3.982838209309828*^9, 3.9828382409621153`*^9}, {3.982838331595724*^9, 
  3.982838450909442*^9}, {3.982839223653892*^9, 
  3.982839247871666*^9}},ExpressionUUID->"31297a90-51db-4d8b-af85-\
3e615bd9c1dc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"reflcparams", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r0c", "->", 
      RowBox[{"refl", "[", 
       RowBox[{"-", "\[Phi]0"}], "]"}]}], ",", 
     RowBox[{"rp\[CapitalOmega]c", "->", 
      RowBox[{"refl", "[", 
       RowBox[{"-", "\[Phi]usb"}], "]"}]}], ",", 
     RowBox[{"rm\[CapitalOmega]c", "->", 
      RowBox[{"refl", "[", 
       RowBox[{"-", "\[Phi]lsb"}], "]"}]}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.982840675879197*^9, 3.9828406883299837`*^9}},
 CellLabel->
  "In[117]:=",ExpressionUUID->"63ae62ee-93e1-416b-b0db-6132dedb33c3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Erefltotalc", "=", 
  RowBox[{
   RowBox[{"TrigToExp", "[", 
    RowBox[{"ComplexExpand", "[", 
     RowBox[{"Conjugate", "[", "Erefltotal", "]"}], "]"}], "]"}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r0", "->", "r0c"}], ",", 
     RowBox[{"rp\[CapitalOmega]", "->", "rp\[CapitalOmega]c"}], ",", 
     RowBox[{"rm\[CapitalOmega]", "->", "rm\[CapitalOmega]c"}]}], 
    "}"}]}]}]], "Input",
 CellChangeTimes->{{3.982838461454979*^9, 3.982838462563089*^9}, {
  3.982839172108532*^9, 3.98283920449039*^9}},
 CellLabel->
  "In[100]:=",ExpressionUUID->"12b70a5a-974a-4037-b4ae-ffe278cce40c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[Omega]0"}]], " ", "E0",
    " ", "r0c"}], "-", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}], "-", 
     RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[Omega]0"}]}]], " ", "E0", " ",
    "rm\[CapitalOmega]c", " ", "\[CapitalGamma]"}], "-", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[CapitalOmega]"}], "-", 
     RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[Omega]0"}]}]], " ", "E0", " ",
    "rp\[CapitalOmega]c", " ", "\[CapitalGamma]"}]}]], "Output",
 CellChangeTimes->{{3.9828391926476183`*^9, 3.9828392047523823`*^9}},
 CellLabel->
  "Out[100]=",ExpressionUUID->"1941eb0d-c26f-49c5-b1ff-913f12b2cc9b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Prefltotal", "=", 
  RowBox[{"TrigToExp", "[", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"ComplexExpand", "[", 
     RowBox[{"Erefltotal", " ", "Erefltotalc"}], "]"}], "]"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.982838042701868*^9, 3.9828380441908407`*^9}, {
   3.982838096511511*^9, 3.98283820015042*^9}, 3.982839254315651*^9},
 CellLabel->
  "In[101]:=",ExpressionUUID->"b1769ff9-f36a-4942-b155-7e0205e330f9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["E0", "2"], " ", "r0", " ", "r0c"}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[CapitalOmega]"}]], " ", 
   SuperscriptBox["E0", "2"], " ", "r0c", " ", "rm\[CapitalOmega]", " ", 
   "\[CapitalGamma]"}], "-", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]], " ", 
   SuperscriptBox["E0", "2"], " ", "r0", " ", "rm\[CapitalOmega]c", " ", 
   "\[CapitalGamma]"}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]], " ", 
   SuperscriptBox["E0", "2"], " ", "r0c", " ", "rp\[CapitalOmega]", " ", 
   "\[CapitalGamma]"}], "-", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[CapitalOmega]"}]], " ", 
   SuperscriptBox["E0", "2"], " ", "r0", " ", "rp\[CapitalOmega]c", " ", 
   "\[CapitalGamma]"}], "+", 
  RowBox[{
   FractionBox["1", "4"], " ", 
   SuperscriptBox["E0", "2"], " ", "rm\[CapitalOmega]", " ", 
   "rm\[CapitalOmega]c", " ", 
   SuperscriptBox["\[CapitalGamma]", "2"]}], "+", 
  RowBox[{
   FractionBox["1", "4"], " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"2", " ", "\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]], 
   " ", 
   SuperscriptBox["E0", "2"], " ", "rm\[CapitalOmega]c", " ", 
   "rp\[CapitalOmega]", " ", 
   SuperscriptBox["\[CapitalGamma]", "2"]}], "+", 
  RowBox[{
   FractionBox["1", "4"], " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "t", " ", 
     "\[CapitalOmega]"}]], " ", 
   SuperscriptBox["E0", "2"], " ", "rm\[CapitalOmega]", " ", 
   "rp\[CapitalOmega]c", " ", 
   SuperscriptBox["\[CapitalGamma]", "2"]}], "+", 
  RowBox[{
   FractionBox["1", "4"], " ", 
   SuperscriptBox["E0", "2"], " ", "rp\[CapitalOmega]", " ", 
   "rp\[CapitalOmega]c", " ", 
   SuperscriptBox["\[CapitalGamma]", "2"]}]}]], "Output",
 CellChangeTimes->{3.982838200711499*^9, 3.982839257548744*^9},
 CellLabel->
  "Out[101]=",ExpressionUUID->"03869ca8-a099-49e2-ae9b-0f877571202e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Prefltotal", "=", 
  RowBox[{"Prefltotal", "/.", 
   RowBox[{"{", 
    RowBox[{
     SuperscriptBox["\[CapitalGamma]", "2"], "->", "0"}], "}"}]}]}]], "Input",\

 CellChangeTimes->{{3.982838290083271*^9, 3.982838303289791*^9}},
 CellLabel->
  "In[102]:=",ExpressionUUID->"94ecba30-3347-431c-97e2-f2c498c9d09a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["E0", "2"], " ", "r0", " ", "r0c"}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[CapitalOmega]"}]], " ", 
   SuperscriptBox["E0", "2"], " ", "r0c", " ", "rm\[CapitalOmega]", " ", 
   "\[CapitalGamma]"}], "-", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]], " ", 
   SuperscriptBox["E0", "2"], " ", "r0", " ", "rm\[CapitalOmega]c", " ", 
   "\[CapitalGamma]"}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]], " ", 
   SuperscriptBox["E0", "2"], " ", "r0c", " ", "rp\[CapitalOmega]", " ", 
   "\[CapitalGamma]"}], "-", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[CapitalOmega]"}]], " ", 
   SuperscriptBox["E0", "2"], " ", "r0", " ", "rp\[CapitalOmega]c", " ", 
   "\[CapitalGamma]"}]}]], "Output",
 CellChangeTimes->{3.982838303698707*^9, 3.9828392626209993`*^9},
 CellLabel->
  "Out[102]=",ExpressionUUID->"8028ed32-ae19-44fe-b13f-916a6cc47b67"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "5. Set the coefficient for ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{
     RowBox[{"-", "i"}], " ", "\[CapitalOmega]", " ", "t"}]], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "68d47d51-5f38-407d-a322-b5a66252d2c6"],
 " equal to some complex number z, and the coefficient for ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{"i", " ", "\[CapitalOmega]", " ", "t"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d796860b-00cb-4a14-ac29-4022d8a8a031"],
 " equal to y.  What is z and y?  \[LineSeparator]Is there any connection \
between z and y? \[LineSeparator]What is it?"
}], "Subsubsection",
 CellChangeTimes->{{3.9828382667613363`*^9, 3.9828382788493557`*^9}, {
  3.982839340013721*^9, 3.98283936109914*^9}, {3.982839452911888*^9, 
  3.982839465100135*^9}},ExpressionUUID->"5e709c4a-3ba7-41a1-8aab-\
dd0008c7e8d8"],

Cell[TextData[{
 "First, Collect our ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "refl"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0003f077-e156-4da4-9cc5-3f4fc8133202"],
 "(t) by using ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{
     RowBox[{"-", "i"}], " ", "\[CapitalOmega]", " ", "t"}]], 
   TraditionalForm]],ExpressionUUID->"47122079-4599-4115-82d0-0b9ff56292ba"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{"i", " ", "\[CapitalOmega]", " ", "t"}]], TraditionalForm]],
  ExpressionUUID->"73adc7ce-3b7e-4cc9-a045-2f4f5e218ba4"],
 " coefficients."
}], "Text",
 CellChangeTimes->{{3.982839311533691*^9, 3.982839331107094*^9}, {
  3.982839388237138*^9, 
  3.9828393988548117`*^9}},ExpressionUUID->"3f2de56b-7594-41d7-a62e-\
0fe41b170830"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Collect", "[", 
  RowBox[{"Prefltotal", ",", 
   RowBox[{"{", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]], ",", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[CapitalOmega]"}]]}], 
    "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9828392686522923`*^9, 3.9828392918017197`*^9}},
 CellLabel->
  "In[105]:=",ExpressionUUID->"4ad33a63-6f4f-45ed-8dc6-2039fab940b7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["E0", "2"], " ", "r0", " ", "r0c"}], "+", 
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       FractionBox["1", "2"]}], " ", "\[ImaginaryI]", " ", 
      SuperscriptBox["E0", "2"], " ", "r0", " ", "rm\[CapitalOmega]c", " ", 
      "\[CapitalGamma]"}], "+", 
     RowBox[{
      FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
      SuperscriptBox["E0", "2"], " ", "r0c", " ", "rp\[CapitalOmega]", " ", 
      "\[CapitalGamma]"}]}], ")"}]}], "+", 
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[CapitalOmega]"}]], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
      SuperscriptBox["E0", "2"], " ", "r0c", " ", "rm\[CapitalOmega]", " ", 
      "\[CapitalGamma]"}], "-", 
     RowBox[{
      FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
      SuperscriptBox["E0", "2"], " ", "r0", " ", "rp\[CapitalOmega]c", " ", 
      "\[CapitalGamma]"}]}], ")"}]}]}]], "Output",
 CellChangeTimes->{3.9828394020597057`*^9},
 CellLabel->
  "Out[105]=",ExpressionUUID->"c9f8ebc4-64d8-45ac-904c-9e7cc382c36b"]
}, Open  ]],

Cell[TextData[{
 "The first term above is the DC term, the second term associated with ",
 Cell[BoxData[
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]]], "Output",
  CellChangeTimes->{3.9828394020597057`*^9},ExpressionUUID->
  "486ace04-d9ff-4a37-b928-825ce517c9b8"],
 " is the ",
 StyleBox["y",
  FontSlant->"Italic"],
 " term, and the third term associated with ",
 Cell[BoxData[
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[CapitalOmega]"}]]], 
  "Output",
  GeneratedCell->False,
  CellAutoOverwrite->False,
  CellChangeTimes->{3.9828394020597057`*^9},ExpressionUUID->
  "9ca5ff2b-ad5e-4e11-908c-f22594d1bd2c"],
 " is the ",
 StyleBox["z",
  FontSlant->"Italic"],
 " term:"
}], "Text",
 CellChangeTimes->{{3.982839410558157*^9, 3.982839415776618*^9}, {
  3.982839467637995*^9, 3.982839488277809*^9}, {3.9828400331384573`*^9, 
  3.9828400518079844`*^9}},ExpressionUUID->"86da1879-18e1-4bcb-9aad-\
0d9b02d1ba72"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"z", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
      SuperscriptBox["E0", "2"], " ", "r0c", " ", "rm\[CapitalOmega]", " ", 
      "\[CapitalGamma]"}], "-", 
     RowBox[{
      FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
      SuperscriptBox["E0", "2"], " ", "r0", " ", "rp\[CapitalOmega]c", " ", 
      "\[CapitalGamma]"}]}], ")"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"y", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       FractionBox["1", "2"]}], " ", "\[ImaginaryI]", " ", 
      SuperscriptBox["E0", "2"], " ", "r0", " ", "rm\[CapitalOmega]c", " ", 
      "\[CapitalGamma]"}], "+", 
     RowBox[{
      FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
      SuperscriptBox["E0", "2"], " ", "r0c", " ", "rp\[CapitalOmega]", " ", 
      "\[CapitalGamma]"}]}], ")"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.982839490268216*^9, 3.9828395593886337`*^9}},
 CellLabel->
  "In[108]:=",ExpressionUUID->"587a357d-a099-4de8-9626-d2e37924c066"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
  SuperscriptBox["E0", "2"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"r0c", " ", "rm\[CapitalOmega]"}], "-", 
    RowBox[{"r0", " ", "rp\[CapitalOmega]c"}]}], ")"}], " ", 
  "\[CapitalGamma]"}]], "Output",
 CellChangeTimes->{{3.982839552497891*^9, 3.982839559647257*^9}},
 CellLabel->
  "Out[108]=",ExpressionUUID->"11cde21b-a893-4775-82ce-255728dbc54a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox["1", "2"]}], " ", "\[ImaginaryI]", " ", 
  SuperscriptBox["E0", "2"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"r0", " ", "rm\[CapitalOmega]c"}], "-", 
    RowBox[{"r0c", " ", "rp\[CapitalOmega]"}]}], ")"}], " ", 
  "\[CapitalGamma]"}]], "Output",
 CellChangeTimes->{{3.982839552497891*^9, 3.982839559652199*^9}},
 CellLabel->
  "Out[109]=",ExpressionUUID->"ab5eb2a5-e198-46ab-b0ea-264d95ad9f0e"]
}, Open  ]],

Cell[TextData[{
 "Analyzing ",
 StyleBox["z",
  FontSlant->"Italic"],
 " and ",
 StyleBox["y ",
  FontSlant->"Italic"],
 "we see that y is the complex conjugate of z.  \[LineSeparator]We can write ",
 StyleBox["y",
  FontSlant->"Italic"],
 " = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["z", "*"], TraditionalForm]],
  InitializationCell->True,
  FormatType->TraditionalForm,ExpressionUUID->
  "a1da5927-f4fb-4a17-ba8f-9cbdb32d43e7"],
 "."
}], "Text",
 CellChangeTimes->{{3.9828395655113993`*^9, 
  3.982839633409687*^9}},ExpressionUUID->"c8206987-8ceb-4190-ae3d-\
3bd5a47b2bb8"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "6. Rewrite ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "refl"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2cd633b2-9f1a-4464-8d37-bddac008c438"],
 " in terms of z and y."
}], "Subsubsection",
 CellChangeTimes->{{3.9828396534620743`*^9, 
  3.9828396600887833`*^9}},ExpressionUUID->"5b9601fd-4065-4929-8464-\
a0c0ee38160c"],

Cell[BoxData[
 RowBox[{"Prefl", "=", 
  RowBox[{
   RowBox[{
    SuperscriptBox["E0", "2"], " ", "r0", " ", "r0c"}], "+", 
   RowBox[{
    SuperscriptBox["z", "*"], " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]]}], " ", "+", 
   RowBox[{"z", " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[CapitalOmega]"}]], 
    " "}]}]}]], "Text",
 CellChangeTimes->{{3.982839684198669*^9, 3.982839768571375*^9}, {
  3.9828400124431458`*^9, 
  3.982840016443657*^9}},ExpressionUUID->"d427fa3d-9f8e-4657-852c-\
7cf0c9cedac4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "7. ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "I"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "22448c68-4128-47b5-a864-c745cdccace0"],
 " + ",
 StyleBox["i",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "Q"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ce0c6a9e-f574-4bb7-aa05-d13c424ebb6f"],
 " = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["P", "\[CapitalOmega]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a2914589-f487-483c-ad4d-27884e9a495c"],
 " . Show we can rewrite the demodulation in this way."
}], "Subsubsection",
 CellChangeTimes->{{3.982839772430594*^9, 3.982839775036393*^9}, {
  3.9828398206056223`*^9, 
  3.9828398692536373`*^9}},ExpressionUUID->"6ce1d7fd-c369-4462-8403-\
dd9bf3435789"],

Cell[TextData[{
 "Cos[\[CapitalOmega]t]+i Sin[\[CapitalOmega]t] = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{"i", " ", "\[CapitalOmega]", " ", "t"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "359e1a87-337c-4161-a13f-abaa2e8d43f7"],
 ", so we can combine our two real demodulations into a single complex \
demodulation.  This will gives us a complex number whose real and imaginary \
parts represent our usual I and Q outputs."
}], "Text",
 CellChangeTimes->{{3.98283987746362*^9, 
  3.982839967237892*^9}},ExpressionUUID->"1ef41cb4-de83-4cd9-93c1-\
9ca831dd9d40"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "8. Calculate the 1\[CapitalOmega] demodulated power ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["P", "refl"], "\[CapitalOmega]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b5fda350-0231-4655-979f-1e7741cc37eb"],
 "(\[Phi]0, \[Phi]\n\nusb , \[Phi]lsb). \[LineSeparator]What can we see pops \
out?"
}], "Subsubsection",
 CellChangeTimes->{{3.982839976249064*^9, 3.982839999019126*^9}, {
  3.982840217462164*^9, 
  3.982840227633367*^9}},ExpressionUUID->"c9cf949b-9b24-499c-86c4-\
6903c6349cbd"],

Cell[TextData[{
 "Looking at our Prefl expression above:\[LineSeparator]",
 Cell[BoxData[
  RowBox[{"Prefl", "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox["E0", "2"], " ", "r0", " ", "r0c"}], "+", 
    RowBox[{
     SuperscriptBox["z", "*"], " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]]}], " ", 
    "+", 
    RowBox[{"z", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[CapitalOmega]"}]], 
     " "}]}]}]], "Text",
  CellChangeTimes->{{3.982839684198669*^9, 3.982839768571375*^9}, {
   3.9828400124431458`*^9, 3.982840016443657*^9}},ExpressionUUID->
  "f68b334f-133f-4e33-ab87-9dfbf09f6e2f"],
 "\[LineSeparator]it\[CloseCurlyQuote]s clear that if we multiply by ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{"i", " ", "\[CapitalOmega]", " ", "t"}]], TraditionalForm]],
  ExpressionUUID->"d0377c44-b8f4-47b0-94c3-f4744503f924"],
 " and integrate Prefl by one cycle in \[CapitalOmega]t, the DC term and ",
 Cell[BoxData[
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]]], "Text",
  CellChangeTimes->{{3.982839684198669*^9, 3.982839768571375*^9}, {
   3.9828400124431458`*^9, 3.982840016443657*^9}},ExpressionUUID->
  "5e5b975e-d33e-4582-9bbd-0198ae3d3e97"],
 " will go to ",
 Cell[BoxData[
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]]], "Text",
  CellChangeTimes->{{3.982839684198669*^9, 3.982839768571375*^9}, {
   3.9828400124431458`*^9, 3.982840016443657*^9}},ExpressionUUID->
  "c6b8af5e-5684-495d-8e7e-127c12a94aa8"],
 " and ",
 Cell[BoxData[
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"2", "\[ImaginaryI]", " ", "t", " ", "\[CapitalOmega]"}]]], "Text",
  
  CellChangeTimes->{{3.982839684198669*^9, 3.982839768571375*^9}, {
   3.9828400124431458`*^9, 3.982840016443657*^9}},ExpressionUUID->
  "e5854b00-c59d-46f7-adc2-781fe9b204ea"],
 ", and will integrate to zero over one \
cycle.\[LineSeparator]\[LineSeparator]BUT the ",
 Cell[BoxData[
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", "t", " ", "\[CapitalOmega]"}]]], 
  "Text",
  CellChangeTimes->{{3.982839684198669*^9, 3.982839768571375*^9}, {
   3.9828400124431458`*^9, 3.982840016443657*^9}},ExpressionUUID->
  "f4853a53-1e49-48a0-aa38-5204490b1015"],
 " term goes to stationary in time, so we should get exactly ",
 StyleBox["z ",
  FontSlant->"Italic"],
 "out of our demodulation:\n",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["P", "refl"], "\[CapitalOmega]"], TraditionalForm]],
  FontWeight->"Bold",
  FontSlant->"Italic",
  FontVariations->{"Underline"->False},ExpressionUUID->
  "ffa4116a-ad85-433b-a03a-f438694dfb78"],
 StyleBox[" = z.",
  FontWeight->"Bold",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.982840070637429*^9, 3.9828402402963037`*^9}, {
  3.9828402758018303`*^9, 3.982840311955018*^9}, {3.982840368450182*^9, 
  3.9828403715416803`*^9}},ExpressionUUID->"05e40f82-4f2d-4288-9a75-\
cea682870607"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Prefl\[CapitalOmega]", "=", "z"}]], "Input",
 CellChangeTimes->{{3.9828402532196703`*^9, 3.982840273340438*^9}, {
  3.982840314466776*^9, 3.9828403155703363`*^9}},
 CellLabel->
  "In[113]:=",ExpressionUUID->"af488de4-a703-456a-9c2f-488bb83d100e"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
  SuperscriptBox["E0", "2"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"r0c", " ", "rm\[CapitalOmega]"}], "-", 
    RowBox[{"r0", " ", "rp\[CapitalOmega]c"}]}], ")"}], " ", 
  "\[CapitalGamma]"}]], "Output",
 CellChangeTimes->{3.9828403158745327`*^9},
 CellLabel->
  "Out[113]=",ExpressionUUID->"ed3ea44d-c498-4fc5-9523-44f44fb4523f"]
}, Open  ]]
}, Open  ]],

Cell[TextData[{
 "9. Calculate the derivative of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["P", "refl"], "\[CapitalOmega]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "39f108d3-d1c2-4df9-883d-80fecde42b16"],
 " with respect to \[Phi]0, then evaluate it about zero."
}], "Subsubsection",
 CellChangeTimes->{{3.982840345000018*^9, 
  3.982840386858141*^9}},ExpressionUUID->"b27bffd9-e254-46b2-abe1-\
6401ce482115"],

Cell[CellGroupData[{

Cell[TextData[{
 "10. Plot the real and imaginary parts of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["P", "refl"], "\[CapitalOmega]"], TraditionalForm]],
  ExpressionUUID->"6c29f7a0-d20f-4fd5-8a79-9ace5ae7dc69"],
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["\[Phi]", "0"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0ee28bd2-7a78-4be0-b19e-3c6d25abcc8a"],
 "\n\n \[Phi]usb , \[Phi]lsb ) as a function of \[Phi]0 \[Element] [\[Minus]\
\[Pi], \[Pi]]."
}], "Subsubsection",
 CellChangeTimes->{{3.982840514886335*^9, 
  3.982840549179119*^9}},ExpressionUUID->"e0848857-f042-4fdb-aa39-\
cdd3d492c731"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"values", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"L", "->", "1"}], ",", 
    RowBox[{"T1", "->", "0.2"}], ",", 
    RowBox[{"T2", "->", "0.2"}], ",", 
    RowBox[{"r1", "->", 
     SqrtBox[
      RowBox[{"1", "-", "T1"}]]}], ",", 
    RowBox[{"r2", "->", 
     SqrtBox[
      RowBox[{"1", "-", "T2"}]]}], ",", "\[IndentingNewLine]", 
    RowBox[{"E0", "->", "1"}], ",", 
    RowBox[{"\[CapitalGamma]", "->", "0.1"}], ",", 
    RowBox[{"\[Phi]usb", "->", 
     FractionBox["\[Pi]", "2"]}], ",", 
    RowBox[{"\[Phi]lsb", "->", 
     RowBox[{"-", 
      FractionBox["\[Pi]", "2"]}]}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.9828405932100897`*^9, 3.982840645574418*^9}, {
  3.982840708695513*^9, 3.98284073147583*^9}},
 CellLabel->
  "In[119]:=",ExpressionUUID->"587a75c5-eae5-4fb8-a6cb-57e986f3e55d"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"L", "\[Rule]", "1"}], ",", 
   RowBox[{"T1", "\[Rule]", "0.2`"}], ",", 
   RowBox[{"T2", "\[Rule]", "0.2`"}], ",", 
   RowBox[{"r1", "\[Rule]", 
    SqrtBox[
     RowBox[{"1", "-", "T1"}]]}], ",", 
   RowBox[{"r2", "\[Rule]", 
    SqrtBox[
     RowBox[{"1", "-", "T2"}]]}], ",", 
   RowBox[{"E0", "\[Rule]", "1"}], ",", 
   RowBox[{"\[CapitalGamma]", "\[Rule]", "0.1`"}], ",", 
   RowBox[{"\[Phi]usb", "\[Rule]", 
    FractionBox["\[Pi]", "2"]}], ",", 
   RowBox[{"\[Phi]lsb", "\[Rule]", 
    RowBox[{"-", 
     FractionBox["\[Pi]", "2"]}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.982840646108972*^9, 3.982840740547327*^9},
 CellLabel->
  "Out[119]=",ExpressionUUID->"dcbcd84b-82ac-459b-a65d-97cc8430cd48"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"plotPrefl\[CapitalOmega]", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Prefl\[CapitalOmega]", "/.", "reflparams"}], "/.", 
     "reflcparams"}], "/.", "params"}], "//.", "values"}]}]], "Input",
 CellChangeTimes->{{3.9828405584796143`*^9, 3.982840590885048*^9}, {
  3.982840698224666*^9, 3.9828406985859823`*^9}, {3.982840742902776*^9, 
  3.9828407441195507`*^9}},
 CellLabel->
  "In[120]:=",ExpressionUUID->"c937ff51-f91f-4bd1-b41a-f48bce0ae7d3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{"0.`", "\[VeryThinSpace]", "+", 
    RowBox[{"0.05`", " ", "\[ImaginaryI]"}]}], ")"}], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"0.9938079899999066`", " ", 
       RowBox[{"(", 
        RowBox[{"0.8944271909999159`", "\[VeryThinSpace]", "-", 
         RowBox[{"0.8944271909999159`", " ", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]0"}]]}]}], 
        ")"}]}], 
      RowBox[{"1", "-", 
       RowBox[{"0.7999999999999999`", " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]0"}]]}]}]]}], 
    "+", 
    FractionBox[
     RowBox[{"0.9938079899999066`", " ", 
      RowBox[{"(", 
       RowBox[{"0.8944271909999159`", "\[VeryThinSpace]", "-", 
        RowBox[{"0.8944271909999159`", " ", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]0"}]]}]}], ")"}]}], 
     RowBox[{"1", "-", 
      RowBox[{"0.7999999999999999`", " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]0"}]]}]}]]}], 
   ")"}]}]], "Output",
 CellChangeTimes->{3.982840584803422*^9, 3.982840647250764*^9, 
  3.9828406994441423`*^9, 3.98284074619379*^9},
