Cell[CellGroupData[{

Cell[TextData[{
 "Manipulate plot of PDH error signal ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["P", "refl"], "\[CapitalGamma]"], 
    RowBox[{"(", 
     RowBox[{"\[Phi]0", ",", "\[Phi]rf"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cabbb77f-2a9d-402d-9023-5cf67d312110"]
}], "Subsubsection",
 CellChangeTimes->{{3.982848119996282*^9, 3.982848140228861*^9}, {
  3.982848287108398*^9, 
  3.982848318039877*^9}},ExpressionUUID->"147c57af-c8b2-43dd-bd8f-\
731764c73cd8"],

Cell[TextData[{
 "For fun, in the manipulate plot, I\[CloseCurlyQuote]ve added in the Demod \
Angle \[Zeta], which is just a simple rotation of the detected I and Q \
quadrature.\[LineSeparator]The way to consider the demod phase is similar to \
the arbitrary phase accrued while transmitting to the photodetector.\nWe can \
explicitly consider it while demodulating by demodulating over Cos[\
\[CapitalOmega]t+\[Zeta]] and Sin[\[CapitalOmega]t+\[Zeta]].  \nIf we set \
\[Zeta] = ",
 Cell[BoxData[
  FormBox[
   FractionBox["\[Pi]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d539d0c2-59ae-4049-9157-0748aefa6d2f"],
 ", we\[CloseCurlyQuote]ll flip which quadrature our signal is in."
}], "Text",
 CellChangeTimes->{{3.982854175553195*^9, 
  3.9828543670858088`*^9}},ExpressionUUID->"683e6eb6-4a45-41b6-83de-\
5e956ec8e948"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"manivalues2", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"L", "->", "1"}], ",", 
    RowBox[{"r1", "->", 
     SqrtBox[
      RowBox[{"1", "-", "T1"}]]}], ",", 
    RowBox[{"r2", "->", 
     SqrtBox[
      RowBox[{"1", "-", "T2"}]]}], ",", 
    RowBox[{"E0", "->", "1"}], ",", 
    RowBox[{"\[Phi]usb", "->", 
     RowBox[{"\[Phi]0", "+", "\[Phi]rf"}]}], ",", 
    RowBox[{"\[Phi]lsb", "->", 
     RowBox[{"\[Phi]0", "-", "\[Phi]rf"}]}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.9828481712619047`*^9, 3.982848207706387*^9}, 
   3.982848241215576*^9, {3.982848349039033*^9, 3.982848363890791*^9}},
 CellLabel->
  "In[144]:=",ExpressionUUID->"21a2835c-2517-4e3e-82e0-8bfbc323a8aa"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"L", "\[Rule]", "1"}], ",", 
   RowBox[{"r1", "\[Rule]", 
    SqrtBox[
     RowBox[{"1", "-", "T1"}]]}], ",", 
   RowBox[{"r2", "\[Rule]", 
    SqrtBox[
     RowBox[{"1", "-", "T2"}]]}], ",", 
   RowBox[{"E0", "\[Rule]", "1"}], ",", 
   RowBox[{"\[Phi]usb", "\[Rule]", 
    RowBox[{"\[Phi]0", "+", "\[Phi]rf"}]}], ",", 
   RowBox[{"\[Phi]lsb", "\[Rule]", 
    RowBox[{"\[Phi]0", "-", "\[Phi]rf"}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.982848364594748*^9},
 CellLabel->
  "Out[144]=",ExpressionUUID->"960066e1-87ce-4a75-b689-5a23a2d1aeca"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"maniPrefl\[CapitalOmega]", "[", 
   RowBox[{
   "\[Phi]0_", ",", "\[Phi]rf_", ",", "\[CapitalGamma]_", ",", "T1_", ",", 
    "T2_"}], "]"}], ":=", 
  RowBox[{"Evaluate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Prefl\[CapitalOmega]", "/.", "reflparams"}], "/.", 
     "reflcparams"}], "//.", "manivalues2"}], "]"}]}]], "Input",
