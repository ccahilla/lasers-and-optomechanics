Cell[CellGroupData[{

Cell[TextData[{
 "11. Plot ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["P", "refl"], "\[CapitalOmega]"], TraditionalForm]],
  ExpressionUUID->"fc194bc1-6af0-4142-a392-b1b40a8560eb"],
 " as a phasor as a function of \[CurlyPhi]0 \[Element] [\[Minus] ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["\[Pi]", "2"], ",", 
    FractionBox["\[Pi]", "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1657b358-eaac-407d-9eec-b6568ef2a08c"],
 "]"
}], "Subsubsection",
 CellChangeTimes->{{3.982853043426242*^9, 3.982853048039666*^9}, {
  3.9828532005854197`*^9, 
  3.9828532279496326`*^9}},ExpressionUUID->"96ff9191-138b-4d57-90bc-\
4c06c3f16503"],

Cell[TextData[{
 "Below we evaluate our ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    SuperscriptBox["P", "\[CapitalOmega]"], "refl"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b0bdf4d5-5e24-4cf4-9b8c-c7bfec1e296c"],
 " signal as a phasor.\[LineSeparator]The carrier resonance is the line \
almost perfectly along the real axis.\[LineSeparator]The circles are the RF \
sideband sidelobes.\[LineSeparator]\[LineSeparator]Those circles are \
representative of the reflection of the RF sidebands off the cavity, rotated \
by either + or -90\[Degree].  \[LineSeparator]If we increase the cavity \
finesse by lowering the mirror transmission T2 or T1, our signals get \
stronger and cleaner,\[LineSeparator]as the improved finesse of the cavity \
shrinks the size of the resonance, preventing mixing."
}], "Text",
 CellChangeTimes->{{3.9828551123006496`*^9, 3.982855119250855*^9}, {
  3.982855155760871*^9, 
  3.9828553643535557`*^9}},ExpressionUUID->"3c089390-ea90-469c-96a7-\
a36f94799ad4"],

